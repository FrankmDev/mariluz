---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';
import { CheckCircle, ArrowLeft, MessageCircle } from 'lucide-astro';
---

<Layout
  title="Mensaje enviado"
  description="Gracias por contactar con luzaria. Mariluz estudiará tu factura y te responderá con una explicación clara antes de cualquier decisión."
  noindex={true}
>
  <main class="page-wrapper">
    <div class="glass-card">
      <div class="card-specular"></div>
      <div class="card-content">
        <div class="success-icon">
          <CheckCircle size={48} stroke-width={1.5} aria-hidden="true" />
        </div>

        <h1 class="title">Mensaje enviado</h1>
        <p class="subtitle">
          Gracias por contactar conmigo. He recibido tu solicitud y estudiaré tu factura antes de proponerte cualquier decisión.
        </p>

        <div class="divider"></div>

        <div class="next-steps">
          <p class="steps-title">¿Qué pasa ahora?</p>
          <ul class="steps-list">
            <li>
              <span class="step-check">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>Reviso tu factura y consumo real</span>
            </li>
            <li>
              <span class="step-check">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>Valoro si hay margen claro de mejora</span>
            </li>
            <li>
              <span class="step-check">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>Te explico la propuesta antes de cualquier gestión</span>
            </li>
          </ul>
        </div>

        <div class="actions">
          <a href="/" class="btn-primary">
            <ArrowLeft size={18} aria-hidden="true" />
            <span>Volver al inicio</span>
          </a>
          <a href={siteConfig.whatsappUrl} class="btn-secondary" rel="noopener noreferrer">
            <MessageCircle size={18} fill="currentColor" aria-hidden="true" />
            <span>WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </main>

  <style>
    .page-wrapper {
      min-height: 100svh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-8) var(--space-4);
    }

    .glass-card {
      position: relative;
      width: 100%;
      max-width: 520px;
      border-radius: var(--radius-2xl);
      overflow: hidden;
      background: rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
      -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
      border: 1px solid rgba(255, 255, 255, 0.72);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.98),
        inset 0 -1px 0 rgba(0, 0, 0, 0.025),
        0 4px 6px rgba(0, 0, 0, 0.04),
        0 12px 40px rgba(0, 0, 0, 0.09),
        0 32px 80px rgba(0, 0, 0, 0.06);
      text-align: center;
    }

    .card-specular {
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 55%;
      background: linear-gradient(180deg,
        rgba(255,255,255,0.92) 0%,
        rgba(255,255,255,0.45) 35%,
        rgba(255,255,255,0.10) 65%,
        transparent 100%
      );
      pointer-events: none;
      z-index: 1;
    }

    .card-content {
      position: relative;
      z-index: 2;
      padding: var(--space-10) var(--space-8);
    }

    .success-icon {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, rgba(52, 199, 89, 0.12) 0%, rgba(52, 199, 89, 0.06) 100%);
      color: var(--color-success);
      margin-bottom: var(--space-6);
      box-shadow: inset 0 0 0 1px rgba(52, 199, 89, 0.15);
    }

    .title {
      font-family: var(--font-display);
      font-size: var(--text-3xl);
      font-weight: var(--font-extrabold);
      letter-spacing: var(--tracking-tighter);
      color: var(--text-primary);
      margin: 0 0 var(--space-3);
      line-height: var(--leading-tight);
    }

    .subtitle {
      font-size: var(--text-base);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      margin: 0 auto var(--space-6);
      max-width: 380px;
    }

    .subtitle strong {
      color: var(--text-primary);
      font-weight: var(--font-semibold);
    }

    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.06) 50%, transparent 100%);
      margin: var(--space-6) 0;
      border: none;
    }

    .next-steps {
      text-align: left;
      margin-bottom: var(--space-8);
    }

    .steps-title {
      font-size: var(--text-sm);
      font-weight: var(--font-semibold);
      color: var(--text-primary);
      margin: 0 0 var(--space-3);
      text-align: center;
    }

    .steps-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .steps-list li {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      font-size: var(--text-sm);
      color: var(--text-secondary);
      font-weight: var(--font-medium);
    }

    .step-check {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--color-success) 0%, var(--green-600) 100%);
      color: white;
      flex-shrink: 0;
    }

    .actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-3);
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-6);
      border-radius: var(--radius-pill);
      background: var(--color-primary);
      color: white;
      font-family: var(--font-display);
      font-size: var(--text-base);
      font-weight: var(--font-semibold);
      text-decoration: none;
      box-shadow:
        0 4px 16px rgba(0, 122, 255, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.25);
      transition: all 0.3s var(--ease-ios-spring);
    }

    .btn-primary:hover {
      background: var(--color-primary-hover);
      transform: scale(1.04) translateY(-2px);
      box-shadow:
        0 8px 24px rgba(0, 122, 255, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.3);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-6);
      border-radius: var(--radius-pill);
      background: rgba(37, 211, 102, 0.1);
      color: #128C7E;
      font-family: var(--font-display);
      font-size: var(--text-base);
      font-weight: var(--font-semibold);
      text-decoration: none;
      border: 1px solid rgba(37, 211, 102, 0.2);
      transition: all 0.3s var(--ease-ios-spring);
    }

    .btn-secondary:hover {
      background: rgba(37, 211, 102, 0.18);
      transform: scale(1.04) translateY(-2px);
    }

    @media (max-width: 480px) {
      .card-content {
        padding: var(--space-8) var(--space-5);
      }

      .title {
        font-size: var(--text-2xl);
      }

      .actions {
        flex-direction: column;
        width: 100%;
      }

      .btn-primary,
      .btn-secondary {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</Layout>
