---
import { ArrowRight, MessageCircle, Phone } from 'lucide-astro';
import { siteConfig } from '../../config/site';

const navLinks = [
  { label: 'Cómo funciona', shortLabel: 'Proceso', caption: 'Tres pasos sencillos', href: '#como-funciona' },
  { label: 'Calculadora', shortLabel: 'Calculadora', caption: 'Estima tu ahorro', href: '#calculadora' },
  { label: 'Sobre mí', shortLabel: 'Sobre mí', caption: 'Asesoría personal', href: '#sobre-mi' },
  { label: 'FAQ', shortLabel: 'Dudas', caption: 'Respuestas rápidas', href: '#faq' },
];
---

<div id="navbar-wrapper" class="navbar-wrapper">
  <header id="navbar" class="navbar-pill" role="banner">
    <div class="navbar-specular" aria-hidden="true"></div>

    <a href="/" class="navbar-brand" aria-label="LUZARIA — Inicio">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-copy">
        <span class="brand-text">LUZARIA</span>
        <span class="brand-meta">Asesoría energética</span>
      </span>
      <span class="brand-dot">.</span>
    </a>

    <nav class="navbar-links" aria-label="Navegación principal">
      {navLinks.map((link) => (
        <a href={link.href} class="navbar-link">
          <span class="link-text">{link.label}</span>
          <span class="link-bg" aria-hidden="true"></span>
        </a>
      ))}
    </nav>

    <div class="navbar-cta-wrap">
      <a href={siteConfig.whatsappUrl} class="navbar-cta" rel="noopener noreferrer">
        <span class="cta-bg" aria-hidden="true"></span>
        <MessageCircle size={15} fill="currentColor" aria-hidden="true" style="position: relative; z-index: 1;" />
        <span class="cta-text">Contactar</span>
      </a>

      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="mobile-menu-btn-glow" aria-hidden="true"></span>
        <span class="mobile-menu-btn-label">Menú</span>
        <span class="mobile-menu-icon" aria-hidden="true">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </button>
    </div>
  </header>
</div>

<div id="mobile-menu-overlay" class="mobile-menu-overlay" aria-hidden="true"></div>

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-glow mobile-menu-glow-blue" aria-hidden="true"></div>
  <div class="mobile-menu-glow mobile-menu-glow-green" aria-hidden="true"></div>
  <div class="mobile-specular" aria-hidden="true"></div>

  <div class="mobile-sheet-handle" aria-hidden="true"></div>

  <div class="mobile-menu-top">
    <div class="mobile-menu-heading">
      <div>
        <p class="mobile-menu-title">Menú</p>
        <p class="mobile-menu-note">Mariluz García · Asesoría energética</p>
      </div>
      <span class="mobile-status-pill">
        <span class="mobile-status-dot" aria-hidden="true"></span>
        Disponible
      </span>
    </div>
  </div>

  <nav class="mobile-menu-links" aria-label="Menú móvil">
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-menu-link">
        <span class="mobile-link-bg" aria-hidden="true"></span>
        <span class="mobile-link-body">
          <span class="mobile-link-text">{link.shortLabel}</span>
          <span class="mobile-link-caption">{link.caption}</span>
        </span>
        <span class="mobile-link-arrow" aria-hidden="true">
          <ArrowRight size={18} stroke-width={2.2} />
        </span>
      </a>
    ))}
  </nav>

  <div class="mobile-menu-footer">
    <a href={siteConfig.whatsappUrl} class="mobile-cta mobile-cta-primary" rel="noopener noreferrer">
      <span class="mobile-cta-bg" aria-hidden="true"></span>
      <MessageCircle size={18} fill="currentColor" aria-hidden="true" style="position: relative; z-index: 1;" />
      <span class="mobile-cta-copy">
        <span class="mobile-cta-title">WhatsApp</span>
        <span class="mobile-cta-caption">Respuesta rápida</span>
      </span>
    </a>

    <a href={`tel:+${siteConfig.phoneClean}`} class="mobile-cta mobile-cta-secondary">
      <span class="mobile-cta-secondary-bg" aria-hidden="true"></span>
      <Phone size={18} aria-hidden="true" style="position: relative; z-index: 1;" />
      <span class="mobile-cta-copy">
        <span class="mobile-cta-title">Llamar</span>
        <span class="mobile-cta-caption">{siteConfig.phone}</span>
      </span>
    </a>
  </div>
</div>

<style>
  .navbar-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    justify-content: center;
    padding: var(--space-4) var(--space-6);
    pointer-events: none;
    transition: transform 0.5s var(--ease-ios-spring), opacity 0.4s var(--ease-ios);
  }

  .navbar-wrapper.hidden {
    transform: translateY(-100%);
    opacity: 0;
  }

  .navbar-pill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    pointer-events: auto;
    width: 100%;
    max-width: 860px;
    min-height: 4.1rem;
    position: relative;
    padding: 0.35rem 0.4rem 0.35rem 0.5rem;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(40px) saturate(220%) brightness(1.05);
    -webkit-backdrop-filter: blur(40px) saturate(220%) brightness(1.05);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 100px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 1px 2px rgba(0, 0, 0, 0.03),
      0 4px 12px rgba(0, 0, 0, 0.05),
      0 12px 40px rgba(0, 0, 0, 0.08),
      0 24px 60px rgba(0, 0, 0, 0.04);
    transition: all 0.5s var(--ease-ios-spring);
    opacity: 0;
    transform: translateY(-20px) scale(0.96);
    animation: navbarEnter 0.8s var(--ease-ios-decel) forwards;
    animation-delay: 0.2s;
  }

  @keyframes navbarEnter {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .navbar-specular {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    border-radius: 100px 100px 0 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.45) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
    opacity: 0.9;
  }

  .navbar-pill:hover {
    background: rgba(255, 255, 255, 0.82);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 2px 6px rgba(0, 0, 0, 0.04),
      0 8px 24px rgba(0, 0, 0, 0.08),
      0 20px 56px rgba(0, 0, 0, 0.1);
  }

  .navbar-pill.scrolled {
    min-height: 3.95rem;
    padding: 0.3rem 0.35rem 0.3rem 0.45rem;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(44px) saturate(240%) brightness(1.06);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 2px 6px rgba(0, 0, 0, 0.04),
      0 6px 16px rgba(0, 0, 0, 0.06),
      0 16px 44px rgba(0, 0, 0, 0.08);
  }

  .navbar-pill.scrolled .navbar-brand {
    transform: scale(0.975);
  }

  .navbar-brand {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.68rem;
    flex-shrink: 0;
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.62rem 0.72rem 0.62rem 0.34rem;
    border-radius: 999px;
    transition: all 0.3s var(--ease-ios);
  }

  .navbar-brand:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .brand-mark {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    border-radius: 999px;
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.2) 30%, transparent 65%),
      linear-gradient(145deg, rgba(90, 200, 250, 0.95), rgba(0, 122, 255, 0.9) 58%, rgba(52, 170, 220, 0.86));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.86),
      0 8px 18px rgba(0, 122, 255, 0.16);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
    min-width: 0;
  }

  .brand-text {
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .brand-meta {
    font-size: 0.68rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--label-secondary);
  }

  .brand-dot {
    align-self: flex-start;
    margin-top: -0.1rem;
    color: var(--color-primary);
    font-size: 1.5rem;
    line-height: 1;
    transition: transform 0.3s var(--ease-ios-spring);
  }

  .navbar-brand:hover .brand-dot {
    transform: scale(1.18);
  }

  .navbar-links {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-width: 0;
    gap: 0.2rem;
  }

  .navbar-link {
    position: relative;
    overflow: hidden;
    white-space: nowrap;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.72rem 0.92rem;
    border-radius: var(--radius-pill);
    transition: color 0.25s var(--ease-ios);
  }

  .link-text {
    position: relative;
    z-index: 2;
    transition: transform 0.3s var(--ease-ios-spring), color 0.25s var(--ease-ios);
  }

  .link-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0;
    transform: scale(0.92);
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: var(--radius-pill);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-primary) 10%, rgba(255, 255, 255, 0.6)) 0%,
      color-mix(in srgb, var(--ios-blue) 4%, transparent) 100%
    );
    transition: all 0.3s var(--ease-ios-spring);
  }

  .navbar-link:hover,
  .navbar-link:focus-visible,
  .navbar-link.active {
    color: var(--color-primary);
  }

  .navbar-link:hover .link-bg,
  .navbar-link:focus-visible .link-bg,
  .navbar-link.active .link-bg {
    opacity: 1;
    transform: scale(1);
  }

  .navbar-link:hover .link-text,
  .navbar-link:focus-visible .link-text {
    transform: translateY(-1px);
  }

  .navbar-link.active {
    font-weight: 600;
  }

  .navbar-link.active .link-bg {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-primary) 12%, rgba(255, 255, 255, 0.64)) 0%,
      color-mix(in srgb, var(--ios-blue) 7%, transparent) 100%
    );
  }

  .navbar-cta-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-shrink: 0;
  }

  .navbar-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    overflow: hidden;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.01em;
    padding: 0.82rem 1.05rem;
    border-radius: var(--radius-pill);
    box-shadow:
      0 4px 14px color-mix(in srgb, var(--color-primary) 32%, transparent),
      0 1px 3px color-mix(in srgb, var(--color-primary) 18%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
    transition: all 0.35s var(--ease-ios-spring);
    will-change: transform;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 50%, var(--color-primary) 100%);
    background-size: 200% 100%;
    animation: shimmer-btn 4s ease-in-out infinite;
  }

  .cta-text {
    position: relative;
    z-index: 1;
  }

  .navbar-cta:hover {
    transform: scale(1.05) translateY(-2px);
    box-shadow:
      0 8px 24px color-mix(in srgb, var(--color-primary) 45%, transparent),
      0 3px 8px color-mix(in srgb, var(--color-primary) 25%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
    letter-spacing: 0.01em;
  }

  .navbar-cta:active {
    transform: scale(0.97) translateY(0);
    transition-duration: 0.1s;
  }

  .navbar-cta:hover .cta-bg {
    animation-duration: 2.5s;
  }

  @keyframes shimmer-btn {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .mobile-menu-btn {
    display: none;
    position: relative;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 44px;
    min-width: 44px;
    height: 44px;
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.48);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.96),
      0 4px 14px rgba(0, 0, 0, 0.05);
    transition: all 0.35s var(--ease-ios-spring);
  }

  .mobile-menu-btn-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 24% 18%, rgba(90, 200, 250, 0.26), transparent 48%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.36), rgba(255, 255, 255, 0.08));
    opacity: 0.95;
    transition: opacity 0.3s var(--ease-ios);
  }

  .mobile-menu-btn-label,
  .mobile-menu-icon {
    position: relative;
    z-index: 1;
  }

  .mobile-menu-btn-label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .mobile-menu-icon {
    width: 20px;
    height: 20px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .mobile-menu-btn:hover,
  .mobile-menu-btn:focus-visible,
  .mobile-menu-btn.active {
    transform: translateY(-1px) scale(1.015);
    background: rgba(255, 255, 255, 0.66);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .mobile-menu-btn.active .mobile-menu-btn-glow {
    opacity: 1;
  }

  .hamburger-line {
    display: block;
    width: 17px;
    height: 2px;
    border-radius: 2px;
    background: var(--text-primary);
    transition: all 0.3s var(--ease-ios-spring);
  }

  .mobile-menu-btn.active .hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-menu-btn.active .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .mobile-menu-btn.active .hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 998;
    opacity: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 90% 58% at 50% 100%, rgba(0, 122, 255, 0.10), transparent 62%),
      linear-gradient(180deg, rgba(242, 245, 250, 0.10), rgba(242, 245, 250, 0.48)),
      rgba(7, 16, 32, 0.16);
    backdrop-filter: blur(16px) saturate(130%);
    -webkit-backdrop-filter: blur(16px) saturate(130%);
    transition: opacity 0.35s var(--ease-ios);
  }

  .mobile-menu-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu {
    --mobile-panel-inset: 0.72rem;
    --mobile-panel-gap: 0.52rem;
    --mobile-panel-radius: 22px;
    position: fixed;
    left: max(0.85rem, env(safe-area-inset-left));
    right: max(0.85rem, env(safe-area-inset-right));
    bottom: max(0.85rem, env(safe-area-inset-bottom));
    z-index: 999;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.76);
    backdrop-filter: blur(48px) saturate(230%) brightness(1.04);
    -webkit-backdrop-filter: blur(48px) saturate(230%) brightness(1.04);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 16px 48px rgba(0, 0, 0, 0.13),
      0 36px 90px rgba(0, 0, 0, 0.10);
    transform: translateY(18px) scale(0.975);
    transition:
      opacity 0.4s var(--ease-ios),
      transform 0.5s var(--ease-ios-spring);
  }

  .mobile-menu.open {
    max-height: none;
    opacity: 1;
    pointer-events: auto;
    overflow: hidden;
    transform: translateY(0) scale(1);
  }

  .mobile-menu-top,
  .mobile-menu-link,
  .mobile-cta {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.36s var(--ease-ios),
      transform 0.44s var(--ease-ios-spring);
  }

  .mobile-menu.open .mobile-menu-top,
  .mobile-menu.open .mobile-menu-link,
  .mobile-menu.open .mobile-cta {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu.open .mobile-menu-link:nth-child(1) { transition-delay: 0.04s; }
  .mobile-menu.open .mobile-menu-link:nth-child(2) { transition-delay: 0.07s; }
  .mobile-menu.open .mobile-menu-link:nth-child(3) { transition-delay: 0.10s; }
  .mobile-menu.open .mobile-menu-link:nth-child(4) { transition-delay: 0.13s; }
  .mobile-menu.open .mobile-cta:nth-child(1) { transition-delay: 0.16s; }
  .mobile-menu.open .mobile-cta:nth-child(2) { transition-delay: 0.19s; }

  .mobile-menu-glow {
    position: absolute;
    width: 12rem;
    height: 12rem;
    border-radius: 999px;
    filter: blur(90px);
    opacity: 0.46;
    pointer-events: none;
  }

  .mobile-menu-glow-blue {
    top: -4rem;
    right: -2.2rem;
    background: rgba(90, 200, 250, 0.38);
  }

  .mobile-menu-glow-green {
    bottom: -4.2rem;
    left: -2.4rem;
    background: rgba(52, 199, 89, 0.24);
  }

  .mobile-specular {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    border-radius: 28px 28px 0 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 255, 255, 0.42) 40%,
      rgba(255, 255, 255, 0.08) 70%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .mobile-menu-top,
  .mobile-menu-links,
  .mobile-menu-footer {
    position: relative;
    z-index: 2;
  }

  .mobile-sheet-handle {
    position: relative;
    z-index: 2;
    width: 2.7rem;
    height: 0.28rem;
    margin: 0.62rem auto 0;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.12);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .mobile-menu-top {
    padding: 0.72rem var(--mobile-panel-inset) 0.42rem;
  }

  .mobile-menu-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    min-width: 0;
  }

  .mobile-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    min-height: 2rem;
    padding: 0.35rem 0.6rem;
    flex-shrink: 0;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.68);
    background: rgba(238, 255, 245, 0.66);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 2px 8px rgba(0, 0, 0, 0.04);
    color: var(--green-700);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .mobile-status-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--ios-green), #7be495);
    box-shadow: 0 0 0 4px rgba(52, 199, 89, 0.12);
  }

  .mobile-menu-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 5.8vw, 2rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.055em;
    color: var(--label-primary);
  }

  .mobile-menu-note {
    margin: 0.2rem 0 0;
    font-size: 0.82rem;
    line-height: 1.25;
    color: var(--label-secondary);
  }

  .mobile-menu-links {
    display: flex;
    flex-direction: column;
    gap: var(--mobile-panel-gap);
    padding: 0.4rem var(--mobile-panel-inset) 0.42rem;
  }

  .mobile-menu-link {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.68rem;
    overflow: hidden;
    isolation: isolate;
    color: var(--text-primary);
    text-decoration: none;
    min-height: 4.1rem;
