---
import { siteConfig } from '../../config/site';

const navLinks = [
  { label: 'Cómo funciona', href: '#como-funciona' },
  { label: 'Calculadora', href: '#calculadora' },
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'FAQ', href: '#faq' },
];
---

<div id="navbar-wrapper" class="navbar-wrapper">
  <header id="navbar" class="navbar-pill" role="banner">

    <!-- Wordmark -->
    <a
      href="/"
      class="navbar-brand"
      aria-label="Mariluz — Inicio"
    >
      Mariluz<span class="brand-dot">.</span>
    </a>

    <!-- Desktop Links -->
    <nav class="navbar-links" aria-label="Navegación principal">
      {navLinks.map(link => (
        <a href={link.href} class="navbar-link">{link.label}</a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="navbar-cta-wrap">
      <a href={siteConfig.whatsappUrl} class="navbar-cta btn-primary btn-small btn-shimmer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Contactar
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="mobile-menu-btn md-hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>

  </header>
</div>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="mobile-menu liquid-glass"
  aria-hidden="true"
>
  <nav class="mobile-menu-links" aria-label="Menú móvil">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-menu-link">{link.label}</a>
    ))}
  </nav>
  <div class="mobile-menu-footer">
    <a href={siteConfig.whatsappUrl} class="btn-primary" style="width: 100%; justify-content: center;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Contactar por WhatsApp
    </a>
  </div>
</div>

<style>
  .navbar-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    justify-content: center;
    padding: 14px 24px;
    pointer-events: none;
    transition: transform 0.4s var(--ease-ios-spring);
  }

  .navbar-wrapper.hidden {
    transform: translateY(-100%);
  }

  .navbar-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    pointer-events: auto;
    /* Authentic Liquid Glass */
    background: rgba(250, 250, 252, 0.82);
    backdrop-filter: blur(32px) saturate(220%);
    -webkit-backdrop-filter: blur(32px) saturate(220%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    border-radius: 100px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.01),
      0 4px 20px rgba(0, 0, 0, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.03);
    padding: 7px 7px 7px 22px;
    transition: all 400ms var(--ease-ios-spring);
    max-width: 820px;
    width: 100%;
    position: relative;
  }

  /* Specular highlight */
  .navbar-pill::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    border-radius: 100px 100px 0 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(255, 255, 255, 0.3) 60%,
      transparent 100%
    );
    pointer-events: none;
  }

  .navbar-pill:hover {
    background: rgba(255, 255, 255, 0.88);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 8px 28px rgba(0, 0, 0, 0.08),
      0 2px 4px rgba(0, 0, 0, 0.04);
  }

  /* Scrolled state - compact mode */
  .navbar-pill.scrolled {
    padding: 5px 5px 5px 18px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(36px) saturate(240%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .navbar-pill.scrolled .navbar-brand {
    font-size: 1rem;
  }

  .navbar-pill.scrolled .navbar-link {
    font-size: 0.85rem;
    padding: 6px 12px;
  }

  .navbar-pill.scrolled .navbar-cta {
    padding: 8px 16px !important;
    font-size: 0.8125rem !important;
  }

  .navbar-brand {
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--label-primary);
    text-decoration: none;
    letter-spacing: -0.04em;
    flex-shrink: 0;
    transition: opacity 200ms;
  }

  .navbar-brand:hover {
    opacity: 0.65;
  }

  .brand-dot {
    color: var(--ios-blue);
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }

  .navbar-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--label-secondary);
    text-decoration: none;
    padding: 7px 14px;
    border-radius: var(--radius-pill);
    transition: all 200ms var(--ease-ios);
    white-space: nowrap;
    font-family: var(--font-display);
  }

  .navbar-link:hover {
    color: var(--label-primary);
    background: rgba(0, 0, 0, 0.04);
  }

  .navbar-cta-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .navbar-cta {
    font-size: 0.875rem !important;
    padding: 9px 18px !important;
  }

  .mobile-menu-btn {
    display: none;
    width: 36px;
    height: 36px;
    border: none;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 10px;
    cursor: pointer;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    transition: background 200ms;
    padding: 0;
  }

  .mobile-menu-btn:hover {
    background: rgba(0, 0, 0, 0.08);
  }

  .hamburger-line {
    width: 16px;
    height: 1.5px;
    background: var(--label-primary);
    border-radius: 2px;
    transition: all 300ms var(--ease-ios-spring);
    display: block;
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    top: 76px;
    left: 16px;
    right: 16px;
    z-index: 999;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transition: max-height 500ms var(--ease-ios-spring), opacity 350ms ease, transform 500ms var(--ease-ios-spring);
    transform: translateY(-10px) scale(0.97);
  }

  .mobile-menu.open {
    max-height: 400px;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .mobile-menu-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 16px 16px 8px;
  }

  .mobile-menu-link {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--label-primary);
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 14px;
    transition: background 200ms;
    font-family: var(--font-display);
  }

  .mobile-menu-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .mobile-menu-footer {
    padding: 8px 16px 16px;
    border-top: 1px solid var(--separator);
    margin-top: 4px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .navbar-wrapper {
      padding: 10px 16px;
    }

    .navbar-pill {
      padding: 6px 6px 6px 18px;
    }

    .navbar-links {
      display: none;
    }

    .navbar-cta {
      display: none !important;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }

  @media (max-width: 900px) and (min-width: 769px) {
    .navbar-link {
      padding: 7px 10px;
      font-size: 0.8375rem;
    }
  }
</style>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const navbarPill = document.querySelector('.navbar-pill');
  let lastScrollY = window.scrollY;
  let ticking = false;

  // Scroll behavior for navbar
  const updateNavbar = () => {
    const scrollY = window.scrollY;
    
    if (navbarPill) {
      if (scrollY > 100) {
        navbarPill.classList.add('scrolled');
      } else {
        navbarPill.classList.remove('scrolled');
      }
    }
    
    // Hide/show on scroll direction
    if (scrollY > lastScrollY && scrollY > 200) {
      document.querySelector('.navbar-wrapper')?.classList.add('hidden');
    } else {
      document.querySelector('.navbar-wrapper')?.classList.remove('hidden');
    }
    
    lastScrollY = scrollY;
    ticking = false;
  };

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateNavbar);
      ticking = true;
    }
  }, { passive: true });

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      mobileMenu?.classList.remove('open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
    } else {
      mobileMenu?.classList.add('open');
      mobileMenu?.setAttribute('aria-hidden', 'false');
      mobileMenuBtn.setAttribute('aria-expanded', 'true');
    }
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('click', (e) => {
    const target = e.target;
    if (
      mobileMenu?.classList.contains('open') &&
      !mobileMenu.contains(target) &&
      !mobileMenuBtn?.contains(target)
    ) {
      mobileMenu.classList.remove('open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
