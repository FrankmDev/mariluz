</style>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileOverlay = document.getElementById('mobile-menu-overlay');
  const navbarPill = document.querySelector('.navbar-pill');
  const navbarWrapper = document.querySelector('.navbar-wrapper');
  const mobileMenuLinks = document.querySelectorAll('.mobile-menu-link');
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.navbar-link, .mobile-menu-link');

  let lastScrollY = window.scrollY;
  let ticking = false;
  let scrollDirection: 'up' | 'down' = 'up';

  const syncMenuState = (isOpen: boolean) => {
    mobileMenu?.classList.toggle('open', isOpen);
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    mobileOverlay?.classList.toggle('open', isOpen);
    mobileOverlay?.setAttribute('aria-hidden', String(!isOpen));
    mobileMenuBtn?.classList.toggle('active', isOpen);
    mobileMenuBtn?.setAttribute('aria-expanded', String(isOpen));
    mobileMenuBtn?.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  };

  const openMobileMenu = () => {
    syncMenuState(true);
    const firstLink = mobileMenuLinks[0] as HTMLAnchorElement | undefined;
    firstLink?.focus();
  };

  const closeMobileMenu = () => {
    const shouldRestoreFocus = mobileMenu?.classList.contains('open');
    syncMenuState(false);

    if (shouldRestoreFocus) {
      mobileMenuBtn?.focus();
    }
  };

  const toggleMobileMenu = () => {
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  };

  const updateNavbar = () => {
    const scrollY = window.scrollY;

    if (navbarPill) {
      navbarPill.classList.toggle('scrolled', scrollY > 80);
    }

    const newDirection = scrollY > lastScrollY ? 'down' : 'up';

    if (navbarWrapper) {
      if (scrollDirection === 'down' && newDirection === 'up') {
        navbarWrapper.classList.remove('hidden');
      } else if (scrollDirection === 'up' && newDirection === 'down' && scrollY > 150) {
        navbarWrapper.classList.add('hidden');
        closeMobileMenu();
      }
    }

    scrollDirection = newDirection;
    lastScrollY = scrollY;
    ticking = false;
  };

  const highlightActiveLink = () => {
    const scrollPos = window.scrollY + 160;

    sections.forEach((section) => {
      const sectionTop = (section as HTMLElement).offsetTop;
      const sectionHeight = (section as HTMLElement).offsetHeight;
      const sectionId = section.getAttribute('id');

      if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
        navLinks.forEach((link) => {
          link.classList.toggle('active', link.getAttribute('href') === `#${sectionId}`);
        });
      }
    });
  };

  mobileMenuBtn?.addEventListener('click', toggleMobileMenu);
  mobileOverlay?.addEventListener('click', closeMobileMenu);

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateNavbar);
      ticking = true;
    }
  }, { passive: true });

  window.addEventListener('scroll', () => {
    requestAnimationFrame(highlightActiveLink);
  }, { passive: true });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      syncMenuState(false);
    }
  });

  window.addEventListener('hashchange', closeMobileMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) {
      closeMobileMenu();
    }
  });

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      navbarPill?.classList.add('paused');
    } else {
      navbarPill?.classList.remove('paused');
    }
  });

  highlightActiveLink();
</script>
