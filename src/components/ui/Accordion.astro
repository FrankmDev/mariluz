---
interface Props {
  question: string;
  answer: string;
  index: number;
}

const { question, answer, index } = Astro.props;
---

<details class="faq-item" id={`faq-${index}`}>
  <summary class="faq-summary" aria-controls={`faq-body-${index}`}>
    <span class="t-headline" style="color: var(--label-primary); padding-right: 16px;">{question}</span>
    <svg
      class="faq-chevron"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </summary>
  <div class="faq-body" id={`faq-body-${index}`}>
    <p class="t-callout" style="color: var(--label-secondary); padding: 0 24px 20px; margin: 0;">{answer}</p>
  </div>
</details>

<style>
  .faq-item {
    display: block;
    border-bottom: 1px solid var(--separator);
  }
  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
    -webkit-user-select: none;
    user-select: none;
    transition: background 150ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary:hover {
    background: rgba(0, 0, 0, 0.02);
  }

  .faq-chevron {
    color: #AEAEB2;
    flex-shrink: 0;
    transition: transform 280ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--apple-blue);
  }

  .faq-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 280ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .faq-item[open] .faq-body {
    max-height: 300px;
  }
</style>

<script>
  document.querySelectorAll('.faq-item').forEach(item => {
    const summary = item.querySelector('.faq-summary');
    summary?.addEventListener('click', (e) => {
      e.preventDefault();
      if (item.hasAttribute('open')) {
        item.removeAttribute('open');
      } else {
        item.setAttribute('open', '');
      }
    });
  });
</script>
