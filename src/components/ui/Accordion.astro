---
interface Props {
  question: string;
  answer: string;
  index: number;
}

const { question, answer, index } = Astro.props;
---

<details class="accordion-item surface-panel" id={`faq-${index}`}>
  <summary class="accordion-summary" aria-controls={`faq-body-${index}`}>
    <span class="accordion-index">{String(index + 1).padStart(2, '0')}</span>
    <span class="accordion-question">{question}</span>
    <span class="accordion-icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </span>
  </summary>
  <div class="accordion-body" id={`faq-body-${index}`}>
    <p>{answer}</p>
  </div>
</details>

<style>
  .accordion-item {
    overflow: hidden;
  }

  .accordion-summary {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    list-style: none;
    cursor: pointer;
    user-select: none;
    -webkit-user-select: none;
  }

  .accordion-summary::-webkit-details-marker {
    display: none;
  }

  .accordion-index {
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-widest);
    color: var(--text-quaternary);
  }

  .accordion-question {
    font-size: var(--text-md);
    line-height: 1.45;
    color: var(--text-primary);
    font-weight: var(--font-semibold);
  }

  .accordion-icon {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.05);
    color: var(--text-tertiary);
    transition: transform var(--duration-normal) var(--ease-ios-spring),
      background var(--duration-normal) var(--ease-ios),
      color var(--duration-normal) var(--ease-ios);
  }

  .accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration-normal) var(--ease-ios-decel);
  }

  .accordion-body p {
    overflow: hidden;
    padding: 0 var(--space-6) var(--space-6) calc(var(--space-6) + 2rem + var(--space-4));
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .accordion-item[open] .accordion-body {
    grid-template-rows: 1fr;
  }

  .accordion-item[open] .accordion-icon {
    transform: rotate(180deg);
    background: color-mix(in srgb, var(--color-primary) 16%, white);
    color: var(--color-primary);
  }
</style>
