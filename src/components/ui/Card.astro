---
interface Props {
  class?: string;
  surface?: 'default' | 'muted' | 'blue' | 'green' | 'violet' | 'warm';
}

const { class: className = '', surface = 'default' } = Astro.props;

const surfaces = {
  default: 'surface-panel',
  muted: 'surface-panel surface-panel-muted',
  blue: 'surface-panel surface-tint-blue',
  green: 'surface-panel surface-tint-green',
  violet: 'surface-panel surface-tint-violet',
  warm: 'surface-panel surface-tint-warm',
};
---

<div class={`${surfaces[surface]} ${className}`}>
  <slot />
</div>
