---
import { siteConfig } from '../../config/site';

const benefits = [
  {
    title: 'Sin coste',
    subtitle: 'para ti',
    description: 'Mi servicio es completamente gratuito. Cobro una comisión de la comercializadora, nunca de ti.',
    icon: 'sparkles',
    tag: 'GRATIS',
    gradient: 'linear-gradient(145deg, var(--color-primary) 0%, var(--color-secondary) 50%, var(--color-secondary) 100%)',
    tint: 'rgba(236, 246, 255, 0.75)',
    accent: 'var(--color-primary)',
  },
  {
    title: 'Gestión completa',
    description: 'Me encargo de todo el papeleo y trámites con la comercializadora.',
    icon: 'document',
    checklist: ['Papeleo incluido', 'Sin trámites', 'Cambio inmediato'],
    accent: 'var(--color-secondary)',
    tint: 'rgba(243, 240, 255, 0.75)',
  },
  {
    title: 'Asesoría personal',
    description: 'Análisis individual de tu consumo para encontrar la tarifa exacta.',
    icon: 'person',
    profiles: ['MR', 'JL', 'AP'],
    profilesLabel: '450+ asesorados',
    accent: 'var(--color-accent)',
    tint: 'rgba(255, 248, 240, 0.75)',
  },
  {
    title: 'Cambio sin cortes',
    subtitle: 'Garantizado',
    description: 'Transición inmediata sin interrupción del suministro. La luz nunca se corta.',
    icon: 'bolt',
    tag: '0 RIESGO',
    gradient: 'linear-gradient(145deg, var(--color-success) 0%, var(--color-success) 50%, var(--color-success) 100%)',
    tint: 'rgba(238, 255, 245, 0.75)',
    accent: 'var(--color-success)',
  },
  {
    title: 'Ahorro inmediato',
    description: 'Verás la reducción en tu siguiente factura. Sin esperas.',
    icon: 'chart',
    trend: true,
    trendValue: '-23%',
    accent: 'var(--color-success)',
    tint: 'rgba(240, 255, 254, 0.75)',
  },
  {
    title: 'Siempre disponible',
    description: 'Atención por WhatsApp con respuesta en menos de 24 horas.',
    icon: 'message',
    responseBar: true,
    accent: 'var(--color-secondary)',
    tint: 'rgba(252, 245, 255, 0.75)',
  },
];

const stats = [
  { value: '450+', label: 'Hogares', color: 'var(--text-primary)', icon: 'home' },
  { value: '280€', label: 'Ahorro/año', color: 'var(--color-primary)', icon: 'euro' },
  { value: '74%', label: 'Menos factura', color: 'var(--color-success)', icon: 'trend' },
  { value: '24h', label: 'Respuesta', color: 'var(--color-secondary)', icon: 'clock' },
];

const icons = {
  sparkles: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3L14.5 8.5L20 11L14.5 13.5L12 19L9.5 13.5L4 11L9.5 8.5L12 3Z"/><path d="M5 3L5.5 4.5L7 5L5.5 5.5L5 7L4.5 5.5L3 5L4.5 4.5L5 3Z"/><path d="M19 17L19.5 18.5L21 19L19.5 19.5L19 21L18.5 19.5L17 19L18.5 18.5L19 17Z"/></svg>`,
  document: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  person: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  bolt: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  chart: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  message: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
};

const statIcons = {
  home: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  euro: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h12M4 14h9M19 6l-7 7 7 7"/></svg>`,
  trend: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  clock: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
};
---

<section class="benefits-section" aria-label="Ventajas">
  <div class="container-custom">
    
    <!-- Premium Header -->
    <header class="section-header reveal">
      <div class="eyebrow-glass">
        <span class="eyebrow-pulse"></span>
        <span class="eyebrow-text">Ventajas</span>
        <span class="eyebrow-divider"></span>
        <span class="eyebrow-sub">6 razones</span>
      </div>
      
      <h2 class="headline">
        <span class="headline-word">Beneficios</span>
        <span class="headline-accent">reales.</span>
      </h2>
      
      <p class="subhead">
        Sin complicaciones. Sin letra pequeña. Solo ahorro garantizado.
      </p>
    </header>

    <!-- Bento Grid -->
    <div class="bento-grid">
      
      <!-- Card 1: Sin coste - Large Feature -->
      <article class="bento-card card-feature card-blue reveal" data-delay="0">
        <!-- Multi-layer glass structure -->
        <div class="glass-layer glass-back"></div>
        <div class="glass-orb orb-1"></div>
        <div class="glass-orb orb-2"></div>
        <div class="glass-orb orb-3"></div>
        <div class="glass-layer glass-mid"></div>
        <div class="card-specular"></div>
        <div class="glass-shine"></div>
        
        <div class="card-tag tag-glass">
          <span class="tag-dot"></span>
          {benefits[0].tag}
        </div>
        
        <div class="card-content">
          <div class="feature-icon-wrap">
            <div class="icon-glow"></div>
            <Fragment set:html={icons[benefits[0].icon]} />
          </div>
          <h3 class="feature-title">
            {benefits[0].title}
            <span class="title-accent">{benefits[0].subtitle}</span>
          </h3>
          <p class="feature-desc">{benefits[0].description}</p>
        </div>
      </article>

      <!-- Card 2: Gestión completa -->
      <article class="bento-card card-standard reveal" data-delay="1" style="--accent: {benefits[1].accent}; --tint: {benefits[1].tint};">
        <div class="card-specular"></div>
        <div class="card-inner">
          <div class="card-top">
            <div class="std-icon-wrap">
              <Fragment set:html={icons[benefits[1].icon]} />
            </div>
            <h4 class="std-title">{benefits[1].title}</h4>
            <p class="std-desc">{benefits[1].description}</p>
          </div>
          <div class="card-bottom">
            <ul class="feature-list">
              {benefits[1].checklist.map(item => (
                <li class="list-item">
                  <span class="list-bullet">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 6L9 17l-5-5"/>
                    </svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </article>

      <!-- Card 3: Asesoría personal -->
      <article class="bento-card card-standard reveal" data-delay="2" style="--accent: {benefits[2].accent}; --tint: {benefits[2].tint};">
        <div class="card-specular"></div>
        <div class="card-inner">
          <div class="card-top">
            <div class="std-icon-wrap">
              <Fragment set:html={icons[benefits[2].icon]} />
            </div>
            <h4 class="std-title">{benefits[2].title}</h4>
            <p class="std-desc">{benefits[2].description}</p>
          </div>
          <div class="card-bottom">
            <div class="social-proof">
              <div class="avatar-cluster">
              {benefits[2].profiles.map((profile, i) => {
                const gradients = [
                  'linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 100%)',
                  'linear-gradient(135deg, var(--color-secondary) 0%, #AF52DE 100%)',
                  'linear-gradient(135deg, var(--color-accent) 0%, #FF6B35 100%)'
                ];
                return (
                  <div class="sp-avatar" style={`background: ${gradients[i]}; animation-delay: ${i * 0.1}s;`}>
                    <span class="avatar-letter">{profile}</span>
                  </div>
                );
              })}
                <div class="sp-more">+</div>
              </div>
              <span class="sp-label">{benefits[2].profilesLabel}</span>
            </div>
          </div>
        </div>
      </article>

      <!-- Card 4: Ahorro inmediato -->
      <article class="bento-card card-standard reveal" data-delay="3" style="--accent: {benefits[4].accent}; --tint: {benefits[4].tint};">
        <div class="card-specular"></div>
        <div class="card-inner">
          <div class="card-top">
            <div class="std-icon-wrap">
              <Fragment set:html={icons[benefits[4].icon]} />
            </div>
            <h4 class="std-title">{benefits[4].title}</h4>
            <p class="std-desc">{benefits[4].description}</p>
          </div>
          <div class="card-bottom">
            <div class="mini-chart">
              <div class="chart-bars">
                {[55, 48, 52, 40, 35, 30, 25].map((h, i) => (
                  <div class="c-bar" style={`--h: ${h}%; --delay: ${i * 0.05}s;`}></div>
                ))}
              </div>
              <div class="chart-label">
                <span class="trend-arrow">↓</span>
                <span class="trend-value">23%</span>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Card 5: Siempre disponible -->
      <article class="bento-card card-standard reveal" data-delay="4" style="--accent: {benefits[5].accent}; --tint: {benefits[5].tint};">
        <div class="card-specular"></div>
        <div class="card-inner">
          <div class="card-top">
            <div class="std-icon-wrap">
              <Fragment set:html={icons[benefits[5].icon]} />
            </div>
            <h4 class="std-title">{benefits[5].title}</h4>
            <p class="std-desc">{benefits[5].description}</p>
          </div>
          <div class="card-bottom">
            <div class="response-widget">
              <div class="rp-track">
                <div class="rp-fill"></div>
              </div>
              <span class="rp-text">&lt;24h</span>
            </div>
          </div>
        </div>
      </article>

      <!-- Card 6: Cambio sin cortes - Large Feature -->
      <article class="bento-card card-feature card-green reveal" data-delay="5">
        <!-- Multi-layer glass structure -->
        <div class="glass-layer glass-back"></div>
        <div class="glass-orb orb-1"></div>
        <div class="glass-orb orb-2"></div>
        <div class="glass-orb orb-3"></div>
        <div class="glass-layer glass-mid"></div>
        <div class="card-specular"></div>
        <div class="glass-shine"></div>
        
        <div class="card-tag tag-glass">
          <span class="tag-dot green"></span>
          {benefits[3].tag}
        </div>
        
        <div class="card-content">
          <div class="feature-icon-wrap">
            <div class="icon-glow green"></div>
            <Fragment set:html={icons[benefits[3].icon]} />
          </div>
          <h3 class="feature-title">
            {benefits[3].title}
            <span class="title-accent">{benefits[3].subtitle}</span>
          </h3>
          <p class="feature-desc">{benefits[3].description}</p>
        </div>
      </article>

    </div>

    <!-- Stats Island -->
    <div class="stats-wrapper reveal" data-delay="6">
      <div class="stats-island">
        <div class="island-specular"></div>
        <div class="island-content">
          {stats.map((stat, i) => (
            <div class="stat-cell" style={`--stat-color: ${stat.color};`}>
              <div class="stat-icon-wrap">
                <Fragment set:html={statIcons[stat.icon]} />
              </div>
              <span class="stat-number">{stat.value}</span>
              <span class="stat-name">{stat.label}</span>
              {i < stats.length - 1 && <div class="cell-divider"></div>}
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════════════
     BENEFITS SECTION - Clean iOS 26 Edition
     ═══════════════════════════════════════════════════════════════ */

  .benefits-section {
    position: relative;
    padding: var(--section-py) 0 var(--space-32);
    overflow: hidden;
    isolation: isolate;
    /* No background - using global background from Layout */
  }

  /* ─── Section Header ──────────────────────────────────────────── */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
    position: relative;
    z-index: 1;
  }

  .eyebrow-glass {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-6);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 
      inset 0 1px 1px rgba(255,255,255,1),
      0 2px 12px rgba(0,0,0,0.04);
  }

  .eyebrow-pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 100%);
    box-shadow: 0 0 0 0 rgba(0,122,255,0.4);
    animation: pulse-ring 2s ease-out infinite;
  }

  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(0,122,255,0.4); }
    70% { box-shadow: 0 0 0 8px rgba(0,122,255,0); }
    100% { box-shadow: 0 0 0 0 rgba(0,122,255,0); }
  }

  .eyebrow-text {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .eyebrow-divider {
    width: 1px; height: 14px;
    background: rgba(0,0,0,0.1);
  }

  .eyebrow-sub {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
  }

  .headline {
    margin: 0 0 var(--space-4);
  }

  .headline-word {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.08;
    color: var(--text-primary);
  }

  .headline-accent {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.08;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 50%, var(--cyan-500) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subhead {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 400px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ─── Bento Grid ──────────────────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: minmax(280px, auto) minmax(240px, auto);
    gap: var(--space-5);
    margin-bottom: var(--space-8);
    position: relative;
    z-index: 1;
  }

  /* ─── Base Card ───────────────────────────────────────────────── */
  .bento-card {
    border-radius: 22px;
    position: relative;
    overflow: hidden;
    transition: transform 0.5s var(--ease-ios-spring), box-shadow 0.5s var(--ease-ios);
    will-change: transform;
  }

  .bento-card:hover {
    transform: translateY(-8px) scale(1.01);
  }

  /* ─── Feature Cards (Large) - Colored Glass ───────────────────── */
  .card-feature {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-8);
    min-height: 280px;
    border-radius: 24px;
    position: relative;
    overflow: hidden;
    color: var(--text-primary);
    transition: all 0.4s var(--ease-ios-spring);
  }

  /* Card Blue - Soft blue tinted glass */
  .card-blue {
    background: linear-gradient(135deg, 
      rgba(239, 246, 255, 0.95) 0%, 
      rgba(219, 234, 254, 0.9) 50%,
      rgba(191, 219, 254, 0.85) 100%);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(59, 130, 246, 0.1),
      0 4px 12px rgba(59, 130, 246, 0.08),
      0 20px 50px rgba(59, 130, 246, 0.12);
  }

  .card-blue:hover {
    background: linear-gradient(135deg, 
      rgba(239, 246, 255, 1) 0%, 
      rgba(219, 234, 254, 0.95) 50%,
      rgba(191, 219, 254, 0.9) 100%);
    transform: translateY(-6px);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(59, 130, 246, 0.1),
      0 8px 24px rgba(59, 130, 246, 0.12),
      0 28px 60px rgba(59, 130, 246, 0.16);
  }

  /* Card Green - Soft green tinted glass */
  .card-green {
    background: linear-gradient(135deg, 
      rgba(240, 253, 244, 0.95) 0%, 
      rgba(220, 252, 231, 0.9) 50%,
      rgba(187, 247, 208, 0.85) 100%);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(34, 197, 94, 0.1),
      0 4px 12px rgba(34, 197, 94, 0.08),
      0 20px 50px rgba(34, 197, 94, 0.12);
  }

  .card-green:hover {
    background: linear-gradient(135deg, 
      rgba(240, 253, 244, 1) 0%, 
      rgba(220, 252, 231, 0.95) 50%,
      rgba(187, 247, 208, 0.9) 100%);
    transform: translateY(-6px);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(34, 197, 94, 0.1),
      0 8px 24px rgba(34, 197, 94, 0.12),
      0 28px 60px rgba(34, 197, 94, 0.16);
  }

  /* Back glass layer - dark base */
  .glass-layer.glass-back {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    z-index: -3;
    opacity: 0;
  }

  /* Minimal orbs - subtle atmosphere */
  .glass-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    z-index: -2;
    opacity: 0.4;
  }

  /* Blue card orbs - very subtle */
  .card-blue .orb-1 {
    width: 180px;
    height: 180px;
    background: rgba(96, 165, 250, 0.5);
    top: -40px;
    right: -20px;
  }

  .card-blue .orb-2 {
    width: 120px;
    height: 120px;
    background: rgba(147, 197, 253, 0.4);
    bottom: -20px;
    left: -20px;
  }

  .card-blue .orb-3 {
    width: 100px;
    height: 100px;
    background: rgba(191, 219, 254, 0.35);
    top: 40%;
    left: 30%;
  }

  /* Green card orbs - very subtle */
  .card-green .orb-1 {
    width: 160px;
    height: 160px;
    background: rgba(74, 222, 128, 0.45);
    top: -30px;
    left: -20px;
  }

  .card-green .orb-2 {
    width: 140px;
    height: 140px;
    background: rgba(134, 239, 172, 0.4);
    bottom: -30px;
    right: -20px;
  }

  .card-green .orb-3 {
    width: 120px;
    height: 120px;
    background: rgba(187, 247, 208, 0.35);
    top: 50%;
    right: 25%;
  }

  /* Middle glass layer */
  .glass-layer.glass-mid {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    background: rgba(255, 255, 255, 0.1);
    z-index: -1;
  }

  /* Specular highlight - top reflection */
  .card-feature .card-specular {
    position: absolute;
    top: 0; 
    left: 0; 
    right: 0;
    height: 40%;
    background: linear-gradient(180deg, 
      rgba(255, 255, 255, 0.95) 0%, 
      rgba(255, 255, 255, 0.5) 40%, 
      transparent 100%);
    pointer-events: none;
    border-radius: 24px 24px 0 0;
    z-index: 1;
  }

  /* Shine line */
  .glass-shine {
    position: absolute;
    top: 0;
    left: 15%;
    right: 15%;
    height: 1px;
    background: linear-gradient(90deg, 
      transparent 0%, 
      rgba(255, 255, 255, 0.95) 50%, 
      transparent 100%);
    z-index: 2;
    pointer-events: none;
  }

