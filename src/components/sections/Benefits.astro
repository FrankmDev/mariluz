---
import { siteConfig } from '../../config/site';
import { ClipboardCheck, HandCoins, MessageCircle, PlugZap, RefreshCw } from 'lucide-astro';

const benefits = [
  {
    title: 'Potencia contratada',
    text: 'Compruebo si la potencia tiene sentido para tu uso real o si puede estar sobredimensionada.',
    icon: HandCoins,
    className: 'benefit-large benefit-blue',
  },
  {
    title: 'Precio de energía',
    text: 'Reviso el precio por kWh, horarios, tipo de tarifa y cómo encaja con tu consumo habitual.',
    icon: PlugZap,
    className: 'benefit-green',
  },
  {
    title: 'Servicios añadidos',
    text: 'Busco conceptos extra, mantenimientos o condiciones que puedan estar encareciendo la factura.',
    icon: MessageCircle,
    className: 'benefit-purple',
  },
  {
    title: 'Permanencia',
    text: 'Antes de proponer nada, reviso si hay compromisos, penalizaciones o condiciones que conviene tener claras.',
    icon: RefreshCw,
    className: 'benefit-cyan',
  },
  {
    title: 'Alternativas reales',
    text: 'Comparo opciones y descarto cambios cuando no aportan ahorro claro, estable o suficiente.',
    icon: ClipboardCheck,
    className: 'benefit-large benefit-warm',
  },
];
---

<section id="beneficios" class="benefits-section" aria-label="Qué se revisa en tu factura de luz">
  <div class="benefits-container">
    <header class="benefits-header reveal">
      <p class="benefits-kicker">Qué reviso</p>
      <h2>Antes de cambiar, hay que estudiar la factura.</h2>
      <p>
        Una revisión profesional mira precio, potencia, servicios, permanencia y condiciones. No se promete ahorro: se comprueba si existe.
      </p>
    </header>

    <div class="benefits-grid">
      {benefits.map((benefit, index) => {
        const Icon = benefit.icon;
        return (
          <article class={`benefit-card ${benefit.className} reveal`} data-delay={index}>
            <div class="benefit-specular"></div>
            <div class="benefit-content">
              <div class="benefit-icon">
                <Icon size={24} aria-hidden="true" />
              </div>
              <h3>{benefit.title}</h3>
              <p>{benefit.text}</p>
            </div>
          </article>
        );
      })}
    </div>

    <aside class="benefits-footnote reveal" data-delay="5">
      <span>Criterio de revisión</span>
      <p>{siteConfig.savings.disclaimer}</p>
    </aside>
  </div>
</section>

<style>
  .benefits-section {
    position: relative;
    padding: clamp(96px, 12vw, 148px) var(--space-6);
    overflow: hidden;
  }

  .benefits-container {
    width: min(1200px, 100%);
    margin: 0 auto;
  }

  .benefits-header {
    max-width: 880px;
    margin: 0 0 var(--space-12);
  }

  .benefits-kicker {
    display: inline-flex;
    margin: 0 0 var(--space-5);
    padding: 9px 15px;
    border-radius: var(--radius-pill);
    background: rgba(255,255,255,0.68);
    border: 1px solid rgba(255,255,255,0.68);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 8px rgba(0,0,0,0.04);
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .benefits-header h2 {
    margin: 0;
    color: var(--text-primary);
    font-size: clamp(2.05rem, 3.8vw, 3.75rem);
    line-height: 1.06;
    letter-spacing: -0.042em;
    font-weight: 800;
    max-width: 12.5ch;
  }

  .benefits-header p:last-child {
    max-width: 560px;
    margin: var(--space-5) 0 0;
    color: var(--text-secondary);
    font-size: clamp(1rem, 1.25vw, 1.14rem);
    line-height: 1.6;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-auto-flow: dense;
    gap: var(--space-4);
  }

  .benefit-card {
    position: relative;
    grid-column: span 3;
    min-height: 238px;
    padding: clamp(20px, 2.5vw, 28px);
    overflow: hidden;
    border-radius: 26px;
    background: rgba(255,255,255,0.70);
    border: 1px solid rgba(255,255,255,0.58);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    box-shadow: var(--shadow-glass);
    transition: transform 0.55s var(--ease-ios-spring), box-shadow 0.45s var(--ease-ios);
  }

  .benefit-card:hover {
    transform: translateY(-7px) scale(1.01);
    box-shadow: var(--shadow-glass-hover);
  }

  .benefit-large {
    grid-column: span 6;
  }

  .benefit-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 55%;
    background: linear-gradient(180deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.38) 40%, transparent 100%);
    pointer-events: none;
  }

  .benefit-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .benefit-icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    margin-bottom: auto;
    border-radius: 18px;
    color: var(--accent);
    background: rgba(255,255,255,0.58);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.84);
  }

  .benefit-card h3 {
    margin: var(--space-8) 0 0;
    color: var(--text-primary);
    font-size: clamp(1.22rem, 1.65vw, 1.58rem);
    line-height: 1.12;
    letter-spacing: -0.035em;
    font-weight: 800;
    max-width: 13ch;
  }

  .benefit-large h3 {
    font-size: clamp(1.72rem, 2.8vw, 2.8rem);
    max-width: 13ch;
  }

  .benefit-card p {
    margin: var(--space-4) 0 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.58;
    max-width: 52ch;
  }

  .benefit-blue { --accent: var(--ios-blue); background-color: rgba(236,246,255,0.74); }
  .benefit-green { --accent: var(--ios-green); background-color: rgba(238,255,245,0.74); }
  .benefit-purple { --accent: var(--ios-indigo); background-color: rgba(243,240,255,0.74); }
  .benefit-cyan { --accent: var(--ios-teal); background-color: rgba(240,255,254,0.74); }
  .benefit-warm { --accent: var(--ios-orange); background-color: rgba(255,248,240,0.74); }

  .benefits-footnote {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-5);
    align-items: start;
    margin-top: var(--space-6);
    padding: 20px 22px;
    border-radius: 22px;
    background: rgba(255,255,255,0.62);
    border: 1px solid rgba(255,255,255,0.68);
    backdrop-filter: blur(26px) saturate(180%);
    -webkit-backdrop-filter: blur(26px) saturate(180%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9);
  }

  .benefits-footnote span {
    color: var(--text-primary);
    font-weight: 800;
    white-space: nowrap;
  }

  .benefits-footnote p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  @media (max-width: 980px) {
    .benefit-card,
    .benefit-large {
      grid-column: span 6;
    }
  }

  @media (max-width: 680px) {
    .benefits-section {
      padding: var(--space-24) var(--space-5);
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .benefit-card,
    .benefit-large {
      grid-column: auto;
      min-height: auto;
    }

    .benefits-footnote {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
