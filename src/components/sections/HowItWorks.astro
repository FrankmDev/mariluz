---
import { siteConfig } from '../../config/site';

const steps = [
  {
    number: '01',
    title: 'Comparte tu factura',
    description: 'Me envías tu última factura de luz por WhatsApp. En 24h tendrás mi análisis.',
    highlight: 'Análisis en 24h',
    tint: 'blue',
  },
  {
    number: '02',
    title: 'Recibe tu propuesta',
    description: 'Estudio tu consumo real y busco la tarifa perfecta entre más de 200 opciones.',
    highlight: '+200 tarifas',
    tint: 'indigo',
  },
  {
    number: '03',
    title: 'Ahorra desde el primer día',
    description: 'Gestiono todo el cambio por ti. Sin papeleos, sin cortes, sin coste.',
    highlight: '0€ de coste',
    tint: 'cyan',
  },
];
---

<section id="como-funciona" class="how-section" aria-label="Cómo funciona">
  
  <!-- Ambient Background -->
  <div class="ambient-bg" aria-hidden="true">
    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>
  </div>

  <div class="container-custom">

    <!-- Section Header -->
    <header class="section-header reveal">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>El proceso</span>
      </div>
      <h2 class="headline">
        <span class="headline-main">Así funciona.</span>
        <span class="headline-sub">Sin complicaciones.</span>
      </h2>
    </header>

    <!-- Process Flow -->
    <div class="process-flow">
      
      <!-- Connection Line (Desktop) -->
      <div class="connection-line" aria-hidden="true">
        <div class="line-track"></div>
        <div class="line-progress" id="line-progress"></div>
      </div>

      <!-- Steps -->
      <div class="steps-grid">
        {steps.map((step, index) => (
          <article 
            class={`step-card reveal card-${step.tint}`} 
            data-step={index} 
            style={`transition-delay: ${index * 150}ms`}
          >
            
            <!-- Glass Base Layer -->
            <div class="glass-base"></div>
            
            <!-- Specular Highlight -->
            <div class="specular-highlight"></div>
            
            <!-- Glow Effect -->
            <div class="card-glow"></div>
            
            <!-- Content -->
            <div class="card-content">
              
              <!-- Step Number Badge -->
              <div class="step-badge">
                <span class="badge-number">{step.number}</span>
                <div class="badge-ring"></div>
                <div class="badge-glow"></div>
              </div>

              <!-- Text Content -->
              <div class="text-content">
                <h3 class="step-title">{step.title}</h3>
                <p class="step-description">{step.description}</p>
              </div>

              <!-- Highlight Pill -->
              <div class="highlight-pill">
                <div class="pill-icon">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <span>{step.highlight}</span>
              </div>

            </div>

            <!-- Floating Decoration -->
            <div class="card-decoration" aria-hidden="true">
              {index === 0 && (
                <div class="deco-bill">
                  <div class="bill-paper">
                    <div class="bill-lines">
                      <div class="bill-row"></div>
                      <div class="bill-row"></div>
                      <div class="bill-row short"></div>
                    </div>
                    <div class="bill-amount">
                      <span class="amount-currency">€</span>
                      <span class="amount-value">124</span>
                    </div>
                    <div class="bill-shine"></div>
                  </div>
                  <div class="bill-shadow"></div>
                </div>
              )}
              {index === 1 && (
                <div class="deco-chart">
                  <div class="chart-container">
                    <svg viewBox="0 0 40 40" class="donut-svg">
                      <defs>
                        <linearGradient id={`gradient-${index}`} x1="0%" y1="0%" x2="100%" y2="100%">
                          <stop offset="0%" stop-color="var(--ios-indigo)"/>
                          <stop offset="100%" stop-color="#7B8CFF"/>
                        </linearGradient>
                        <filter id={`glow-${index}`}>
                          <feGaussianBlur stdDeviation="1.5" result="coloredBlur"/>
                          <feMerge>
                            <feMergeNode in="coloredBlur"/>
                            <feMergeNode in="SourceGraphic"/>
                          </feMerge>
                        </filter>
                      </defs>
                      <circle class="donut-ring" cx="20" cy="20" r="15.9155" fill="none" stroke="rgba(99,102,241,0.12)" stroke-width="3.5"/>
                      <circle class="donut-segment" cx="20" cy="20" r="15.9155" fill="none" stroke={`url(#gradient-${index})`} stroke-width="3.5" stroke-linecap="round" stroke-dasharray="0 100" transform="rotate(-90 20 20)"/>
                    </svg>
                    <div class="donut-center">
                      <span class="donut-value">75</span>
                      <span class="donut-unit">%</span>
                    </div>
                  </div>
                  <div class="chart-particles">
                    <span class="particle p1"></span>
                    <span class="particle p2"></span>
                    <span class="particle p3"></span>
                  </div>
                </div>
              )}
              {index === 2 && (
                <div class="deco-success">
                  <div class="success-badge">
                    <div class="success-ring">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                      </svg>
                    </div>
                    <div class="success-glow"></div>
                  </div>
                  <div class="success-particles">
                    <span class="sparticle s1"></span>
                    <span class="sparticle s2"></span>
                    <span class="sparticle s3"></span>
                    <span class="sparticle s4"></span>
                  </div>
                </div>
              )}
            </div>

          </article>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  /* Section Base */
  .how-section {
    position: relative;
    padding: var(--space-32) 0 var(--space-40);
    overflow: hidden;
  }

  /* Ambient Background */
  .ambient-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .ambient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    opacity: 0.42;
  }

  .orb-1 {
    width: 70vw;
    height: 70vw;
    max-width: 900px;
    max-height: 900px;
    top: -25%;
    right: -15%;
    background: radial-gradient(circle, rgba(0,122,255,0.45) 0%, transparent 70%);
    animation: orb-float 25s ease-in-out infinite;
  }

  .orb-2 {
    width: 50vw;
    height: 50vw;
    max-width: 600px;
    max-height: 600px;
    bottom: -5%;
    left: -5%;
    background: radial-gradient(circle, rgba(90,200,250,0.38) 0%, transparent 70%);
    animation: orb-float 20s ease-in-out infinite reverse;
  }

  @keyframes orb-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.02); }
    66% { transform: translate(-20px, 15px) scale(0.98); }
  }

  /* Header */
  .section-header {
    position: relative;
    z-index: 10;
    text-align: center;
    margin-bottom: var(--space-20);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-6);
    background: rgba(255,255,255,0.68);
    backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.65);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.92), 0 2px 8px rgba(0,0,0,0.04);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
  }

  .eyebrow-dot {
    width: var(--space-2);
    height: var(--space-2);
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ios-blue) 0%, #5AC8FA 100%);
    box-shadow: 0 0 0 0 rgba(0,122,255,0.4);
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,122,255,0.4); }
    50% { box-shadow: 0 0 0 var(--space-2) rgba(0,122,255,0); }
  }

  .headline { margin: 0; }

  .headline-main {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: var(--font-extrabold);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .headline-sub {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section-sub);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-normal);
    line-height: var(--leading-snug);
    color: var(--text-tertiary);
  }

  /* Process Flow */
  .process-flow {
    position: relative;
    z-index: 10;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Connection Line */
  .connection-line {
    position: absolute;
    top: 100px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 120px);
    max-width: 650px;
    height: 2px;
    display: none;
  }

  .line-track {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.06) 10%, rgba(0,0,0,0.06) 90%, transparent 100%);
    border-radius: 1px;
  }

  .line-progress {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--ios-blue), #5AC8FA);
    border-radius: 1px;
    box-shadow: 0 0 20px rgba(0,122,255,0.4), 0 0 40px rgba(0,122,255,0.2);
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .line-progress::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translate(50%, -50%);
    width: 10px;
    height: 10px;
    background: white;
    border-radius: 50%;
    box-shadow: 0 0 0 3px var(--ios-blue), 0 0 16px rgba(0,122,255,0.5);
    opacity: 0;
    transition: opacity 0.3s ease 0.8s;
  }

  .line-progress.visible::after {
    opacity: 1;
  }

  @media (min-width: 900px) { .connection-line { display: block; } }

  /* Steps Grid */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    position: relative;
  }

  @media (max-width: 900px) {
    .steps-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
      gap: var(--space-5);
    }
  }

  /* Step Card - Definitive Liquid Glass Formula */
  .step-card {
    position: relative;
    border-radius: 22px;
    padding: var(--space-8);
    min-height: 360px;
    display: flex;
    flex-direction: column;
    transition: transform 0.5s var(--ease-ios-spring), box-shadow 0.4s ease;
    cursor: pointer;
  }

  /* Glass Base Layer */
  .glass-base {
    position: absolute;
    inset: 0;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    transition: all 0.5s var(--ease-ios-spring);
  }

  /* Specular Highlight */
  .specular-highlight {
    position: absolute;
    top: 1px;
    left: 1px;
    right: 1px;
    height: 55%;
    border-radius: 21px 21px 0 0;
    background: linear-gradient(180deg,
      rgba(255,255,255,0.92) 0%,
      rgba(255,255,255,0.50) 35%,
      rgba(255,255,255,0.10) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
    opacity: 0.9;
  }

  /* Card Glow - tint per card */
  .card-glow {
    position: absolute;
    inset: -1px;
    border-radius: 23px;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: -1;
  }

  .card-blue .card-glow {
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0,122,255,0.25) 0%, transparent 70%);
  }

  .card-indigo .card-glow {
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(99,102,241,0.25) 0%, transparent 70%);
  }

  .card-cyan .card-glow {
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(6,182,212,0.25) 0%, transparent 70%);
  }

  /* Hover Effects */
  .step-card:hover {
    transform: translateY(-8px) scale(1.01);
  }

  .step-card:hover .glass-base {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 8px 12px rgba(0, 0, 0, 0.05),
      0 20px 60px rgba(0, 0, 0, 0.12),
      0 48px 100px rgba(0, 0, 0, 0.10);
  }

  .step-card:hover .card-glow {
    opacity: 1;
  }

  .step-card:hover .step-badge {
    transform: scale(1.08);
  }

  .step-card:hover .badge-glow {
    opacity: 0.6;
  }

  .step-card:hover .highlight-pill {
    transform: scale(1.03);
  }

  .step-card:hover .card-decoration {
    transform: translateY(-4px);
  }

  /* Card Content */
  .card-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Step Badge */
  .step-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    margin-bottom: var(--space-6);
    transition: transform 0.4s var(--ease-ios-spring);
  }

  .badge-number {
    position: relative;
    z-index: 3;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-extrabold);
    background: linear-gradient(135deg, var(--ios-blue) 0%, #5AC8FA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .badge-ring {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: 50%;
    background: rgba(255,255,255,0.8);
    border: 1.5px solid rgba(0,122,255,0.2);
    box-shadow: 
      inset 0 1px 0 rgba(255,255,255,0.9),
      0 2px 8px rgba(0,122,255,0.12);
  }

  .badge-glow {
    position: absolute;
    inset: -4px;
    z-index: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,122,255,0.3) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
    filter: blur(6px);
  }

  /* Text Content */
  .text-content { flex: 1; }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin: 0 0 var(--space-3);
    line-height: var(--leading-snug);
  }

  .step-description {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin: 0;
  }

  /* Highlight Pill */
  .highlight-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    background: rgba(0,122,255,0.08);
    border: 1px solid rgba(0,122,255,0.12);
    color: var(--ios-blue);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    width: fit-content;
    transition: all 0.3s var(--ease-ios-spring);
  }

  .pill-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(0,122,255,0.15);
  }

  .pill-icon svg {
    stroke: var(--ios-blue);
  }

  .step-card:hover .highlight-pill {
    background: rgba(0,122,255,0.12);
    border-color: rgba(0,122,255,0.18);
  }

  /* Card Decoration */
  .card-decoration {
    position: absolute;
    bottom: var(--space-8);
    right: var(--space-8);
    transition: transform 0.4s var(--ease-ios-spring);
    z-index: 5;
  }

  /* Decorative Elements - Bill */
  .deco-bill { 
    width: 86px; 
    height: 108px; 
    position: relative;
  }

  .bill-paper {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, rgba(255,255,255,0.95) 0%, rgba(248,250,252,0.9) 100%);
    border: 1px solid rgba(0,122,255,0.15);
    border-radius: 10px;
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: 6px;
    box-shadow: 
      0 4px 12px rgba(0,122,255,0.1),
      0 1px 3px rgba(0,0,0,0.05);
    position: relative;
    overflow: hidden;
    transform: rotate(-3deg);
    transition: transform 0.4s var(--ease-ios-spring);
  }

  .step-card:hover .bill-paper {
    transform: rotate(0deg) translateY(-4px);
  }

  .bill-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
    animation: bill-shine 3s ease-in-out infinite;
  }

  @keyframes bill-shine {
    0%, 100% { left: -100%; }
    50% { left: 150%; }
  }

  .bill-lines {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .bill-row { 
    height: 3px; 
    background: linear-gradient(90deg, rgba(0,122,255,0.25) 0%, rgba(0,122,255,0.12) 100%); 
    border-radius: 2px; 
  }
  .bill-row.short { width: 55%; }

  .bill-amount {
    margin-top: auto;
    display: flex;
    align-items: flex-start;
    gap: 1px;
  }

  .amount-currency {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--ios-blue);
    opacity: 0.7;
  }

  .amount-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    background: linear-gradient(135deg, var(--ios-blue) 0%, #5AC8FA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
  }

  .bill-shadow {
    position: absolute;
    bottom: -6px;
    left: 5%;
    width: 90%;
    height: 12px;
    background: rgba(0,122,255,0.15);
    filter: blur(8px);
    border-radius: 50%;
    z-index: -1;
  }

  /* Decorative Elements - Chart */
  .deco-chart { 
    width: 90px; 
    height: 90px; 
    position: relative;
  }

  .chart-container { 
    position: relative; 
    width: 100%; 
    height: 100%;
    filter: drop-shadow(0 4px 12px rgba(99,102,241,0.15));
  }

  .donut-svg { 
    width: 100%; 
    height: 100%;
    transform: rotate(-90deg);
  }

  .donut-segment {
    animation: donut-fill 1.5s ease-out 0.5s forwards;
    stroke-dasharray: 0 100;
  }

  @keyframes donut-fill { 
    to { stroke-dasharray: 75 100; } 
  }

  .donut-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: baseline;
    gap: 1px;
  }

  .donut-value {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-extrabold);
    background: linear-gradient(135deg, var(--ios-indigo) 0%, #7B8CFF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .donut-unit {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    color: var(--ios-indigo);
    opacity: 0.7;
  }

  .chart-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ios-indigo);
    opacity: 0;
  }

  .p1 { top: 10%; right: 20%; animation: particle-float 3s ease-in-out infinite; animation-delay: 0s; }
  .p2 { top: 30%; right: 5%; animation: particle-float 3s ease-in-out infinite; animation-delay: 0.5s; }
  .p3 { bottom: 20%; right: 10%; animation: particle-float 3s ease-in-out infinite; animation-delay: 1s; }

  @keyframes particle-float {
    0%, 100% { opacity: 0; transform: translateY(0) scale(0.5); }
    50% { opacity: 0.6; transform: translateY(-8px) scale(1); }
  }

  /* Decorative Elements - Success */
  .deco-success { 
    width: 70px; 
    height: 70px; 
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-badge {
    position: relative;
    width: 56px;
    height: 56px;
    z-index: 2;
  }

  .success-ring {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: linear-gradient(145deg, rgba(6,182,212,0.15) 0%, rgba(6,182,212,0.08) 100%);
    border: 2px solid rgba(6,182,212,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ios-cyan);
    box-shadow: 
      inset 0 1px 0 rgba(255,255,255,0.6), 
      0 4px 16px rgba(6,182,212,0.15);
