---
import { siteConfig } from '../../config/site';
import SectionHeader from '../ui/SectionHeader.astro';

const steps = [
  {
    number: '01',
    title: 'Envíame tu última factura',
    description: 'Con tu factura puedo revisar consumo, potencia, precio actual, posibles permanencias y condiciones contratadas.',
    highlight: 'Estudio gratuito',
    tint: 'blue',
  },
  {
    number: '02',
    title: 'Reviso y comparo opciones reales',
    description: 'Analizo si tus condiciones actuales siguen siendo competitivas y descarto cualquier cambio que no aporte una mejora clara.',
    highlight: 'Condiciones reales',
    tint: 'indigo',
  },
  {
    number: '03',
    title: 'Te explico el resultado',
    description: 'Recibes una explicación clara para entender si conviene mantener tu contrato o valorar otra opción. Si hay una mejora y la aceptas, se gestiona el cambio.',
    highlight: 'Decisión tranquila',
    tint: 'teal',
  },
];

const tintMap: Record<string, { bg: string; glow: string; line: string }> = {
  blue:   { bg: 'rgba(236,246,255,0.72)', glow: 'rgba(0,122,255,0.20)', line: 'var(--ios-blue)' },
  indigo: { bg: 'rgba(243,240,255,0.72)', glow: 'rgba(88,86,214,0.20)', line: 'var(--ios-indigo)' },
  teal:   { bg: 'rgba(232,252,255,0.72)', glow: 'rgba(6,182,212,0.20)', line: 'var(--ios-teal)' },
};
---

<section id="como-funciona" class="how-section" aria-label="Cómo funciona">
  <div class="container-custom">

    <SectionHeader
      eyebrow="El proceso"
      title="Una revisión clara."
      accent="Antes de decidir."
      subtitle="Primero reviso tu factura. Después te explico si hay una mejora clara y qué opción conviene, sin cambiar nada sin tu permiso."
    />

    <!-- Process Timeline -->
    <div class="process-timeline">

      <!-- Connection Line (desktop) -->
      <div class="connection-line" aria-hidden="true">
        <div class="line-track"></div>
        <div class="line-progress" id="line-progress"></div>
        <div class="line-dot" id="line-dot"></div>
      </div>

      <!-- Steps -->
      <div class="steps-grid">
        {steps.map((step, index) => {
          const tint = tintMap[step.tint] || tintMap.blue;
          return (
            <article
              class={`step-island reveal card-${step.tint}`}
              data-step={index}
              style={`transition-delay: ${index * 120}ms`}
            >
              <!-- Glass Base -->
              <div class="island-glass"></div>

              <!-- Specular Highlight -->
              <div class="island-specular"></div>

              <!-- Ambient Glow -->
              <div class="island-ambient"></div>

              <!-- Giant Number Watermark -->
              <span class="step-watermark" aria-hidden="true">{step.number}</span>

              <!-- Content -->
              <div class="island-content">
                <div class="step-meta">
                  <span class="meta-index">Paso {index + 1}</span>
                  <span class="meta-tag">{step.highlight}</span>
                </div>

                <h3 class="step-title">{step.title}</h3>
                <p class="step-description">{step.description}</p>
              </div>

              <!-- Abstract Visual -->
              <div class="step-visual" aria-hidden="true">
                {index === 0 && (
                  <svg width="80" height="64" viewBox="0 0 80 64" fill="none">
                    <rect x="8" y="12" width="64" height="40" rx="6" fill="white" fill-opacity="0.6" stroke={tint.line} stroke-width="1.5" stroke-opacity="0.25"/>
                    <line x1="20" y1="28" x2="44" y2="28" stroke={tint.line} stroke-width="2" stroke-linecap="round" stroke-opacity="0.35"/>
                    <line x1="20" y1="36" x2="36" y2="36" stroke={tint.line} stroke-width="2" stroke-linecap="round" stroke-opacity="0.2"/>
                    <circle cx="58" cy="36" r="10" fill={tint.line} fill-opacity="0.1"/>
                    <path d="M54 36 L57 39 L63 33" stroke={tint.line} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="0.6"/>
                  </svg>
                )}
                {index === 1 && (
                  <svg width="80" height="64" viewBox="0 0 80 64" fill="none">
                    <circle cx="28" cy="32" r="16" stroke={tint.line} stroke-width="1.5" stroke-opacity="0.2" fill="none"/>
                    <circle cx="28" cy="32" r="16" stroke={tint.line} stroke-width="3" stroke-linecap="round" stroke-dasharray="50 100" transform="rotate(-90 28 32)" stroke-opacity="0.5"/>
                    <text x="28" y="36" text-anchor="middle" fill={tint.line} fill-opacity="0.7" font-size="14" font-weight="700" font-family="var(--font-display)">75</text>
                    <line x1="52" y1="20" x2="72" y2="20" stroke={tint.line} stroke-width="2" stroke-linecap="round" stroke-opacity="0.3"/>
                    <line x1="52" y1="32" x2="68" y2="32" stroke={tint.line} stroke-width="2" stroke-linecap="round" stroke-opacity="0.5"/>
                    <line x1="52" y1="44" x2="72" y2="44" stroke={tint.line} stroke-width="2" stroke-linecap="round" stroke-opacity="0.3"/>
                  </svg>
                )}
                {index === 2 && (
                  <svg width="80" height="64" viewBox="0 0 80 64" fill="none">
                    <circle cx="40" cy="32" r="18" fill={tint.line} fill-opacity="0.08"/>
                    <circle cx="40" cy="32" r="14" stroke={tint.line} stroke-width="1.5" stroke-opacity="0.25" fill="none"/>
                    <path d="M35 32 L38 35 L46 27" stroke={tint.line} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="0.7"/>
                    <circle cx="20" cy="20" r="2" fill={tint.line} fill-opacity="0.2"/>
                    <circle cx="60" cy="20" r="2" fill={tint.line} fill-opacity="0.2"/>
                    <circle cx="20" cy="44" r="2" fill={tint.line} fill-opacity="0.2"/>
                    <circle cx="60" cy="44" r="2" fill={tint.line} fill-opacity="0.2"/>
                  </svg>
                )}
              </div>

            </article>
          );
        })}
      </div>

    </div>
  </div>
</section>

<style>
  /* ============================================
     SECTION BASE
     ============================================ */
  .how-section {
    position: relative;
    padding: var(--section-py) 0;
    overflow: hidden;
  }

  /* ============================================
     TIMELINE CONTAINER
     ============================================ */
  .process-timeline {
    position: relative;
    z-index: 10;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ============================================
     CONNECTION LINE
     ============================================ */
  .connection-line {
    position: absolute;
    top: 140px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 200px);
    max-width: 560px;
    height: 2px;
    display: none;
    pointer-events: none;
  }

  .line-track {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(0,0,0,0.04) 15%, rgba(0,0,0,0.04) 85%, transparent 100%);
    border-radius: 1px;
  }

  .line-progress {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--ios-blue), #5AC8FA);
    border-radius: 1px;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .line-dot {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    box-shadow: 0 0 0 2.5px var(--ios-blue), 0 0 16px rgba(0,122,255,0.35);
    opacity: 0;
    transition: opacity 0.4s ease, left 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .line-progress.visible + .line-dot {
    opacity: 1;
  }

  @media (min-width: 900px) {
    .connection-line { display: block; }
  }

  /* ============================================
     STEPS GRID
     ============================================ */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    position: relative;
  }

  @media (max-width: 900px) {
    .steps-grid {
      grid-template-columns: 1fr;
      max-width: 640px;
      margin: 0 auto;
      gap: var(--space-6);
    }
  }

  @media (max-width: 640px) {
    .steps-grid {
      max-width: 100%;
    }
  }

  /* ============================================
     STEP ISLAND — Definitive Liquid Glass
     ============================================ */
  .step-island {
    position: relative;
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    min-height: 340px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    cursor: default;
    transition: transform 0.45s var(--ease-ios-spring), box-shadow 0.35s var(--ease-ios);
    will-change: transform;
    transform: translateZ(0);
  }

  .step-island::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 4;
    border-radius: inherit;
    background:
      linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.22) 20%, transparent 38%),
      radial-gradient(ellipse 70% 42% at 50% -8%, rgba(255,255,255,0.26), transparent 74%);
    opacity: 0;
    transform: translateX(-14%);
    pointer-events: none;
    transition: opacity 0.35s var(--ease-ios), transform 0.7s var(--ease-ios-decel);
  }

  /* Glass Base */
  .island-glass {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-glass);
    transform: translateZ(0);
    transition: box-shadow 0.35s var(--ease-ios), background 0.35s var(--ease-ios);
  }

  .card-blue .island-glass   { background: rgba(236, 246, 255, 0.74); }
  .card-indigo .island-glass { background: rgba(243, 240, 255, 0.74); }
  .card-teal .island-glass   { background: rgba(232, 252, 255, 0.74); }

  /* Specular Highlight */
  .island-specular {
    position: absolute;
    top: 1px;
    left: 1px;
    right: 1px;
    height: 55%;
    border-radius: calc(var(--radius-xl) - 1px) calc(var(--radius-xl) - 1px) 0 0;
    background: linear-gradient(180deg,
      rgba(255,255,255,0.92) 0%,
      rgba(255,255,255,0.50) 35%,
      rgba(255,255,255,0.10) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
    opacity: 0.9;
  }

  /* Ambient Glow — tint per card */
  .island-ambient {
    position: absolute;
    inset: -1px;
    border-radius: 23px;
    opacity: 0;
    transition: opacity 0.35s var(--ease-ios);
    pointer-events: none;
    z-index: -1;
  }

  .card-blue .island-ambient {
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0,122,255,0.22) 0%, transparent 70%);
  }

  .card-indigo .island-ambient {
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(88,86,214,0.22) 0%, transparent 70%);
  }

  .card-teal .island-ambient {
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(6,182,212,0.22) 0%, transparent 70%);
  }

  /* ============================================
     HOVER EFFECTS
     ============================================ */
  .step-island:hover {
    transform: translateY(-4px) scale(1.003);
  }

  .step-island:hover::after {
    opacity: 0.76;
    transform: translateX(0);
  }

  .step-island:hover .island-glass {
    background: var(--glass-bg-hover);
    box-shadow: var(--shadow-glass-hover);
  }

  .step-island:hover .island-ambient {
    opacity: 1;
  }

  .step-island:hover .step-watermark {
    opacity: 0.055;
    transform: translateY(-2px);
  }

  .step-island:hover .step-visual svg {
    transform: scale(1.055) translateY(-2px);
  }

  /* ============================================
     WATERMARK NUMBER
     ============================================ */
  .step-watermark {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    font-family: var(--font-display);
    font-size: clamp(5rem, 10vw, 7rem);
    font-weight: var(--font-extrabold);
    line-height: 1;
    letter-spacing: var(--tracking-tighter);
    color: var(--text-primary);
    opacity: 0.035;
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.5s ease, transform 0.5s var(--ease-ios-spring);
    user-select: none;
  }

  /* ============================================
     ISLAND CONTENT
     ============================================ */
  .island-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Meta row */
  .step-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-1);
  }

  .meta-index {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    background: rgba(0,0,0,0.035);
    border: 1px solid rgba(0,0,0,0.04);
    font-size: 0.75rem;
    font-weight: var(--font-semibold);
    color: var(--text-secondary);
    letter-spacing: var(--tracking-wide);
  }

  .card-blue .meta-tag   { background: rgba(0,122,255,0.07); color: var(--ios-blue); border-color: rgba(0,122,255,0.1); }
  .card-indigo .meta-tag { background: rgba(88,86,214,0.07); color: var(--ios-indigo); border-color: rgba(88,86,214,0.1); }
  .card-teal .meta-tag   { background: rgba(6,182,212,0.07); color: #0891B2; border-color: rgba(6,182,212,0.1); }

  /* Title */
  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin: 0;
    line-height: var(--leading-snug);
  }

  /* Description */
  .step-description {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin: 0;
    max-width: 280px;
  }

  /* ============================================
     ABSTRACT VISUAL
     ============================================ */
  .step-visual {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-top: var(--space-8);
    height: 64px;
  }

  .step-visual svg {
    transition: transform 0.5s var(--ease-ios-spring);
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.04));
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 900px) {
    .how-section {
      padding: var(--section-py-mobile) 0;
    }

    .step-island {
      min-height: auto;
      padding: var(--space-7);
      border-radius: var(--radius-xl);
    }

    .island-glass,
    .island-ambient {
      border-radius: inherit;
    }

    .island-specular {
      border-radius: calc(var(--radius-xl) - 1px) calc(var(--radius-xl) - 1px) 0 0;
    }

    .step-watermark {
      font-size: 4.5rem;
      top: var(--space-5);
      right: var(--space-5);
    }

    .step-title {
      font-size: var(--text-xl);
    }

    .step-visual {
      margin-top: var(--space-6);
      height: 56px;
    }

    .step-visual svg {
      transform: scale(0.9);
      transform-origin: right center;
    }
  }

  @media (max-width: 480px) {
    .how-section {
      padding: var(--section-py-mobile) 0;
    }

    .step-island {
      padding: var(--space-5);
      border-radius: var(--radius-xl);
    }

    .island-glass,
    .island-ambient {
      border-radius: inherit;
    }

    .island-specular {
      border-radius: calc(var(--radius-xl) - 1px) calc(var(--radius-xl) - 1px) 0 0;
    }

    .step-watermark {
      font-size: 3rem;
      top: var(--space-4);
      right: var(--space-4);
    }

    .step-title {
      font-size: var(--text-lg);
    }

    .step-description {
      font-size: var(--text-sm);
    }

    .step-visual {
      display: none;
    }

    .meta-tag {
      font-size: 0.6875rem;
      padding: 1px 8px;
    }

    .step-meta {
      gap: var(--space-2);
    }
  }

  /* ============================================
     REDUCED MOTION
     ============================================ */
  @media (prefers-reduced-motion: reduce) {
    .step-island,
    .step-island::after,
    .island-glass,
    .island-ambient,
    .island-specular,
    .step-watermark,
    .step-visual svg {
      transition: none !important;
    }
  }
</style>

<script>
  // Line progress animation
  const howSection = document.querySelector('.how-section');
  const lineProgress = document.getElementById('line-progress');
  const lineDot = document.getElementById('line-dot');

  if (howSection && lineProgress) {
    const updateProgress = () => {
      const rect = howSection.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      const sectionTop = rect.top;
      const sectionHeight = rect.height;

      const scrollProgress = Math.max(0, Math.min(1,
        (windowHeight - sectionTop) / (windowHeight + sectionHeight * 0.3)
      ));

      const width = scrollProgress * 100;
      lineProgress.style.width = `${width}%`;

      if (lineDot) {
        lineDot.style.left = `${width}%`;
      }

      if (scrollProgress > 0.05) {
        lineProgress.classList.add('visible');
      }
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          window.addEventListener('scroll', updateProgress, { passive: true });
          updateProgress();
        } else {
          window.removeEventListener('scroll', updateProgress);
        }
      });
    }, { threshold: 0.1 });

    observer.observe(howSection);
  }
</script>
