---
import { siteConfig } from '../../config/site';
import { Mail, Upload, ArrowRight, FileText, CheckCircle } from 'lucide-astro';
import SectionHeader from '../ui/SectionHeader.astro';
import LiquidAction from '../ui/LiquidAction.astro';
---

<section id="contacto" class="contact-section" aria-label="Envía tu factura">
  <div class="container-custom">

    <SectionHeader
      eyebrow="Estudio gratuito"
      title="Solicita una revisión."
      accent="Sin compromiso."
      subtitle="Rellena el formulario y adjunta tu última factura. Haré un estudio gratuito de tus condiciones y te explicaré si hay margen de mejora."
      variant="compact"
    />

    <!-- Form Card -->
    <div class="form-wrapper reveal" data-delay="1">
      <div class="form-card">
        <div class="form-specular"></div>
        <div class="form-glow"></div>

        <div class="form-content">
          <form
            name="contacto"
            class="contact-form"
            id="bill-form"
            method="POST"
            action="/gracias"
            enctype="multipart/form-data"
            netlify
          >
            <input type="hidden" name="form-name" value="contacto" />

            <!-- Name -->
            <div class="field-group">
              <label for="name" class="field-label">Nombre completo</label>
              <div class="input-wrap">
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="form-input surface-field"
                  placeholder="Tu nombre"
                  required
                />
              </div>
            </div>

            <!-- Phone -->
            <div class="field-group">
              <label for="phone" class="field-label">Teléfono de contacto</label>
              <div class="input-wrap">
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="form-input surface-field"
                  placeholder="Ej: 612 345 678"
                  required
                />
              </div>
            </div>

            <!-- Email -->
            <div class="field-group">
              <label for="email" class="field-label">Correo electrónico</label>
              <div class="input-wrap">
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input surface-field"
                  placeholder="tu@email.com"
                />
              </div>
            </div>

            <!-- File Upload -->
            <div class="field-group">
              <label for="bill-file" class="field-label">Factura de luz</label>
              <div class="upload-zone" id="upload-zone">
                <input 
                  type="file" 
                  id="bill-file" 
                  name="attachment" 
                  class="file-input"
                  accept=".pdf,.jpg,.jpeg,.png"
                  required
                />
                <div class="upload-content">
                  <div class="upload-icon">
                    <Upload size={24} aria-hidden="true" />
                  </div>
                  <p class="upload-text">Arrastra tu factura aquí o <span class="upload-link">haz clic para seleccionar</span></p>
                  <p class="upload-hint">PDF, JPG o PNG. Máx. 5 MB.</p>
                </div>
                <div class="upload-preview" id="upload-preview">
                  <FileText size={18} aria-hidden="true" />
                  <span class="preview-name" id="preview-name"></span>
                  <button type="button" class="preview-remove" id="preview-remove" aria-label="Eliminar archivo">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </div>
              </div>
            </div>

            <!-- Message -->
            <div class="field-group">
              <label for="message" class="field-label">Mensaje (opcional)</label>
              <div class="input-wrap">
                <textarea
                  id="message"
                  name="body"
                  class="form-textarea surface-field"
                  rows="3"
                  placeholder="Cuéntame si quieres revisar subida de precio, potencia o alguna duda concreta."
                ></textarea>
              </div>
            </div>

            <!-- File notice -->
            <div class="file-notice file-notice--info" id="file-notice">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>La factura se adjuntará al enviar el formulario.</span>
            </div>

            <!-- Submit -->
            <LiquidAction
              type="submit"
              class="submit-btn"
              bgClass="submit-bg"
              shineClass="submit-shine"
              contentClass="submit-content"
            >
              <Mail size={18} aria-hidden="true" />
              Solicitar estudio gratuito
              <ArrowRight size={16} aria-hidden="true" />
            </LiquidAction>

            <!-- Trust note -->
            <div class="form-trust">
              <CheckCircle size={14} aria-hidden="true" />
              <span>Usaré tu factura solo para estudiar la consulta. No habrá cambios ni contratación sin tu autorización expresa.</span>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Secondary contact options -->
    <div class="alt-contact reveal" data-delay="2">
      <p class="alt-text">También puedes consultarme antes de enviar la factura.</p>
      <div class="alt-links">
        <a href={siteConfig.whatsappUrl} class="alt-link alt-whatsapp" rel="noopener noreferrer">
          WhatsApp
        </a>
        <a href={`mailto:${siteConfig.email}`} class="alt-link alt-email">
          Email
        </a>
        <a href={`tel:${siteConfig.phoneClean}`} class="alt-link alt-phone">
          Llamar
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .contact-section {
    position: relative;
    padding: var(--section-py) 0;
    overflow: hidden;
  }

  /* Form Card */
  .form-wrapper {
    max-width: 560px;
    margin: 0 auto;
  }

  .form-card {
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-glass);
    transition: transform 0.45s var(--ease-ios-spring), box-shadow 0.35s var(--ease-ios), background 0.35s var(--ease-ios);
    transform: translateZ(0);
    will-change: transform;
  }

  .form-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background:
      linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.20) 20%, transparent 38%),
      radial-gradient(ellipse 78% 45% at 50% -10%, rgba(0,122,255,0.10), transparent 72%);
    opacity: 0;
    transform: translateX(-14%);
    pointer-events: none;
    transition: opacity 0.35s var(--ease-ios), transform 0.7s var(--ease-ios-decel);
  }

  .form-card:hover {
    transform: translateY(-4px) scale(1.003);
    background: var(--glass-bg-hover);
    box-shadow: var(--shadow-glass-hover);
  }

  .form-card:hover::after {
    opacity: 0.74;
    transform: translateX(0);
  }

  .form-specular {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(180deg,
      rgba(255,255,255,0.92) 0%,
      rgba(255,255,255,0.45) 35%,
      rgba(255,255,255,0.10) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .form-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0,122,255,0.18) 0%, transparent 70%);
    opacity: 0.6;
    transition: opacity 0.35s var(--ease-ios), transform 0.7s var(--ease-ios-decel);
    pointer-events: none;
    z-index: 0;
  }

  .form-card:hover .form-glow {
    opacity: 0.78;
    transform: translateY(-3px) scale(1.025);
  }

  .form-content {
    position: relative;
    z-index: 2;
    padding: var(--space-8) var(--space-8);
  }

  /* Form Fields */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field-label {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    letter-spacing: var(--tracking-normal);
  }

  .input-wrap {
    position: relative;
  }

  .form-input,
  .form-textarea {
    resize: vertical;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-quaternary);
  }

  /* File Upload */
  .upload-zone {
    position: relative;
    border: 2px dashed rgba(0, 122, 255, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
    background: rgba(255, 255, 255, 0.46);
    transition: border-color 0.3s var(--ease-ios), background 0.3s var(--ease-ios), box-shadow 0.3s var(--ease-ios), transform 0.3s var(--ease-ios-spring);
    cursor: pointer;
  }

  .upload-zone:hover,
  .upload-zone.drag-over {
    border-color: var(--color-primary);
    background: rgba(0, 122, 255, 0.04);
    box-shadow: 0 0 0 4px rgba(0, 122, 255, 0.06);
    transform: translateY(-2px);
  }

  .upload-zone:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px rgba(0, 122, 255, 0.12);
  }

  .file-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    pointer-events: none;
  }

  .upload-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(0,122,255,0.1) 0%, rgba(0,122,255,0.05) 100%);
    color: var(--color-primary);
    margin-bottom: var(--space-1);
    transition: transform 0.35s var(--ease-ios-spring), box-shadow 0.35s var(--ease-ios), background 0.35s var(--ease-ios);
  }

  .upload-zone:hover .upload-icon,
  .upload-zone.drag-over .upload-icon {
    transform: translateY(-2px) scale(1.035);
    background: linear-gradient(135deg, rgba(0,122,255,0.16) 0%, rgba(90,200,250,0.08) 100%);
    box-shadow: 0 14px 30px rgba(0, 122, 255, 0.12);
  }

  .upload-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
    font-weight: var(--font-medium);
  }

  .upload-link {
    color: var(--color-primary);
    font-weight: var(--font-semibold);
  }

  .upload-hint {
    font-size: var(--text-xs);
    color: var(--text-quaternary);
    margin: 0;
  }

  .upload-preview {
    display: none;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: rgba(0, 122, 255, 0.08);
    border: 1px solid rgba(0, 122, 255, 0.15);
    border-radius: var(--radius-pill);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    margin-top: var(--space-2);
  }

  .upload-preview.active {
    display: inline-flex;
  }

  .preview-name {
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .preview-remove {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(0, 122, 255, 0.15);
    color: var(--color-primary);
    border: none;
    cursor: pointer;
    padding: 0;
    margin-left: var(--space-1);
    transition: background 0.2s var(--ease-ios), transform 0.2s var(--ease-ios-spring);
  }

  .preview-remove:hover {
    background: rgba(0, 122, 255, 0.25);
    transform: scale(1.1);
  }

  /* Submit Button */
  :global(.submit-btn) {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: 17px 36px;
    border-radius: var(--radius-pill);
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    font-family: var(--font-display);
    color: var(--text-inverse);
    text-decoration: none;
    border: none;
    cursor: pointer;
    overflow: hidden;
    letter-spacing: var(--tracking-normal);
    transition: transform var(--duration-normal) var(--ease-ios-spring), box-shadow var(--duration-normal) var(--ease-ios);
    box-shadow:
      0 4px 14px rgba(0,122,255,0.32),
      0 1px 3px rgba(0,122,255,0.18),
      inset 0 1px 0 rgba(255,255,255,0.22);
    will-change: transform;
    touch-action: manipulation;
    margin-top: var(--space-2);
  }

  :global(.submit-bg) {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 50%, var(--color-primary) 100%);
    background-size: 200% 100%;
    animation: shimmer-btn 4.5s ease-in-out infinite;
  }

  :global(.submit-shine) {
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
    animation: shine 3.5s ease-in-out infinite;
  }

  :global(.submit-content) {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  :global(.submit-btn:hover) {
    transform: scale(1.04) translateY(-3px);
    box-shadow:
      0 8px 28px rgba(0,122,255,0.45),
      0 4px 14px rgba(0,122,255,0.25),
      inset 0 1px 0 rgba(255,255,255,0.35);
  }

  :global(.submit-btn:active) {
    transform: scale(0.97) translateY(0);
  }

  @keyframes shimmer-btn {
    0%, 100% { background-position: 0% 50%; }
    50%       { background-position: 100% 50%; }
  }

  @keyframes shine {
    0%, 100% { left: -100%; }
    50% { left: 150%; }
  }

  /* File notice */
  .file-notice {
    display: none;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: rgba(0, 122, 255, 0.06);
    border: 1px solid rgba(0, 122, 255, 0.15);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .file-notice.active {
    display: flex;
  }

  .file-notice svg {
    flex-shrink: 0;
    margin-top: 1px;
    stroke: var(--color-primary);
  }

  /* Trust note */
  .form-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-top: var(--space-1);
  }

  .form-trust svg {
    stroke: var(--color-success);
    flex-shrink: 0;
  }

  /* Alt Contact */
  .alt-contact {
    text-align: center;
    margin-top: var(--space-10);
  }

  .alt-text {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: var(--space-3);
  }

  .alt-links {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .alt-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    text-decoration: none;
    transition: transform 0.3s var(--ease-ios-spring), background 0.3s var(--ease-ios), border-color 0.3s var(--ease-ios), box-shadow 0.3s var(--ease-ios);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.72);
  }

  .alt-whatsapp {
    background: rgba(37, 211, 102, 0.1);
    color: #128C7E;
    border: 1px solid rgba(37, 211, 102, 0.2);
  }

  .alt-whatsapp:hover {
    background: rgba(37, 211, 102, 0.18);
    transform: translateY(-2px) scale(1.018);
  }

  .alt-email {
    background: rgba(0, 122, 255, 0.08);
    color: var(--color-primary);
    border: 1px solid rgba(0, 122, 255, 0.15);
  }

  .alt-email:hover {
    background: rgba(0, 122, 255, 0.14);
    transform: translateY(-2px) scale(1.018);
  }

  .alt-phone {
    background: rgba(255, 149, 0, 0.08);
    color: #FF6B00;
    border: 1px solid rgba(255, 149, 0, 0.15);
  }

  .alt-phone:hover {
    background: rgba(255, 149, 0, 0.14);
    transform: translateY(-2px) scale(1.018);
  }

  /* Responsive */
  @media (max-width: 767px) {
    .form-content {
      padding: var(--space-6) var(--space-5);
    }

    .contact-form {
      gap: var(--space-4);
    }

    :global(.submit-btn) {
      padding: 15px 28px;
      font-size: var(--text-md);
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .form-content {
      padding: var(--space-5) max(var(--space-4), env(safe-area-inset-left));
    }

    .contact-form {
      gap: var(--space-3);
    }

    .upload-zone {
      padding: var(--space-4);
    }

    .upload-text {
      font-size: var(--text-sm);
    }

    .alt-links {
      flex-direction: column;
      align-items: center;
    }

    .alt-link {
      width: 100%;
      justify-content: center;
    }

    .form-card {
      border-radius: var(--radius-xl);
    }

    .form-specular,
    .form-glow {
      border-radius: inherit;
    }

    .form-trust {
      font-size: var(--text-xs);
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .form-card,
    .form-card::after,
    .form-glow,
    .upload-zone,
    :global(.submit-bg),
    :global(.submit-shine) {
      animation: none !important;
      transition: none !important;
    }

    .form-card:hover,
    .upload-zone:hover,
    :global(.submit-btn:hover) {
      transform: none;
    }
  }
</style>

<script>
  const fileInput = document.getElementById('bill-file') as HTMLInputElement;
  const uploadZone = document.getElementById('upload-zone');
  const uploadContent = uploadZone?.querySelector('.upload-content') as HTMLElement;
  const uploadPreview = document.getElementById('upload-preview') as HTMLElement;
  const previewName = document.getElementById('preview-name') as HTMLElement;
  const previewRemove = document.getElementById('preview-remove') as HTMLButtonElement;
  const fileNotice = document.getElementById('file-notice');
  const form = document.getElementById('bill-form') as HTMLFormElement;

  const MAX_SIZE_MB = 5;
  const ALLOWED_TYPES = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png'];
  const ALLOWED_EXT = ['.pdf', '.jpg', '.jpeg', '.png'];

  function isValidFile(file: File): boolean {
    const sizeOk = file.size <= MAX_SIZE_MB * 1024 * 1024;
    const typeOk = ALLOWED_TYPES.includes(file.type) || ALLOWED_EXT.some(ext => file.name.toLowerCase().endsWith(ext));
    return sizeOk && typeOk;
  }

  function showPreview(file: File) {
    if (!isValidFile(file)) {
      alert(`Archivo no válido. Usa PDF, JPG o PNG (máx. ${MAX_SIZE_MB} MB).`);
      if (fileInput) fileInput.value = '';
      return;
    }
    if (uploadContent) uploadContent.style.display = 'none';
    if (previewName) previewName.textContent = file.name;
    uploadPreview?.classList.add('active');
    fileNotice?.classList.add('active');
  }

  function clearPreview() {
    if (fileInput) fileInput.value = '';
    if (uploadContent) uploadContent.style.display = 'flex';
    uploadPreview?.classList.remove('active');
    fileNotice?.classList.remove('active');
  }

  fileInput?.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) showPreview(file);
  });

  previewRemove?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    clearPreview();
  });

  // Drag & drop with better visual states
  ['dragenter', 'dragover'].forEach(eventName => {
    uploadZone?.addEventListener(eventName, (e) => {
      e.preventDefault();
      uploadZone.classList.add('drag-over');
    });
  });

  ['dragleave', 'drop'].forEach(eventName => {
    uploadZone?.addEventListener(eventName, (e) => {
      e.preventDefault();
      uploadZone.classList.remove('drag-over');
    });
  });

  uploadZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    const files = e.dataTransfer?.files;
    if (files && files[0]) {
      fileInput.files = files;
      showPreview(files[0]);
    }
  });
</script>
