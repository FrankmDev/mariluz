---
import { Image } from 'astro:assets';
import { siteConfig } from '../../config/site';
import SectionHeader from '../ui/SectionHeader.astro';
import Counter from '../ui/Counter.astro';
import LiquidAction from '../ui/LiquidAction.astro';
import aboutPhoto from '../../assets/about.avif';
import {
  BadgeCheck,
  CheckCircle2,
  Clock,
  Send,
  Shield,
  Sparkles,
  TrendingDown,
  Users,
} from 'lucide-astro';

const { advisor } = siteConfig;
const averageYearly = siteConfig.savings.averageYearly;
---

<section id="sobre-mi" class="about-section" aria-label="Sobre mí">
  <div class="orb orb-blue-soft float-slow" style="width: 320px; height: 320px; top: 6%; left: -8%; opacity: 0.34;" aria-hidden="true"></div>
  <div class="orb orb-cyan-soft float-breathe" style="width: 240px; height: 240px; bottom: 10%; right: -6%; opacity: 0.28;" aria-hidden="true"></div>

  <div class="container-custom">
    <SectionHeader
      eyebrow="Tu asesora"
      title="Quién revisa."
      accent="Mariluz Marín."
      subtitle="Revisión directa, con criterio y con una propuesta solo cuando mejora el caso."
    />

    <div class="about-grid">
      <article class="about-card about-profile reveal">
        <div class="profile-media">
          <Image
            src={aboutPhoto}
            alt={`${advisor.name}, ${advisor.title}`}
            class="profile-image"
            width={600}
            height={800}
            loading="lazy"
            decoding="async"
          />
          <div class="profile-shade" aria-hidden="true"></div>
          <div class="profile-specular" aria-hidden="true"></div>
        </div>

        <div class="profile-status surface-pill">
          <span class="status-dot" aria-hidden="true"></span>
          Atención directa
        </div>

        <div class="profile-body">
          <div class="profile-copy">
            <p class="profile-kicker">Asesoría personal</p>
            <h3 class="profile-name">{advisor.name}</h3>
            <p class="profile-role">{advisor.title}</p>
          </div>
          <div class="profile-meta-pills">
            <span class="surface-pill profile-pill">
              <BadgeCheck size={13} aria-hidden="true" />
              Desde {advisor.since}
            </span>
            <span class="surface-pill profile-pill">
              <Shield size={13} aria-hidden="true" />
              Revisión individual
            </span>
          </div>
        </div>
      </article>

      <article class="about-card about-stats reveal" data-delay="1">
        <div class="card-specular"></div>
        <div class="stats-strip">
          <div class="stat-item">
            <span class="icon-tile icon-tile-blue">
              <Users size={18} aria-hidden="true" />
            </span>
            <div class="stat-copy">
              <div class="stat-value"><Counter endValue={advisor.clients} suffix="+" /></div>
              <p class="stat-label">facturas revisadas</p>
            </div>
          </div>

          <div class="stat-rule" aria-hidden="true"></div>

          <div class="stat-item">
            <span class="icon-tile icon-tile-violet">
              <Clock size={18} aria-hidden="true" />
            </span>
            <div class="stat-copy">
              <div class="stat-value"><Counter endValue={24} suffix="h" /></div>
              <p class="stat-label">respuesta habitual</p>
            </div>
          </div>

          <div class="stat-rule" aria-hidden="true"></div>

          <div class="stat-item">
            <span class="icon-tile icon-tile-gradient">
              <TrendingDown size={18} aria-hidden="true" />
            </span>
            <div class="stat-copy">
              <div class="stat-value stat-value-accent"><Counter endValue={averageYearly} suffix="€" /></div>
              <p class="stat-label">mejora media orientativa</p>
            </div>
          </div>
        </div>
      </article>

      <article class="about-card about-bio reveal" data-delay="2">
        <div class="card-specular"></div>
        <div class="panel-body">
          <p class="panel-kicker panel-kicker-green">Método</p>
          <h3 class="panel-title">Reviso, comparo y explico antes de proponer.</h3>
          <p class="panel-text">
            Reviso tu factura, comparo opciones reales y te explico el resultado antes de plantear cualquier cambio.
          </p>

          <ul class="panel-list">
            <li>
              <span class="list-icon icon-tile icon-tile-green">
                <CheckCircle2 size={14} aria-hidden="true" />
              </span>
              Propuesta clara antes de decidir
            </li>
            <li>
              <span class="list-icon icon-tile icon-tile-green">
                <CheckCircle2 size={14} aria-hidden="true" />
              </span>
              Revisión inicial sin coste
            </li>
            <li>
              <span class="list-icon icon-tile icon-tile-green">
                <CheckCircle2 size={14} aria-hidden="true" />
              </span>
              Recomendación conservadora si no compensa
            </li>
          </ul>
        </div>
      </article>

      <article class="about-card about-cta reveal" data-delay="3">
        <div class="card-specular"></div>
        <div class="panel-body">
          <p class="panel-kicker panel-kicker-blue">Siguiente paso</p>
          <h3 class="panel-title">Envía la factura y te explico el resultado.</h3>
          <p class="panel-text">
            Si hay una mejora clara, recibirás una propuesta entendible antes de decidir si sigues adelante.
          </p>

          <div class="cta-trust">
            <span class="surface-pill trust-pill">
              <Shield size={13} aria-hidden="true" />
              Datos protegidos
            </span>
            <span class="surface-pill trust-pill">
              <Sparkles size={13} aria-hidden="true" />
              Sin cambio automático
            </span>
          </div>

          <LiquidAction
            href="#contacto"
            class="about-cta-button"
            ariaLabel="Enviar factura para revisión inicial"
            bgClass="about-cta-bg"
            contentClass="about-cta-content"
          >
            <Send size={17} aria-hidden="true" />
            <span>Enviar factura</span>
          </LiquidAction>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    padding: var(--space-32) 0 var(--space-40);
    overflow: hidden;
    isolation: isolate;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr 1fr;
    grid-template-rows: minmax(126px, auto) minmax(280px, auto);
    grid-auto-flow: dense;
    gap: var(--space-5);
    position: relative;
    z-index: 1;
  }

  .about-profile {
    grid-column: 1;
    grid-row: 1 / 3;
    min-height: 620px;
  }

  .about-stats {
    grid-column: 2 / 4;
    grid-row: 1;
  }

  .about-bio {
    grid-column: 2;
    grid-row: 2;
  }

  .about-cta {
    grid-column: 3;
    grid-row: 2;
  }

  .about-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2xl);
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-glass);
    transition: transform 0.45s var(--ease-ios-spring), background 0.35s var(--ease-ios), box-shadow 0.35s var(--ease-ios);
    transform: translateZ(0);
    will-change: transform;
  }

  .about-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background:
      linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.20) 20%, transparent 38%),
      radial-gradient(ellipse 82% 46% at 50% -10%, rgba(255,255,255,0.24), transparent 72%);
    opacity: 0;
    transform: translateX(-14%);
    pointer-events: none;
    transition: opacity 0.35s var(--ease-ios), transform 0.7s var(--ease-ios-decel);
  }

  .about-card:hover {
    transform: translateY(-4px) scale(1.003);
    background: var(--glass-bg-hover);
    box-shadow: var(--shadow-glass-hover);
  }

  .about-card:hover::after {
    opacity: 0.74;
    transform: translateX(0);
  }

  .about-card:active {
    transform: translateY(-1px) scale(0.992);
    box-shadow: var(--shadow-glass-pressed);
  }

  .about-stats {
    background: var(--surface-tint-blue);
  }

  .about-bio {
    background: var(--surface-tint-green);
  }

  .about-cta {
    background: var(--surface-tint-violet);
  }

  .card-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.45) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .about-profile {
    border-radius: var(--radius-2xl);
  }

  .profile-media {
    position: absolute;
    inset: 0;
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
    display: block;
    transition: transform 0.9s var(--ease-ios);
  }

  .about-profile:hover .profile-image {
    transform: scale(1.035);
  }

  .profile-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 18, 36, 0.08) 0%,
      rgba(10, 18, 36, 0.08) 38%,
      rgba(10, 18, 36, 0.42) 72%,
      rgba(8, 14, 32, 0.78) 100%
    );
  }

  .profile-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 24%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0.05) 65%, transparent 100%);
  }

  .profile-status {
    position: absolute;
    top: var(--space-5);
    left: var(--space-5);
    z-index: 3;
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
  }

  .profile-body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    padding: var(--space-6) var(--space-5) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .profile-kicker {
    margin: 0 0 0.35rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .profile-name {
    margin: 0;
    color: white;
    font-size: clamp(1.7rem, 2vw, 2.15rem);
    font-weight: var(--font-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.3);
  }

  .profile-role {
    margin: 0.45rem 0 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    line-height: 1.45;
  }

  .profile-meta-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .profile-pill {
    font-size: var(--text-xs);
    color: white;
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.22);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22);
    transition: transform 0.35s var(--ease-ios-spring), background 0.35s var(--ease-ios), border-color 0.35s var(--ease-ios);
  }

  .about-profile:hover .profile-pill {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .stats-strip {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    min-height: 100%;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .stat-rule {
    width: 1px;
    height: 42px;
    background: linear-gradient(180deg, transparent 0%, rgba(15, 23, 42, 0.12) 50%, transparent 100%);
  }

  .stat-copy {
    min-width: 0;
  }

  .stat-value {
    font-size: clamp(1.65rem, 2vw, 2rem);
    line-height: 1;
    letter-spacing: var(--tracking-tighter);
    font-weight: var(--font-extrabold);
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
    transition: transform 0.35s var(--ease-ios-spring);
  }

  .about-stats:hover .stat-value {
    transform: translateY(-1px);
  }

  .stat-value-accent {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-500) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    margin: 0.35rem 0 0;
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    line-height: 1.3;
  }

  .panel-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    padding: clamp(22px, 2.5vw, 28px);
  }

  .panel-kicker {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .panel-kicker-green {
    color: var(--color-success-hover);
  }

  .panel-kicker-blue {
    color: var(--color-primary);
  }

  .panel-title {
    margin: 0;
    color: var(--text-primary);
    font-size: clamp(1.22rem, 1.65vw, 1.58rem);
    line-height: 1.12;
    letter-spacing: var(--tracking-tighter);
    font-weight: var(--font-extrabold);
    text-wrap: balance;
    max-width: 14ch;
  }

  .panel-text {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.58;
    max-width: 54ch;
  }

  .panel-list {
    list-style: none;
    padding: 0;
    margin: auto 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .panel-list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-primary);
    font-size: var(--text-sm);
    line-height: 1.42;
    font-weight: var(--font-medium);
  }

  .list-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 12px;
  }

  .cta-trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .trust-pill {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    font-weight: var(--font-semibold);
  }

  :global(.about-cta-button) {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-top: auto;
    padding: 0.95rem 1.35rem;
    border-radius: var(--radius-pill);
    color: var(--text-inverse);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 122, 255, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.24);
    transition: transform var(--duration-normal) var(--ease-ios-spring), box-shadow var(--duration-normal) var(--ease-ios);
  }

  :global(.about-cta-button:hover) {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0, 122, 255, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.26);
  }

  :global(.about-cta-bg) {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 52%, var(--color-primary) 100%);
    background-size: 200% 100%;
    animation: about-cta-shift 4.5s ease-in-out infinite;
  }

  :global(.about-cta-content) {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  @keyframes about-cta-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }

    .about-profile,
    .about-stats {
      grid-column: span 2;
    }

    .about-profile {
      min-height: 500px;
    }
  }

  @media (max-width: 767px) {
    .about-section {
      padding: var(--space-24) 0;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .about-profile,
    .about-stats,
    .about-bio,
    .about-cta {
      grid-column: auto;
      grid-row: auto;
    }

    .about-profile {
      min-height: 470px;
    }

    .about-card {
      border-radius: var(--radius-xl);
    }

    .stats-strip {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .stat-rule {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent 0%, rgba(15, 23, 42, 0.12) 50%, transparent 100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-card,
    .about-card::after,
    .profile-image,
    :global(.about-cta-bg) {
      animation: none !important;
      transition: none !important;
    }

    .about-card:hover,
    .about-profile:hover .profile-image,
    :global(.about-cta-button:hover) {
      transform: none;
    }
  }
</style>
