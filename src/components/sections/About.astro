<script>
  // 3D Tilt Effect on Cards - Premium Smooth
  const tiltCards = document.querySelectorAll('[data-tilt]');
  
  tiltCards.forEach(card => {
    let rafId: number | null = null;
    let targetRotateX = 0;
    let targetRotateY = 0;
    let currentRotateX = 0;
    let currentRotateY = 0;
    
    const animate = () => {
      // Smooth interpolation
      currentRotateX += (targetRotateX - currentRotateX) * 0.12;
      currentRotateY += (targetRotateY - currentRotateY) * 0.12;
      
      card.style.transform = `perspective(1000px) rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg)`;
      
      if (Math.abs(targetRotateX - currentRotateX) > 0.01 || Math.abs(targetRotateY - currentRotateY) > 0.01) {
        rafId = requestAnimationFrame(animate);
      } else {
        rafId = null;
      }
    };
    
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      
      targetRotateX = (y - centerY) / 25;
      targetRotateY = (centerX - x) / 25;
      
      if (!rafId) {
        rafId = requestAnimationFrame(animate);
      }
    });
    
    card.addEventListener('mouseleave', () => {
      targetRotateX = 0;
      targetRotateY = 0;
      if (!rafId) {
        rafId = requestAnimationFrame(animate);
      }
    });
  });

  // Cursor Glow Effect
  const aboutSection = document.getElementById('about');
  
  if (aboutSection && !window.matchMedia('(pointer: coarse)').matches) {
    aboutSection.addEventListener('mousemove', (e) => {
      const rect = aboutSection.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      
      aboutSection.style.setProperty('--mouse-x', x);
      aboutSection.style.setProperty('--mouse-y', y);
    });
  }
</script>
