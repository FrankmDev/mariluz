---
import { Image } from 'astro:assets';
import { siteConfig } from '../../config/site';
import Counter from '../ui/Counter.astro';
import aboutPhoto from '../../assets/about.jpeg';
import { MessageCircle } from 'lucide-astro';

const { advisor } = siteConfig;
const averageYearly = siteConfig.savings.averageYearly;
---

<section class="about" aria-label="Sobre mí" id="sobre-mi" data-cursor-glow>
  <div class="container">
    <!-- Section Header -->
    <div class="section-header reveal-blur">
      <div class="eyebrow-pill">
        <span class="eyebrow-dot"></span>
        <span class="eyebrow-text">Tu asesora</span>
      </div>
      <h2 class="section-title">
        <span class="title-line">Conoce a</span>
        <span class="title-accent">{advisor.name}</span>
      </h2>
      <p class="section-subtitle">{advisor.title}</p>
    </div>

    <!-- Bento Grid Layout -->
    <div class="bento-grid">
      <!-- Main Profile Card (Large) -->
      <div class="bento-item bento-profile" data-tilt>
        <div class="card-layers profile-layers">
          <div class="card-layer layer-back"></div>
          <div class="card-layer layer-mid"></div>
          <div class="card-layer layer-front">
            <div class="card-highlight"></div>
            <div class="card-content profile-content">
              <div class="profile-image-full">
                <div class="image-frame">
                  <Image
                    src={aboutPhoto}
                    alt={`${advisor.name}, ${advisor.title}`}
                    class="profile-image"
                    width={600}
                    height={800}
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="image-overlay"></div>
                </div>
                <div class="availability-badge">
                  <div class="badge-pulse"></div>
                  <span class="badge-text">Disponible</span>
                </div>
                <div class="image-shine"></div>
              </div>
              
              <div class="profile-meta">
                <h3 class="profile-name">{advisor.name}</h3>
                <p class="profile-title">{advisor.title}</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats Card -->
      <div class="bento-item bento-stats" data-tilt>
        <div class="glass-card">
          <div class="card-shine"></div>
          <div class="stats-grid">

            
            <div class="stat-box">
              <div class="stat-icon icon-clients">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              </div>
              <div class="stat-data">
                <span class="stat-number"><Counter endValue={advisor.clients} suffix="+" /></span>
                <span class="stat-label">Clientes<br/>satisfechos</span>
              </div>
            </div>
            
            <div class="stat-divider horizontal"></div>
            
            <div class="stat-box">
              <div class="stat-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div class="stat-data">
                <span class="stat-number"><Counter endValue={24} suffix="h" /></span>
                <span class="stat-label">Respuesta<br/>garantizada</span>
              </div>
            </div>
            
            <div class="stat-divider horizontal"></div>
            
            <div class="stat-box stat-highlight">
              <div class="stat-icon icon-savings">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="1" x2="12" y2="23"/>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
              </div>
              <div class="stat-data">
                <span class="stat-number accent"><Counter endValue={averageYearly} suffix="€" /></span>
                <span class="stat-label">Ahorro medio<br/>anual</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bio Card -->
      <div class="bento-item bento-bio" data-tilt>
        <div class="glass-card">
          <div class="card-shine"></div>
          <div class="bio-content">
            <div class="bio-header">
              <div class="bio-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                </svg>
              </div>
              <h4 class="bio-title">Mi compromiso</h4>
            </div>
            
            <div class="bio-text">
              <p class="bio-lead">
                Ayudo a familias y negocios a pagar menos por su electricidad. 
                <span class="highlight-text">Sin complicaciones.</span>
              </p>
              <p class="bio-body">
                Analizo tu consumo real, comparo todas las comercializadoras del mercado 
                y encuentro la tarifa que mejor se adapta a ti.
              </p>
            </div>

            <div class="bio-features">
              <div class="feature-item">
                <div class="feature-check">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <span>Sin permanencia</span>
              </div>
              <div class="feature-item">
                <div class="feature-check">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <span>Sin costes ocultos</span>
              </div>
              <div class="feature-item">
                <div class="feature-check">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <span>100% independiente</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Card -->
      <div class="bento-item bento-cta" data-tilt>
        <div class="glass-card cta-card">
          <div class="card-shine"></div>
          <div class="cta-content">
            <div class="cta-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span>Valoración 4.9/5</span>
            </div>
            
            <h4 class="cta-title">¿Empezamos a ahorrar?</h4>
            <p class="cta-desc">Análisis gratuito en menos de 24h</p>
            
            <a href={siteConfig.whatsappUrl} class="cta-button" rel="noopener noreferrer">
              <span class="btn-bg"></span>
              <span class="btn-shine"></span>
              <MessageCircle size={20} fill="currentColor" />
              <span class="btn-text">Habla conmigo</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Bar -->
    <div class="trust-bar reveal-up">
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <span>Datos protegidos</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9 12l2 2 4-4"/>
          </svg>
        </div>
        <span>Sin permanencia</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <div class="trust-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v20M2 12h20"/>
          </svg>
        </div>
        <span>Sin costes</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── CSS Custom Properties for Animation ─────────────────────── */
  :root {
    --mouse-x: 0.5;
    --mouse-y: 0.5;
  }

  /* ─── Section Foundation ──────────────────────────────────────── */
  .about {
    position: relative;
    min-height: 100svh;
    padding: 120px 0 100px;
    overflow: hidden;
    /* No background - using global background from Layout */
  }

  /* ─── Container ───────────────────────────────────────────────── */
  .container {
    position: relative;
    z-index: 1;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* ─── Section Header ──────────────────────────────────────────── */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .eyebrow-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-pill);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    margin-bottom: var(--space-6);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-ios-spring);
  }

  .eyebrow-pill::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    border-radius: var(--radius-pill) var(--radius-pill) 0 0;
    z-index: 1;
  }

  .eyebrow-dot,
  .eyebrow-text {
    position: relative;
    z-index: 2;
  }

  .eyebrow-pill:hover {
    transform: translateY(-2px) scale(1.02);
    background: rgba(255, 255, 255, 0.80);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 6px 12px rgba(0, 0, 0, 0.06),
      0 16px 48px rgba(0, 0, 0, 0.10),
      0 40px 96px rgba(0, 0, 0, 0.08);
  }

  .eyebrow-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-secondary) 0%, var(--purple-500) 100%);
    box-shadow: 0 0 0 2px rgba(88, 86, 214, 0.2);
    animation: pulseDot 2s ease-in-out infinite;
  }

  @keyframes pulseDot {
    0%, 100% { box-shadow: 0 0 0 2px rgba(88, 86, 214, 0.2); }
    50% { box-shadow: 0 0 0 4px rgba(88, 86, 214, 0.1); }
  }

  .eyebrow-text {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-secondary);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .section-title {
    margin: 0 0 var(--space-3);
  }

  .title-line {
    display: block;
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2);
    text-wrap: balance;
  }

  .title-accent {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: 800;
    letter-spacing: -0.04em;
    text-wrap: balance;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--text-secondary) 50%, var(--text-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    font-weight: 500;
    margin: 0;
  }

  /* ─── Bento Grid ──────────────────────────────────────────────── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, auto);
    gap: var(--space-5);
    margin-bottom: var(--space-12);
  }

  .bento-item {
    position: relative;
    border-radius: var(--radius-2xl);
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .bento-profile {
    grid-column: span 1;
    grid-row: span 2;
  }

  .bento-stats {
    grid-column: span 2;
  }

  .bento-bio {
    grid-column: span 1;
  }

  .bento-cta {
    grid-column: span 1;
  }

  /* ─── Multi-Layer Glass Cards ─────────────────────────────────── */
  .card-layers {
    position: relative;
    height: 100%;
  }

  .card-layer {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-2xl);
    transition: transform 0.3s ease-out;
  }

  .layer-back {
    background: linear-gradient(135deg, rgba(88, 86, 214, 0.15) 0%, rgba(88, 86, 214, 0.1) 100%);
    transform: translateY(8px) scale(0.96);
    filter: blur(20px);
    opacity: 0.6;
  }

  .layer-mid {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.3) 100%);
    backdrop-filter: blur(40px) saturate(150%);
    -webkit-backdrop-filter: blur(40px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.6);
    transform: translateY(4px) scale(0.98);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  .layer-front {
    position: relative;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.6) 100%);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow: 
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 4px 24px rgba(0, 0, 0, 0.06),
      0 16px 48px rgba(0, 0, 0, 0.04);
    overflow: hidden;
  }

  .card-highlight {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 60%;
    background: linear-gradient(180deg, 
      rgba(255, 255, 255, 0.9) 0%,
      rgba(255, 255, 255, 0.4) 40%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .card-content {
    position: relative;
    z-index: 3;
    padding: var(--space-8);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Hover depth effect - Premium */
  .bento-item:hover .layer-back {
    transform: translateY(16px) scale(0.92);
    opacity: 0.85;
    filter: blur(25px);
  }

  .bento-item:hover .layer-mid {
    transform: translateY(8px) scale(0.96);
  }

  .bento-item:hover .layer-front {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 12px 40px rgba(0, 0, 0, 0.12),
      0 32px 80px rgba(0, 0, 0, 0.08);
  }

  .bento-item:hover .card-highlight {
    opacity: 0.95;
  }

  .bento-item:hover .card-content {
    transform: translateZ(20px);
  }

  /* Smooth transition for card content */
  .card-content {
    transition: transform 0.5s var(--ease-ios-spring);
  }

  /* ─── Profile Content ─────────────────────────────────────────── */
  .profile-layers {
    height: 100%;
    min-height: 520px;
  }

  .profile-content {
    padding: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .profile-image-full {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  }

  .image-frame {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bento-item:hover .profile-image {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 50%,
      rgba(0, 0, 0, 0.02) 70%,
      rgba(0, 0, 0, 0.08) 100%
    );
    pointer-events: none;
  }

  .image-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    animation: imageShine 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes imageShine {
    0%, 100% { left: -100%; }
    50% { left: 150%; }
  }

  .availability-badge {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: var(--space-2) 14px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px) saturate(180%);
    border-radius: var(--radius-pill);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.9);
    z-index: 10;
  }

  .badge-pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    position: relative;
  }

  .badge-pulse::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(52, 199, 89, 0.3);
    animation: pulseRing 2s ease-out infinite;
  }

  @keyframes pulseRing {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  .badge-text {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--green-700);
  }

  .profile-meta {
    text-align: center;
    padding: var(--space-6) 28px;
    background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0.9) 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(10px);
  }

  .profile-name {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 4px;
    letter-spacing: -0.02em;
  }

  .profile-title {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
    margin: 0;
  }

  /* ─── Glass Card Component ────────────────────────────────────── */
  .glass-card {
    position: relative;
    height: 100%;
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-2xl);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .card-shine {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 55%;
    background: linear-gradient(180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .glass-card:hover {
    transform: translateY(-6px) scale(1.03);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 8px 12px rgba(0, 0, 0, 0.05),
      0 20px 60px rgba(0, 0, 0, 0.12),
      0 48px 100px rgba(0, 0, 0, 0.10);
  }

  .glass-card:hover .card-shine {
    background: linear-gradient(180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.45) 35%,
      rgba(255, 255, 255, 0.10) 65%,
      transparent 100%
    );
  }

  /* ─── Stats Grid ──────────────────────────────────────────────── */
  .stats-grid {
    position: relative;
    z-index: 2;
    height: 100%;
    padding: 28px;
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .stat-box {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .stat-icon {
    width: 48px; height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(88, 86, 214, 0.15) 0%, rgba(88, 86, 214, 0.1) 100%);
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  .stat-icon.icon-clients {
    background: linear-gradient(135deg, rgba(0, 122, 255, 0.15) 0%, rgba(0, 98, 204, 0.1) 100%);
    color: var(--color-primary);
  }

  .stat-icon.icon-savings {
    background: linear-gradient(135deg, rgba(52, 199, 89, 0.15) 0%, rgba(36, 138, 61, 0.1) 100%);
    color: var(--color-success);
  }

  .stat-data {
    display: flex;
