---
import { siteConfig } from '../../config/site';
import { MessageCircle, Phone, ShieldCheck, Clock, ArrowRight } from 'lucide-astro';
---

<section class="final-cta-section" id="final-cta">
  <!-- Atmospheric orbs -->
  <div class="orb orb-blue-soft float-slow" style="width: 420px; height: 420px; top: -10%; left: -8%; opacity: 0.30;" aria-hidden="true"></div>
  <div class="orb orb-cyan-soft float-breathe" style="width: 300px; height: 300px; bottom: -5%; right: -6%; opacity: 0.24;" aria-hidden="true"></div>

  <div class="container-custom">
    <div class="cta-card reveal">
      <!-- Liquid Glass layers -->
      <div class="card-specular" aria-hidden="true"></div>
      <div class="card-glow" aria-hidden="true"></div>

      <!-- Copy -->
      <div class="cta-copy">
        <span class="cta-kicker">
          <span class="kicker-dot" aria-hidden="true"></span>
          Estudio gratuito
        </span>
        <h2 class="cta-headline">
          <span class="headline-solid">Reviso tu factura.</span>
          <span class="headline-accent">Sin compromiso.</span>
        </h2>
        <p class="cta-body">Envíamela y reviso si hay margen de mejora.</p>
      </div>

      <!-- Actions -->
      <div class="cta-actions">
        <a
          href={siteConfig.whatsappUrl}
          class="btn-primary"
          rel="noopener noreferrer"
        >
          <span class="btn-shimmer" aria-hidden="true"></span>
          <span class="btn-inner">
            <MessageCircle size={18} fill="currentColor" aria-hidden="true" />
            <span>Solicitar revisión</span>
          </span>
        </a>

        <a href={`tel:${siteConfig.phoneClean}`} class="btn-secondary">
          <span class="btn-inner">
            <Phone size={17} aria-hidden="true" />
            <span>{siteConfig.phone}</span>
          </span>
        </a>

        <!-- Trust pills under buttons -->
        <div class="trust-pills">
          <span class="trust-pill">
            <ShieldCheck size={13} aria-hidden="true" />
            Solo con tu autorización
          </span>
          <span class="trust-pill">
            <Clock size={13} aria-hidden="true" />
            Respuesta en 24 h
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    position: relative;
    padding: clamp(80px, 10vw, 140px) 0 clamp(64px, 8vw, 120px);
    overflow: hidden;
    isolation: isolate;
  }

  /* ─── Card ──────────────────────────────────────────────────── */
  .cta-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) auto;
    align-items: center;
    gap: clamp(32px, 5vw, 64px);
    padding: clamp(32px, 5vw, 52px);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    transition: transform 0.5s var(--ease-ios-spring), box-shadow 0.4s var(--ease-ios);
  }

  .cta-card:hover {
    transform: translateY(-4px) scale(1.003);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 6px 10px rgba(0, 0, 0, 0.05),
      0 16px 48px rgba(0, 0, 0, 0.10),
      0 36px 84px rgba(0, 0, 0, 0.07);
  }

  /* Specular highlight — separate DOM element per Hero reference */
  .card-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 50%;
    pointer-events: none;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    border-radius: 22px 22px 0 0;
  }

  /* Ambient glow orb inside card */
  .card-glow {
    position: absolute;
    width: 420px;
    height: 220px;
    right: -90px;
    top: -80px;
    z-index: 0;
    border-radius: 999px;
    background:
      radial-gradient(ellipse at center, rgba(0, 122, 255, 0.14), transparent 66%),
      radial-gradient(ellipse at 80% 70%, rgba(52, 199, 89, 0.08), transparent 58%);
    filter: blur(46px);
    opacity: 0.8;
    pointer-events: none;
  }

  .cta-copy,
  .cta-actions {
    position: relative;
    z-index: 2;
  }

  /* ─── Copy ──────────────────────────────────────────────────── */
  .cta-copy {
    max-width: 520px;
  }

  .cta-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: var(--space-3);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }

  .kicker-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.18);
    animation: kicker-pulse 2.5s ease-in-out infinite;
  }

  @keyframes kicker-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  .cta-headline {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 3.4rem);
    font-weight: var(--font-extrabold);
    line-height: 1.02;
    letter-spacing: -0.048em;
  }

  .headline-solid {
    display: block;
    color: var(--text-primary);
  }

  .headline-accent {
    display: block;
    background: linear-gradient(135deg, var(--ios-blue) 0%, #5AC8FA 55%, #34AADC 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-body {
    max-width: 380px;
    margin: var(--space-3) 0 0;
    color: var(--text-secondary);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.55;
  }

  /* ─── Actions ───────────────────────────────────────────────── */
  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-4);
    min-width: 280px;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    width: 100%;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    text-decoration: none;
    transition: transform 0.35s var(--ease-ios-spring), box-shadow 0.35s var(--ease-ios), background 0.35s var(--ease-ios), color 0.35s var(--ease-ios);
    touch-action: manipulation;
  }

  .btn-primary {
    position: relative;
    overflow: hidden;
    padding: 0 32px;
    color: white;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 52%, var(--color-primary) 100%);
    background-size: 200% 100%;
    box-shadow: 0 8px 24px rgba(0, 122, 255, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.25);
    animation: gradient-shift 5s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .btn-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.22) 50%, transparent 100%);
    transform: translateX(-110%);
    animation: shimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes shimmer {
    0%, 55%, 100% { transform: translateX(-110%); }
    75% { transform: translateX(110%); }
  }

  .btn-inner {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }

  .btn-primary:hover {
    transform: translateY(-3px) scale(1.018);
    box-shadow: 0 14px 36px rgba(0, 122, 255, 0.34), inset 0 1px 0 rgba(255, 255, 255, 0.32);
  }

  .btn-primary:active {
    transform: translateY(-1px) scale(0.98);
  }

  .btn-secondary {
    gap: 8px;
    padding: 0 28px;
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.56);
    border: 1px solid rgba(255, 255, 255, 0.68);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.80), 0 2px 10px rgba(0, 0, 0, 0.04);
  }

  .btn-secondary:hover {
    color: var(--color-primary);
    background: rgba(236, 246, 255, 0.72);
    transform: translateY(-2px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.90), 0 6px 18px rgba(0, 0, 0, 0.06);
  }

  /* Trust pills under buttons */
  .trust-pills {
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .trust-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.50);
    border: 1px solid rgba(255, 255, 255, 0.60);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.70);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    white-space: nowrap;
    transition: all 0.25s var(--ease-ios);
  }

  .trust-pill:hover {
    background: rgba(255, 255, 255, 0.70);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .trust-pill svg {
    color: var(--color-success);
    flex-shrink: 0;
  }

  /* ─── Responsive ────────────────────────────────────────────── */
  @media (max-width: 920px) {
    .cta-card {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-8);
    }

    .cta-copy {
      margin: 0 auto;
    }

    .cta-headline,
    .cta-body {
      margin-left: auto;
      margin-right: auto;
    }

    .cta-actions {
      align-items: center;
      min-width: 0;
      width: 100%;
      max-width: 360px;
      margin: 0 auto;
    }

    .trust-pills {
      justify-content: center;
    }
  }

  @media (max-width: 560px) {
    .final-cta-section {
      padding: var(--space-20) 0 var(--space-16);
    }

    .cta-card {
      padding: var(--space-7) var(--space-5);
      border-radius: 20px;
    }

    .card-specular {
      border-radius: 20px 20px 0 0;
    }

    .cta-headline {
      font-size: clamp(1.8rem, 8vw, 2.6rem);
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }

    .trust-pill {
      white-space: normal;
      justify-content: center;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .final-cta-section {
      padding: var(--space-16) 0 var(--space-12);
    }

    .cta-card {
      padding: var(--space-8) var(--space-6);
      gap: var(--space-8);
    }

    .cta-headline {
      font-size: clamp(1.65rem, 7.5vw, 2.2rem);
    }

    .cta-body {
      font-size: var(--text-base);
    }

    .cta-actions {
      gap: var(--space-5);
    }

    .trust-pills {
      gap: 8px;
      margin-top: var(--space-3);
    }

    .trust-pill {
      font-size: var(--text-xs);
      padding: 8px 14px;
    }
  }

  @media (max-width: 360px) {
    .cta-card {
      padding: var(--space-7) var(--space-5);
      gap: var(--space-6);
    }

    .cta-headline {
      font-size: 1.5rem;
    }

    .cta-actions {
      gap: var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kicker-dot,
    .btn-shimmer,
    .btn-primary {
      animation: none !important;
    }

    .btn-primary,
    .btn-secondary,
    .cta-card {
      transition: none !important;
    }

    .btn-primary:hover,
    .btn-secondary:hover,
    .cta-card:hover {
      transform: none !important;
    }
  }
</style>
