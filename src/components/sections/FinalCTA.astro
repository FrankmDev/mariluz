---
import { siteConfig } from '../../config/site';
import { MessageCircle, Phone, ShieldCheck } from 'lucide-astro';
---

<section class="final-cta-section" id="final-cta">
  <div class="container-custom">
    <div class="cta-card reveal">
      <div class="card-specular" aria-hidden="true"></div>
      <div class="card-glow" aria-hidden="true"></div>

      <div class="cta-copy">
        <span class="cta-kicker">Revisión inicial sin compromiso</span>
        <h2>¿Quieres saber si tu factura puede mejorar?</h2>
        <p>Envíamela y te explico qué estás pagando, qué conviene revisar y si merece la pena cambiar.</p>
      </div>

      <div class="cta-side">
        <div class="cta-actions" aria-label="Opciones de contacto">
          <a href={siteConfig.whatsappUrl} class="btn-primary-cta" rel="noopener noreferrer">
            <span class="btn-shimmer" aria-hidden="true"></span>
            <span class="btn-content">
              <MessageCircle size={18} fill="currentColor" aria-hidden="true" />
              Enviar factura
            </span>
          </a>

          <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="btn-secondary-cta">
            <Phone size={17} aria-hidden="true" />
            {siteConfig.phone}
          </a>
        </div>

        <div class="trust-row">
          <span>
            <ShieldCheck size={14} aria-hidden="true" />
            Sin cambios sin autorización
          </span>
          <span>Respuesta habitual en 24 h</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    position: relative;
    padding: clamp(72px, 9vw, 116px) 0;
    overflow: hidden;
  }

  .cta-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(28px, 5vw, 64px);
    padding: clamp(28px, 5vw, 52px);
    border-radius: var(--radius-2xl);
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(44px) saturate(220%) brightness(1.04);
    -webkit-backdrop-filter: blur(44px) saturate(220%) brightness(1.04);
    border: 1px solid rgba(255, 255, 255, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.98),
      inset 0 -1px 0 rgba(0,0,0,0.025),
      0 4px 6px rgba(0,0,0,0.04),
      0 14px 44px rgba(0,0,0,0.085),
      0 32px 80px rgba(0,0,0,0.055);
  }

  .card-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 55%;
    pointer-events: none;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.90) 0%,
      rgba(255,255,255,0.42) 36%,
      rgba(255,255,255,0.08) 68%,
      transparent 100%
    );
  }

  .card-glow {
    position: absolute;
    width: 420px;
    height: 220px;
    right: -90px;
    top: -80px;
    z-index: 0;
    border-radius: 999px;
    background:
      radial-gradient(ellipse at center, rgba(0,122,255,0.18), transparent 66%),
      radial-gradient(ellipse at 80% 70%, rgba(52,199,89,0.12), transparent 58%);
    filter: blur(46px);
    opacity: 0.82;
    pointer-events: none;
  }

  .cta-copy,
  .cta-side {
    position: relative;
    z-index: 2;
  }

  .cta-copy {
    max-width: 700px;
  }

  .cta-kicker {
    display: inline-flex;
    margin-bottom: var(--space-4);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    letter-spacing: 0.055em;
    text-transform: uppercase;
  }

  .cta-copy h2 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.4vw, 4rem);
    font-weight: var(--font-extrabold);
    line-height: 1.03;
    letter-spacing: -0.052em;
    max-width: 12.5ch;
  }

  .cta-copy p {
    max-width: 560px;
    margin: var(--space-5) 0 0;
    color: var(--text-secondary);
    font-size: clamp(1rem, 1.25vw, 1.15rem);
    line-height: 1.62;
  }

  .cta-side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-4);
    min-width: 290px;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .btn-primary-cta,
  .btn-secondary-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    text-decoration: none;
    transition: transform 0.35s var(--ease-ios-spring), box-shadow 0.35s var(--ease-ios), background 0.35s var(--ease-ios), color 0.35s var(--ease-ios);
    touch-action: manipulation;
  }

  .btn-primary-cta {
    position: relative;
    overflow: hidden;
    padding: 0 26px;
    color: white;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 52%, var(--color-primary) 100%);
    background-size: 200% 100%;
    box-shadow: 0 8px 24px rgba(0,122,255,0.28), inset 0 1px 0 rgba(255,255,255,0.25);
  }

  .btn-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.22) 50%, transparent 100%);
    transform: translateX(-110%);
    animation: shimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes shimmer {
    0%, 55%, 100% { transform: translateX(-110%); }
    75% { transform: translateX(110%); }
  }

  .btn-content {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }

  .btn-primary-cta:hover {
    transform: translateY(-3px) scale(1.018);
    box-shadow: 0 14px 36px rgba(0,122,255,0.34), inset 0 1px 0 rgba(255,255,255,0.32);
  }

  .btn-secondary-cta {
    gap: 8px;
    padding: 0 22px;
    color: var(--text-primary);
    background: rgba(255,255,255,0.56);
    border: 1px solid rgba(255,255,255,0.68);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.80), 0 2px 10px rgba(0,0,0,0.04);
  }

  .btn-secondary-cta:hover {
    color: var(--color-primary);
    background: rgba(236,246,255,0.72);
    transform: translateY(-2px);
  }

  .trust-row {
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .trust-row span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: var(--radius-pill);
    color: var(--text-secondary);
    background: rgba(255,255,255,0.50);
    border: 1px solid rgba(255,255,255,0.60);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    white-space: nowrap;
  }

  .trust-row svg {
    color: var(--color-success);
    flex-shrink: 0;
  }

  @media (max-width: 920px) {
    .cta-card {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .cta-copy {
      margin: 0 auto;
    }

    .cta-copy h2,
    .cta-copy p {
      margin-left: auto;
      margin-right: auto;
    }

    .cta-side {
      align-items: center;
      min-width: 0;
    }

    .cta-actions,
    .trust-row {
      justify-content: center;
    }
  }

  @media (max-width: 560px) {
    .final-cta-section {
      padding: var(--space-20) 0;
    }

    .cta-card {
      padding: var(--space-7) var(--space-5);
    }

    .cta-copy h2 {
      max-width: 11ch;
    }

    .cta-actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .btn-primary-cta,
    .btn-secondary-cta {
      width: 100%;
    }

    .trust-row span {
      white-space: normal;
      justify-content: center;
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-shimmer {
      animation: none !important;
    }

    .btn-primary-cta,
    .btn-secondary-cta {
      transition: none !important;
    }

    .btn-primary-cta:hover,
    .btn-secondary-cta:hover {
      transform: none !important;
    }
  }
</style>
