---
import { siteConfig } from '../../config/site';
import { MessageCircle } from 'lucide-astro';
---

<section class="final-cta-section" id="final-cta">
  <div class="container-custom cta-container">
    <div class="cta-content reveal">

      <!-- Two Column Layout -->
      <div class="cta-grid">
        
        <!-- Left: Visual Element -->
        <div class="cta-visual">
          <div class="visual-card">
            <div class="visual-specular"></div>
            <div class="visual-content">
              <!-- Savings Preview -->
              <div class="savings-preview">
                <div class="savings-header">
                  <span class="savings-label">Ahorro estimado</span>
                  <span class="savings-badge">Anual</span>
                </div>
                <div class="savings-amount">
                  <span class="savings-currency">€</span>
                  <span class="savings-number" id="savings-counter">0</span>
                </div>
                <div class="savings-chart">
                  <div class="chart-bar" style="--height: 40%"></div>
                  <div class="chart-bar" style="--height: 55%"></div>
                  <div class="chart-bar" style="--height: 45%"></div>
                  <div class="chart-bar active" style="--height: 85%"></div>
                  <div class="chart-bar" style="--height: 70%"></div>
                </div>
              </div>
              
              <!-- Client Counter -->
              <div class="client-counter">
                <div class="counter-avatars">
                  <div class="avatar avatar-1"></div>
                  <div class="avatar avatar-2"></div>
                  <div class="avatar avatar-3"></div>
                  <div class="avatar avatar-more">+</div>
                </div>
                <div class="counter-text">
                  <strong>450+</strong> clientes ya ahorran
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Main CTA Content -->
        <div class="cta-main">
          
          <!-- Content Stack -->
          <div class="content-stack">
            
            <!-- Top: Status & Label -->
            <div class="content-header">
              <div class="status-pill">
                <span class="status-dot"></span>
                <span>Asesoría disponible</span>
              </div>
              <p class="availability-note">Respuesta en menos de 24h</p>
            </div>

            <!-- Middle: Headline with decorative elements -->
            <div class="headline-wrap">
              <span class="headline-eyebrow">¿Listo para el cambio?</span>
              <h2 class="cta-headline">
                <span class="headline-line">Paga menos</span>
                <span class="headline-accent">en tu factura.</span>
              </h2>
              <p class="headline-sub">
                Análisis gratuito. Sin compromiso. Resultados reales.
              </p>
            </div>

            <!-- Bottom: CTAs -->
            <div class="cta-actions">
              <a href={siteConfig.whatsappUrl} class="btn-primary-cta">
                <span class="btn-shimmer"></span>
                <span class="btn-content">
                  <MessageCircle size={18} fill="currentColor" />
                  WhatsApp
                </span>
              </a>

              <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="btn-secondary-cta">
                {siteConfig.phone}
              </a>
            </div>

            <!-- Trust Indicators -->
            <div class="trust-indicators">
              <div class="trust-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>Sin compromiso</span>
              </div>
              <div class="trust-item">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>100% gratuito</span>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ========== Section Base ========== */
  .final-cta-section {
    position: relative;
    padding: var(--section-py) 0;
    overflow: hidden;
    /* No background - using global background from Layout */
  }

  /* ========== Container ========== */
  .cta-container {
    position: relative;
    z-index: 1;
  }

  .cta-content {
    display: flex;
    justify-content: center;
  }

  /* ========== Two Column Grid ========== */
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-20);
    align-items: center;
    max-width: 1100px;
    width: 100%;
  }

  /* ========== Visual Card (Left) ========== */
  .cta-visual {
    display: flex;
    justify-content: center;
  }

  .visual-card {
    position: relative;
    width: 100%;
    max-width: 340px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(44px) saturate(220%) brightness(1.04);
    -webkit-backdrop-filter: blur(44px) saturate(220%) brightness(1.04);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-2xl);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    transform: rotate(-3deg);
    transition: all 0.5s var(--ease-ios-spring);
  }

  .visual-card:hover {
    transform: rotate(0deg) translateY(-10px) scale(1.02);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 8px 24px rgba(0, 0, 0, 0.08),
      0 24px 64px rgba(0, 0, 0, 0.12),
      0 48px 120px rgba(0, 0, 0, 0.1);
  }

  .visual-card:hover .savings-number {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 50%, var(--color-primary) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 3s ease infinite;
  }

  .visual-card:hover .chart-bar.active {
    filter: brightness(1.1);
  }

  .visual-specular {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.45) 35%,
      rgba(255, 255, 255, 0.12) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .visual-content {
    position: relative;
    z-index: 2;
    padding: var(--space-8);
  }

  /* Savings Preview */
  .savings-preview {
    margin-bottom: var(--space-6);
  }

  .savings-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }

  .savings-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-secondary);
  }

  .savings-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(0, 122, 255, 0.1);
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .savings-amount {
    display: flex;
    align-items: flex-start;
    gap: 4px;
    margin-bottom: var(--space-5);
  }

  .savings-currency {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-top: 4px;
  }

  .savings-number {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .savings-chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 60px;
  }

  .chart-bar {
    flex: 1;
    height: var(--height);
    background: rgba(0, 122, 255, 0.15);
    border-radius: 4px 4px 0 0;
    transition: all 0.4s var(--ease-ios-spring);
  }

  .chart-bar.active {
    background: linear-gradient(180deg, var(--color-primary) 0%, var(--cyan-400) 100%);
  }

  .visual-card:hover .chart-bar {
    opacity: 0.5;
  }

  .visual-card:hover .chart-bar.active {
    opacity: 1;
  }

  /* Client Counter */
  .client-counter {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-5);
    border-top: 1px solid var(--separator);
  }

  .counter-avatars {
    display: flex;
  }

  .avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid white;
    margin-left: -8px;
    background-size: cover;
    background-position: center;
  }

  .avatar:first-child {
    margin-left: 0;
  }

  .avatar-1 { background-image: url('https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face'); }
  .avatar-2 { background-image: url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face'); }
  .avatar-3 { background-image: url('https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop&crop=face'); }

  .avatar-more {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .counter-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .counter-text strong {
    color: var(--text-primary);
    font-weight: 700;
  }

  /* ========== Main Content (Right) ========== */
  .cta-main {
    text-align: left;
  }

  .content-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Content Header */
  .content-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    border-radius: 100px;
    box-shadow: 
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: var(--color-success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.2); }
  }

  .availability-note {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin: 0;
  }

  /* Headline Wrap */
  .headline-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .headline-eyebrow {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cta-headline {
    margin: 0;
  }

  .headline-line {
    display: block;
    font-size: var(--text-section);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.055em;
    color: var(--text-primary);
  }

  .headline-accent {
    display: block;
    font-size: var(--text-section);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.055em;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 55%, var(--cyan-500) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .headline-sub {
    font-size: var(--text-xl);
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 8px 0 0;
    max-width: 400px;
  }

  /* CTAs - Smaller buttons */
  .cta-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: 8px;
  }

  .btn-primary-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: var(--space-3) var(--space-6);
    background: var(--color-primary);
    border: none;
    border-radius: 100px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: -0.01em;
    color: white;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.35s var(--ease-ios-spring);
    box-shadow: 
      0 3px 10px rgba(0, 122, 255, 0.3),
      0 6px 20px rgba(0, 122, 255, 0.2);
  }

  .btn-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.3) 50%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: shimmer 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes shimmer {
    0%, 100% { background-position: 200% 0; }
    50% { background-position: -200% 0; }
  }

  .btn-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .btn-primary-cta:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 
      0 8px 24px rgba(0, 122, 255, 0.45),
      0 16px 40px rgba(0, 122, 255, 0.3);
    letter-spacing: 0.01em;
  }

  .btn-primary-cta:active {
    transform: translateY(-1px) scale(0.98);
    box-shadow: 
      0 4px 12px rgba(0, 122, 255, 0.35);
  }

  .btn-secondary-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 100px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-base);
    letter-spacing: -0.01em;
    color: var(--text-primary);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.35s var(--ease-ios-spring);
  }

  .btn-secondary-cta:hover {
    background: rgba(0, 122, 255, 0.08);
    border-color: rgba(0, 122, 255, 0.15);
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  /* Trust Indicators */
  .trust-indicators {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-tertiary);
  }

  .trust-item svg {
    stroke: var(--color-success);
    flex-shrink: 0;
  }

  /* ========== Responsive ========== */
  @media (max-width: 900px) {
    .cta-grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
      text-align: center;
    }

    .cta-main {
      text-align: center;
    }

    .content-stack {
      align-items: center;
    }

    .content-header {
      flex-direction: column;
      gap: 8px;
    }

    .headline-sub {
      margin-left: auto;
      margin-right: auto;
    }

    .cta-actions {
      justify-content: center;
    }

    .trust-indicators {
      justify-content: center;
    }

    .visual-card {
      max-width: 300px;
      transform: rotate(0deg);
    }
  }

  @media (max-width: 640px) {
    .final-cta-section {
      padding: 100px 0;
    }

    .headline-line,
    .headline-accent {
      font-size: 2rem;
    }

    .btn-primary-cta,
    .btn-secondary-cta {
      width: auto;
      min-width: 140px;
    }

    .savings-number {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .final-cta-section {
      padding: var(--space-20) 0;
    }

    .headline-line,
    .headline-accent {
      font-size: 1.75rem;
    }

    .headline-eyebrow {
      font-size: var(--text-sm);
    }

    .headline-sub {
      font-size: var(--text-md);
    }

    .visual-content {
      padding: var(--space-6);
    }

    .savings-number {
      font-size: 2rem;
    }

    .cta-actions {
      flex-direction: row;
      width: 100%;
    }

    .btn-primary-cta,
    .btn-secondary-cta {
      flex: 1;
      min-width: 0;
      padding: var(--space-3) var(--space-4);
      font-size: var(--text-sm);
    }

    .trust-indicators {
      flex-wrap: wrap;
      gap: var(--space-3);
    }
  }
</style>

<script>
  // Animate savings counter
  const counter = document.getElementById('savings-counter');
  if (counter) {
    const target = 324;
    const duration = 2000;
    const start = performance.now();
    
    function updateCounter(currentTime: number) {
      const elapsed = currentTime - start;
      const progress = Math.min(elapsed / duration, 1);
      const easeOut = 1 - Math.pow(1 - progress, 3);
      const current = Math.floor(easeOut * target);
      counter.textContent = current.toLocaleString();
      
      if (progress < 1) {
        requestAnimationFrame(updateCounter);
      }
    }
    
    // Start animation when element is visible
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          requestAnimationFrame(updateCounter);
          observer.disconnect();
        }
      });
    }, { threshold: 0.5 });
    
    observer.observe(counter);
  }
</script>
