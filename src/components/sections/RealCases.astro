---
import { siteConfig } from '../../config/site';
import { MessageCircle, TrendingDown, FileText, CheckCircle } from 'lucide-astro';

const caseStudies = [
  {
    clientType: 'Piso en Madrid',
    problem: 'Factura de 118€/mes con potencia mal ajustada',
    diagnosis: 'Potencia contratada excesiva y tarifa sin discriminación horaria',
    result: 'Reducción de potencia + cambio a tarifa adaptada',
    beforeMonthly: 118,
    afterMonthly: 96,
    yearlySaving: 264,
  },
  {
    clientType: 'Casa en Córdoba',
    problem: '126€/mes sin revisar en años',
    diagnosis: 'En tarifa antigua con precios desactualizados',
    result: 'Migración a tarifa indexada con precio de mercado',
    beforeMonthly: 126,
    afterMonthly: 105,
    yearlySaving: 252,
  },
];
---

<section id="casos-reales" class="cases-section" aria-label="Casos reales de optimización">
  <div class="container-custom">

    <!-- Section Header -->
    <header class="section-header reveal">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>Casos reales</span>
      </div>
      <h2 class="headline">
        <span class="headline-main">Ejemplos de revisiones.</span>
        <span class="headline-sub">Facturas reales, explicadas.</span>
      </h2>
    </header>

    <!-- Case Cards -->
    <div class="cases-grid">
      {caseStudies.map((study, index) => (
        <article class="case-card reveal" style={`transition-delay: ${index * 150}ms`}>
          <!-- Glass Base -->
          <div class="glass-base"></div>
          <div class="card-specular"></div>

          <!-- Content -->
          <div class="card-content">
            <!-- Header -->
            <div class="case-header">
              <div class="client-badge">
                <FileText size={14} aria-hidden="true" />
                <span>{study.clientType}</span>
              </div>
              <div class="saving-badge">
                <TrendingDown size={14} aria-hidden="true" />
                <span>-{Math.round(((study.beforeMonthly - study.afterMonthly) / study.beforeMonthly) * 100)}%</span>
              </div>
            </div>

            <!-- Before / After Visual -->
            <div class="bill-comparison">
              <div class="bill-block bill-before">
                <span class="bill-label">Factura mensual</span>
                <div class="bill-amount">
                  <span class="currency">€</span>
                  <span class="number">{study.beforeMonthly}</span>
                </div>
                <div class="bill-bar">
                  <div class="bar-fill" style={`width: 100%`}></div>
                </div>
              </div>

              <div class="bill-arrow" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>

              <div class="bill-block bill-after">
                <span class="bill-label">Factura optimizada</span>
                <div class="bill-amount">
                  <span class="currency">€</span>
                  <span class="number">{study.afterMonthly}</span>
                </div>
                <div class="bill-bar">
                  <div class="bar-fill bar-fill-new" style={`width: ${(study.afterMonthly / study.beforeMonthly) * 100}%`}></div>
                </div>
              </div>
            </div>

            <!-- Diagnosis -->
            <div class="diagnosis-block">
              <div class="diagnosis-title">
                <CheckCircle size={14} aria-hidden="true" />
                <span>Qué se detectó</span>
              </div>
              <p class="diagnosis-text">{study.diagnosis}</p>
              <p class="diagnosis-result">{study.result}</p>
            </div>

            <!-- Yearly Saving -->
            <div class="yearly-saving">
              <span class="saving-label">Diferencia estimada al año</span>
              <span class="saving-value">~{study.yearlySaving}€</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="cases-cta reveal">
      <p class="cta-text">Cada factura es distinta. La tuya también lo es.</p>
      <a href={siteConfig.whatsappUrl} class="cta-link" rel="noopener noreferrer">
        <MessageCircle size={16} fill="currentColor" aria-hidden="true" />
        <span>Enviar mi factura para revisar</span>
      </a>
    </div>

  </div>
</section>

<style>
  .cases-section {
    position: relative;
    padding: var(--space-32) 0 var(--space-24);
    overflow: hidden;
  }

  /* Header */
  .section-header {
    position: relative;
    z-index: 10;
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-6);
    background: rgba(255,255,255,0.68);
    backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.65);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.92), 0 2px 8px rgba(0,0,0,0.04);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
  }

  .eyebrow-dot {
    width: var(--space-2);
    height: var(--space-2);
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ios-blue) 0%, #5AC8FA 100%);
    box-shadow: 0 0 0 0 rgba(0,122,255,0.4);
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,122,255,0.4); }
    50% { box-shadow: 0 0 0 var(--space-2) rgba(0,122,255,0); }
  }

  .headline { margin: 0; }

  .headline-main {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: var(--font-extrabold);
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .headline-sub {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section-sub);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-normal);
    line-height: var(--leading-snug);
    color: var(--text-tertiary);
  }

  /* Cases Grid */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto var(--space-16);
    position: relative;
    z-index: 10;
  }

  @media (max-width: 768px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Case Card */
  .case-card {
    position: relative;
    border-radius: 22px;
    padding: var(--space-8);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1), box-shadow 0.4s ease;
    will-change: transform;
  }

  .glass-base {
    position: absolute;
    inset: 0;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.58);
    box-shadow: var(--shadow-glass);
    transform: translateZ(0);
  }

  .card-specular {
    position: absolute;
    top: 1px;
    left: 1px;
    right: 1px;
    height: 55%;
    border-radius: 21px 21px 0 0;
    background: linear-gradient(180deg,
      rgba(255,255,255,0.92) 0%,
      rgba(255,255,255,0.50) 35%,
      rgba(255,255,255,0.10) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
    opacity: 0.9;
  }

  .card-content {
    position: relative;
    z-index: 10;
  }

  .case-card:hover {
    transform: translateY(-6px) scale(1.01);
  }

  .case-card:hover .glass-base {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 8px 12px rgba(0, 0, 0, 0.05),
      0 20px 60px rgba(0, 0, 0, 0.12),
      0 48px 100px rgba(0, 0, 0, 0.10);
  }

  /* Case Header */
  .case-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }

  .client-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: rgba(0,122,255,0.08);
    border: 1px solid rgba(0,122,255,0.12);
    color: var(--ios-blue);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
  }

  .saving-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: rgba(52,199,89,0.08);
    border: 1px solid rgba(52,199,89,0.12);
    color: var(--ios-green);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
  }

  /* Bill Comparison */
  .bill-comparison {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    padding: var(--space-5);
    background: rgba(0,0,0,0.02);
    border-radius: 16px;
    border: 1px solid rgba(0,0,0,0.04);
  }

  .bill-block {
    flex: 1;
  }

  .bill-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-quaternary);
    margin-bottom: var(--space-1);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .bill-amount {
    display: flex;
    align-items: flex-start;
    gap: 1px;
    margin-bottom: var(--space-2);
  }

  .bill-before .number {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .bill-after .number {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--color-success);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .currency {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    margin-top: 2px;
    color: var(--text-tertiary);
  }

  .bill-after .currency {
    color: var(--color-success);
  }

  .bill-bar {
    height: 6px;
    background: rgba(0,0,0,0.06);
    border-radius: var(--radius-pill);
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--ios-blue), var(--cyan-400));
    border-radius: var(--radius-pill);
    transition: width 1s ease-out;
  }

  .bar-fill-new {
    background: linear-gradient(90deg, var(--color-success), var(--green-400));
  }

  .bill-arrow {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  /* Diagnosis */
  .diagnosis-block {
    padding-top: var(--space-5);
    border-top: 1px solid rgba(0,0,0,0.05);
    margin-bottom: var(--space-5);
  }

  .diagnosis-title {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .diagnosis-title svg {
    color: var(--color-success);
  }

  .diagnosis-text {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 var(--space-2);
  }

  .diagnosis-result {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    font-weight: var(--font-medium);
    margin: 0;
  }

  /* Yearly Saving */
  .yearly-saving {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background: rgba(52,199,89,0.06);
    border: 1px solid rgba(52,199,89,0.10);
    border-radius: 12px;
  }

  .saving-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: var(--font-medium);
  }

  .saving-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-success);
  }

  /* Bottom CTA */
  .cases-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-text {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    font-weight: var(--font-medium);
    margin: 0;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    font-family: var(--font-display);
    color: var(--color-primary);
    text-decoration: none;
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.58);
    box-shadow: var(--shadow-glass);
    transition: all var(--duration-normal) var(--ease-ios-spring);
    position: relative;
    overflow: hidden;
  }

  .cta-link::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    border-radius: var(--radius-pill) var(--radius-pill) 0 0;
    z-index: 1;
  }

  .cta-link > * {
    position: relative;
    z-index: 2;
  }

  .cta-link:hover {
    transform: translateY(-2px) scale(1.02);
    background: rgba(255, 255, 255, 0.85);
    color: var(--color-primary);
    box-shadow: var(--shadow-glass-hover);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .cases-section {
      padding: var(--space-24) 0 var(--space-16);
    }
    .section-header {
      margin-bottom: var(--space-12);
    }
    .headline-main {
      font-size: clamp(2rem, 8vw, 2.75rem);
    }
    .headline-sub {
      font-size: clamp(1.25rem, 4vw, 1.5rem);
    }
    .case-card {
      padding: var(--space-6);
    }
    .bill-comparison {
      padding: var(--space-4);
    }
    .bill-before .number,
    .bill-after .number {
      font-size: var(--text-2xl);
    }
  }

  @media (max-width: 480px) {
    .case-card {
      padding: var(--space-5);
      border-radius: 18px;
    }
    .glass-base {
      border-radius: 18px;
    }
    .card-specular {
      border-radius: 17px 17px 0 0;
    }
    .bill-comparison {
      flex-direction: column;
      gap: var(--space-3);
    }
    .bill-arrow {
      transform: rotate(90deg);
    }
    .bill-before .number,
    .bill-after .number {
      font-size: var(--text-xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eyebrow-dot, .bar-fill {
      animation: none !important;
    }
  }
</style>
