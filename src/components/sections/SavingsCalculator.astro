---
import { siteConfig } from '../../config/site';
import { MessageCircle } from 'lucide-astro';

// Datos de comercializadoras para la simulación
const PROVIDERS = [
  {
    id: 'current',
    name: 'Tu comercializadora actual',
    logo: '🔌',
    color: '#8E8E93',
    isCurrent: true,
    yearlyCost: 0, // Se calcula dinámicamente
  },
  {
    id: 'iberdrola',
    name: 'Iberdrola',
    logo: '⚡',
    color: '#007AFF',
    discount: 0.15,
    rating: 4.2,
    features: ['Sin permanencia', 'Factura digital', 'App móvil'],
  },
  {
    id: 'endesa',
    name: 'Endesa',
    logo: '🔋',
    color: '#FF9500',
    discount: 0.12,
    rating: 4.0,
    features: ['Tarifa online', 'Descuento 12 meses', 'Gestión online'],
  },
  {
    id: 'naturgy',
    name: 'Naturgy',
    logo: '🌿',
    color: '#34C759',
    discount: 0.18,
    rating: 4.4,
    features: ['Energía verde', 'Sin permanencia', 'Precio fijo'],
  },
  {
    id: 'repsol',
    name: 'Repsol',
    logo: '⛽',
    color: '#FF3B30',
    discount: 0.10,
    rating: 3.9,
    features: ['Puntos descuento', 'Gas+luz', 'Tarifa plana'],
  },
];
---

<section id="calculadora" class="calc-section" aria-label="Comparador de tarifas eléctricas">
  <div class="container-custom">
    
    <!-- Section Header -->
    <header class="section-header reveal">
      <div class="eyebrow">
        <span class="eyebrow-dot" aria-hidden="true"></span>
        <span>Estudio gratuito</span>
      </div>
      <h2 class="headline">
        <span class="headline-main">Sube tu factura.</span>
        <span class="headline-accent">Descubre tu ahorro real.</span>
      </h2>
      <p class="subhead">
        Analizo tu factura y te muestro cuánto podrías ahorrar con cada comercializadora. Sin compromiso.
      </p>
    </header>

    <!-- Main Calculator Area -->
    <div class="calc-layout">
      
      <!-- Left: Upload/Results Widget -->
      <div class="reveal calc-widget-col" style="transition-delay: 100ms;">
        
        <div class="calc-card" id="calculator-widget">
          <!-- Specular highlight layer -->
          <div class="card-specular" aria-hidden="true"></div>
          
          <div class="card-content" id="card-content">
            
            <!-- STATE: Upload -->
            <div class="state-upload" id="state-upload">
              <div class="upload-zone" id="upload-zone">
                <input 
                  type="file" 
                  id="file-input" 
                  class="file-input" 
                  accept=".pdf,application/pdf"
                  aria-label="Subir factura eléctrica (PDF)"
                />
                
                <div class="upload-content">
                  <div class="upload-icon-wrapper">
                    <div class="upload-icon-circle">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                        <polyline points="17 8 12 3 7 8"/>
                        <line x1="12" y1="3" x2="12" y2="15"/>
                      </svg>
                    </div>
                    <div class="upload-icon-pulse"></div>
                  </div>
                  
                  <h3 class="upload-title">Arrastra tu factura aquí</h3>
                  <p class="upload-subtitle">o haz clic para seleccionar archivo</p>
                  
                  <div class="upload-formats">
                    <span class="format-badge">Solo PDF</span>
                  </div>
                  
                  <div class="upload-divider">
                    <span>o</span>
                  </div>
                  
                  <!-- Segmented Control para modo manual -->
                  <div class="segmented-control">
                    <button class="segment-btn active" data-type="home" type="button" aria-pressed="true">
                      <span class="btn-inner">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                          <polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                        Hogar
                      </span>
                    </button>
                    <button class="segment-btn" data-type="business" type="button" aria-pressed="false">
                      <span class="btn-inner">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                          <rect x="2" y="7" width="20" height="14" rx="2"/>
                          <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
                        </svg>
                        Negocio
                      </span>
                    </button>
                  </div>
                  
                  <!-- Amount Display Manual -->
                  <div class="amount-display">
                    <p class="amount-label">Factura mensual actual</p>
                    <div class="amount-value">
                      <span id="bill-amount" class="bill-counter">120</span>
                      <span class="amount-currency">€</span>
                    </div>
                  </div>

                  <!-- Premium Slider -->
                  <div class="slider-wrapper">
                    <div class="slider-track">
                      <div id="slider-fill" class="slider-fill"></div>
                      <div class="slider-ticks">
                        <span class="tick"></span>
                        <span class="tick"></span>
                        <span class="tick"></span>
                        <span class="tick"></span>
                        <span class="tick"></span>
                      </div>
                    </div>
                    <input
                      type="range"
                      id="bill-slider"
                      min="20"
                      max="500"
                      value="120"
                      step="5"
                      class="slider-input"
                      aria-label="Factura mensual en euros"
                    />
                    <div class="slider-tooltip" id="slider-tooltip">120€</div>
                  </div>
                  
                  <div class="slider-labels">
                    <span class="slider-label">20€/mes</span>
                    <span class="slider-label">500€/mes</span>
                  </div>
                  
                  <button class="btn-analyze" id="btn-analyze-manual" type="button">
                    <span class="btn-shine" aria-hidden="true"></span>
                    <span class="btn-content">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <path d="M21 21l-4.35-4.35"/>
                      </svg>
                      Analizar mi factura
                    </span>
                  </button>
                </div>
                
                <!-- Drag overlay -->
                <div class="drag-overlay" id="drag-overlay">
                  <div class="drag-content">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                      <polyline points="17 8 12 3 7 8"/>
                      <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <p>Suelta tu factura aquí</p>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- STATE: Analyzing -->
            <div class="state-analyzing" id="state-analyzing" hidden>
              <div class="analyzing-content">
                <div class="document-icon">
                  <div class="document-page page-1"></div>
                  <div class="document-page page-2"></div>
                  <div class="document-page page-3"></div>
                  <div class="scan-line"></div>
                </div>
                
                <h3 class="analyzing-title">Analizando tu factura</h3>
                <p class="analyzing-subtitle" id="analyzing-status">Extrayendo datos de consumo...</p>
                
                <div class="progress-dots">
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <span class="dot"></span>
                </div>
                
                <div class="analysis-steps">
                  <div class="step" data-step="1">
                    <div class="step-icon">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </div>
                    <span>Leyendo factura</span>
                  </div>
                  <div class="step" data-step="2">
                    <div class="step-icon">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </div>
                    <span>Calculando consumo</span>
                  </div>
                  <div class="step" data-step="3">
                    <div class="step-icon">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </div>
                    <span>Comparando tarifas</span>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- STATE: Results -->
            <div class="state-results" id="state-results" hidden>
              <div class="results-header">
                <button class="btn-back" id="btn-back" type="button" aria-label="Volver">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                  </svg>
                </button>
                <h3 class="results-title">Comparativa de tarifas</h3>
                <div class="results-badge">
                  <span id="consumption-badge">350 kWh/mes</span>
                </div>
              </div>
              
              <p class="results-subtitle">
                Basado en tu consumo de <strong id="monthly-cost">120€/mes</strong>
              </p>
              
              <!-- Savings Highlight -->
              <div class="savings-highlight" id="savings-highlight">
                <div class="savings-highlight-specular" aria-hidden="true"></div>
                <div class="savings-highlight-content">
                  <div class="savings-highlight-text">
                    <span class="savings-label">Ahorro máximo anual</span>
                    <span class="savings-amount" id="max-savings">+256€</span>
                  </div>
                  <div class="savings-provider" id="best-provider">
                    <span>con</span>
                    <strong>Naturgy</strong>
                  </div>
                </div>
              </div>
              
              <!-- Providers List -->
              <div class="providers-list" id="providers-list">
                <!-- Se genera dinámicamente -->
              </div>
              
              <!-- CTA -->
              <a href={siteConfig.whatsappUrl} class="results-cta" rel="noopener noreferrer">
                <span class="cta-bg" aria-hidden="true"></span>
                <span class="cta-shine" aria-hidden="true"></span>
                <span class="cta-content">
                  <MessageCircle size={18} fill="currentColor" aria-hidden="true" />
                  Quiero este ahorro
                </span>
              </a>
              
              <p class="results-note">
                Estudio personalizado gratuito. Sin compromiso.
              </p>
            </div>
            
          </div>
        </div>

      </div>

      <!-- Right: Info Cards -->
      <div class="reveal calc-info-col" style="transition-delay: 200ms;">
        
        <!-- Context Block -->
        <div class="context-block">
          <h3 class="context-title">
            Por qué muchos pagan de más sin saberlo.
          </h3>
          <p class="context-text">
            El mercado eléctrico español tiene más de 300 tarifas activas. Las comercializadoras invierten millones en marketing, no en darte la mejor tarifa.
          </p>
        </div>

        <!-- Feature Cards -->
        <div class="features-list">
          
          <div class="feature-card-glass">
            <div class="card-specular" aria-hidden="true"></div>
            <div class="feature-content">
              <div class="feature-icon icon-blue">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                  <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </div>
              <div class="feature-text">
                <p class="feature-title">Comparativa real del mercado</p>
                <p class="feature-desc">Accedo a datos actualizados de todas las comercializadoras, no solo las que pagan más comisión.</p>
              </div>
            </div>
          </div>

          <div class="feature-card-glass">
            <div class="card-specular" aria-hidden="true"></div>
            <div class="feature-content">
              <div class="feature-icon icon-green">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                  <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div class="feature-text">
                <p class="feature-title">Cero coste para ti</p>
                <p class="feature-desc">Mi servicio es completamente gratuito. Cobro una comisión de la comercializadora, nunca de ti.</p>
              </div>
            </div>
          </div>

          <div class="feature-card-glass">
            <div class="card-specular" aria-hidden="true"></div>
            <div class="feature-content">
              <div class="feature-icon icon-indigo">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                  <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
              </div>
              <div class="feature-text">
                <p class="feature-title">Asesora certificada</p>
                <p class="feature-desc">8 años de experiencia auditando consumos y optimizando contratos energéticos.</p>
              </div>
            </div>
          </div>

        </div>

        <!-- Stats Row -->
        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-number" data-target="300">0</span>
            <span class="stat-label">Tarifas analizadas</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-target="74">0</span>
            <span class="stat-suffix">%</span>
            <span class="stat-label">Hogares pagando de más</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-target="24">0</span>
            <span class="stat-suffix">h</span>
            <span class="stat-label">Respuesta garantizada</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* ─── Section Base ───────────────────────────────────────────── */
  .calc-section {
    position: relative;
    padding: var(--space-24) 0 var(--space-32);
    overflow: hidden;
    /* No background - using global background from Layout */
  }

  /* ─── Section Header ─────────────────────────────────────────── */
  .section-header {
    position: relative;
    z-index: 10;
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-6);
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-ios-spring);
  }

  .eyebrow::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    border-radius: 100px 100px 0 0;
    pointer-events: none;
    z-index: 1;
  }

  .eyebrow-dot {
    position: relative;
    z-index: 2;
  }

  .eyebrow:hover {
    transform: translateY(-2px) scale(1.02);
    background: rgba(255, 255, 255, 0.80);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 6px 12px rgba(0, 0, 0, 0.06),
      0 16px 48px rgba(0, 0, 0, 0.10),
      0 40px 96px rgba(0, 0, 0, 0.08);
  }

  .eyebrow-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, #5AC8FA 100%);
    flex-shrink: 0;
    position: relative;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.5), 0 0 0 0 rgba(0,122,255,0.4);
    animation: dot-pulse 2.2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: inset 0 1px 0 rgba(255,255,255,0.5), 0 0 0 0 rgba(0,122,255,0.4); }
    50% { box-shadow: inset 0 1px 0 rgba(255,255,255,0.5), 0 0 0 8px rgba(0,122,255,0); }
  }

  .headline { margin: 0 0 var(--space-5); }

  .headline-main {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section);
    font-weight: var(--font-extrabold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .headline-accent {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-section-sub);
    font-weight: var(--font-semibold);
    letter-spacing: var(--tracking-normal);
    line-height: 1.2;
    background: linear-gradient(135deg, var(--color-primary) 0%, #5AC8FA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subhead {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 460px;
    margin: 0 auto;
  }

  /* ─── Calculator Layout ──────────────────────────────────────── */
  .calc-layout {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ─── Calculator Card ────────────────────────────────────────── */
  .calc-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    transition: all 0.5s var(--ease-ios-spring);
    min-height: 520px;
  }

  .calc-card:hover {
    transform: translateY(-4px) scale(1.005);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 8px 12px rgba(0, 0, 0, 0.05),
      0 20px 60px rgba(0, 0, 0, 0.12),
      0 48px 100px rgba(0, 0, 0, 0.10);
  }

  .calc-card .card-specular {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 55%;
    pointer-events: none;
    z-index: 1;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
  }

  .card-content {
    position: relative;
    z-index: 2;
    padding: var(--space-8);
  }

  /* ─── State: Upload ──────────────────────────────────────────── */
  .state-upload {
    height: 100%;
  }

  .upload-zone {
    position: relative;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(248, 250, 252, 0.5) 100%);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 1px 2px rgba(0, 0, 0, 0.02),
      0 4px 12px rgba(0, 0, 0, 0.03);
    transition: all 0.4s var(--ease-ios-spring);
    cursor: pointer;
    overflow: hidden;
  }

  .upload-zone::before {
    content: '';
    position: absolute;
    inset: 8px;
    border-radius: calc(var(--radius-lg) - 8px);
    border: 2px dashed rgba(0, 122, 255, 0.18);
    pointer-events: none;
    transition: all 0.3s ease;
  }

  .upload-zone:hover {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.85) 0%, rgba(240, 247, 255, 0.6) 100%);
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 8px 24px rgba(0, 122, 255, 0.08),
      0 4px 12px rgba(0, 0, 0, 0.04);
  }

  .upload-zone:hover::before {
    border-color: rgba(0, 122, 255, 0.35);
  }

  .upload-zone:hover .upload-icon-circle {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(0, 122, 255, 0.15);
  }

  .upload-zone.drag-over {
    background: linear-gradient(135deg, rgba(0, 122, 255, 0.08) 0%, rgba(0, 122, 255, 0.03) 100%);
    border-color: rgba(0, 122, 255, 0.4);
    transform: scale(1.01);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      0 12px 32px rgba(0, 122, 255, 0.12);
  }

  .upload-zone.drag-over::before {
    border-color: var(--color-primary);
    border-style: solid;
    background: rgba(0, 122, 255, 0.05);
  }

  .file-input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    z-index: 10;
  }

  .upload-content {
    padding: var(--space-8) var(--space-6);
    text-align: center;
  }

  .upload-icon-wrapper {
    position: relative;
    display: inline-flex;
    margin-bottom: var(--space-5);
  }

  .upload-icon-circle {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, rgba(0,122,255,0.08) 0%, rgba(0,122,255,0.03) 100%);
    border: 1px solid rgba(0,122,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    position: relative;
    z-index: 2;
    transition: all 0.3s var(--ease-ios-spring);
  }

  .upload-icon-pulse {
    position: absolute;
    inset: -6px;
    border-radius: calc(var(--radius-xl) + 6px);
    background: rgba(0, 122, 255, 0.06);
    animation: upload-pulse 2.5s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes upload-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.1); opacity: 0.4; }
  }

  .upload-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin: 0 0 var(--space-1);
    letter-spacing: var(--tracking-normal);
  }

  .upload-subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0 0 var(--space-5);
  }

  .upload-formats {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .format-badge {
    padding: 4px 10px;
    background: rgba(118, 118, 128, 0.08);
    border-radius: 6px;
    font-size: 0.6875rem;
    font-weight: var(--font-semibold);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .upload-divider {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: var(--space-5) 0;
    color: var(--text-quaternary);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
  }

  .upload-divider::before,
  .upload-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,0,0,0.08) 50%, transparent);
  }

  .drag-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 122, 255, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .upload-zone.drag-over .drag-overlay {
    opacity: 1;
  }

  .drag-content {
    color: white;
    text-align: center;
  }

  .drag-content svg {
    margin-bottom: 12px;
  }

  .drag-content p {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin: 0;
  }

  /* Error Message */
  .upload-error {
    background: rgba(255, 59, 48, 0.1);
    border: 1px solid rgba(255, 59, 48, 0.3);
    color: var(--red-500);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    text-align: center;
    margin-bottom: var(--space-4);
    opacity: 0;
    transform: translateY(-10px);
    transition: all 0.3s var(--ease-ios-spring);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .upload-error.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Shake Animation for Error */
  .upload-zone.shake {
    animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
    border-color: rgba(255, 59, 48, 0.5);
    background: rgba(255, 59, 48, 0.05);
  }

  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0); }
    20%, 80% { transform: translate3d(2px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
    40%, 60% { transform: translate3d(4px, 0, 0); }
  }

  /* ─── Segmented Control ──────────────────────────────────────── */
  .segmented-control {
    display: flex;
    background: rgba(118, 118, 128, 0.12);
    border-radius: var(--radius-md);
    padding: 3px;
    margin-bottom: var(--space-6);
  }

  .segment-btn {
    flex: 1;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    font-family: var(--font-display);
    border-radius: 10px;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 300ms var(--ease-ios), box-shadow 300ms var(--ease-ios), color 300ms var(--ease-ios);
    -webkit-user-select: none;
    user-select: none;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .segment-btn.active {
    background: #FFFFFF;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
    color: var(--text-primary);
  }

  .btn-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  /* ─── Amount Display ─────────────────────────────────────────── */
  .amount-display {
    text-align: center;
    margin-bottom: var(--space-5);
  }

  .amount-label {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }

  .amount-value {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 4px;
    line-height: 1;
  }

  .bill-counter {
    font-size: clamp(2rem, 6vw, 2.75rem);
    font-weight: var(--font-extrabold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
  }

  .amount-currency {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-secondary);
    margin-top: 4px;
  }

  /* ─── Slider ─────────────────────────────────────────────────── */
  .slider-wrapper {
    position: relative;
    margin-bottom: 12px;
    padding: 6px 0;
  }

  .slider-track {
    position: relative;
    height: 36px;
    background: rgba(118, 118, 128, 0.12);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.06);
  }

  .slider-fill {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    background: linear-gradient(90deg,
      rgba(0, 122, 255, 0.9) 0%,
      var(--color-secondary) 100%
    );
    border-radius: 18px;
    width: 22%;
    box-shadow: 0 0 30px rgba(0, 122, 255, 0.25);
  }

  .slider-ticks {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 14px;
    pointer-events: none;
  }

  .tick {
    width: 3px;
    height: 10px;
    background: rgba(0, 0, 0, 0.08);
    border-radius: 2px;
    transition: background 0.3s;
  }

  .tick.active {
    background: rgba(255, 255, 255, 0.5);
  }

  .slider-input {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    width: 100%;
    height: 36px;
    background: transparent;
    -webkit-appearance: none;
    appearance: none;
    cursor: grab;
    margin: 0;
    padding: 0 6px;
  }

  .slider-input:active {
    cursor: grabbing;
  }

  .slider-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(180deg, #FFFFFF 0%, #F5F5F7 100%);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.15),
      0 2px 6px rgba(0, 0, 0, 0.1),
      0 0 0 1px rgba(0, 0, 0, 0.06),
      0 0 0 5px rgba(0, 122, 255, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 1);
    cursor: grab;
    transition: all 0.2s var(--ease-ios-spring);
    position: relative;
  }

  .slider-input::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    box-shadow:
      0 6px 20px rgba(0, 0, 0, 0.2),
      0 3px 8px rgba(0, 0, 0, 0.12),
      0 0 0 1px rgba(0, 0, 0, 0.06),
      0 0 0 6px rgba(0, 122, 255, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  .slider-input::-webkit-slider-thumb:active {
    cursor: grabbing;
    transform: scale(1.05);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(0, 0, 0, 0.06),
      0 0 0 8px rgba(0, 122, 255, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  .slider-tooltip {
    position: absolute;
    top: -40px;
    left: 22%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.85);
    color: white;
    padding: 6px var(--space-3);
    border-radius: var(--space-2);
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    font-variant-numeric: tabular-nums;
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s var(--ease-ios-spring);
    backdrop-filter: blur(10px);
  }

  .slider-tooltip::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 5px 5px 0;
    border-style: solid;
    border-color: rgba(0, 0, 0, 0.85) transparent transparent;
  }

  .slider-wrapper:hover .slider-tooltip,
  .slider-input:active ~ .slider-tooltip {
    opacity: 1;
  }

  .slider-labels {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-5);
    padding: 0 6px;
  }

  .slider-label {
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-tertiary);
  }

  /* ─── Analyze Button ─────────────────────────────────────────── */
  .btn-analyze {
    position: relative;
    width: 100%;
    padding: var(--space-3) var(--space-5);
    border-radius: 14px;
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    font-family: var(--font-display);
    color: white;
    border: none;
    cursor: pointer;
    overflow: hidden;
    letter-spacing: var(--tracking-normal);
    transition: transform 0.3s var(--ease-ios-spring),
                box-shadow 0.3s var(--ease-ios-spring);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    box-shadow:
      0 4px 16px rgba(0, 122, 255, 0.35),
      0 1px 3px rgba(0, 122, 255, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-analyze:hover {
    transform: scale(1.02) translateY(-2px);
    box-shadow:
      0 6px 24px rgba(0, 122, 255, 0.45),
      0 3px 10px rgba(0, 122, 255, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .btn-analyze:active {
    transform: scale(0.98) translateY(0);
  }

  .btn-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: btn-shine 3s ease-in-out infinite;
  }

  .btn-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  @keyframes btn-shine {
    0%, 100% { left: -100%; }
    50% { left: 150%; }
  }

  /* ─── State: Analyzing ───────────────────────────────────────── */
  .state-analyzing {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
    padding: var(--space-4);
  }

  .analyzing-content {
    text-align: center;
  }

  .document-icon {
    position: relative;
    width: 100px;
    height: 120px;
    margin: 0 auto var(--space-6);
  }

  .document-page {
    position: absolute;
    width: 80px;
    height: 100px;
    background: white;
    border-radius: var(--space-2);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .page-1 {
    top: 0;
    left: 10px;
    z-index: 3;
    animation: page-float-1 2s ease-in-out infinite;
  }

  .page-2 {
    top: 8px;
    left: 14px;
    z-index: 2;
    opacity: 0.7;
    transform: scale(0.95);
    animation: page-float-2 2s ease-in-out infinite 0.1s;
  }

  .page-3 {
    top: 16px;
    left: 18px;
    z-index: 1;
    opacity: 0.4;
    transform: scale(0.9);
    animation: page-float-3 2s ease-in-out infinite 0.2s;
  }

  @keyframes page-float-1 {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-8px) rotate(-1deg); }
  }

  @keyframes page-float-2 {
    0%, 100% { transform: translateY(0) scale(0.95) rotate(1deg); }
    50% { transform: translateY(-6px) scale(0.95) rotate(2deg); }
  }

  @keyframes page-float-3 {
    0%, 100% { transform: translateY(0) scale(0.9) rotate(2deg); }
    50% { transform: translateY(-4px) scale(0.9) rotate(3deg); }
  }

  .scan-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
    box-shadow: 0 0 20px var(--color-primary);
    animation: scan-down 1.5s ease-in-out infinite;
    z-index: 10;
  }

  @keyframes scan-down {
    0% { top: 0; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  .analyzing-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin: 0 0 var(--space-2);
    letter-spacing: var(--tracking-normal);
  }

  .analyzing-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin: 0 0 var(--space-5);
  }

  .progress-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    margin-bottom: var(--space-7);
  }

  .dot {
    width: var(--space-2);
    height: var(--space-2);
    border-radius: 50%;
    background: rgba(0, 122, 255, 0.3);
    animation: dot-bounce 1.4s ease-in-out infinite both;
  }

  .dot:nth-child(1) { animation-delay: -0.32s; }
  .dot:nth-child(2) { animation-delay: -0.16s; }

  @keyframes dot-bounce {
    0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
    40% { transform: scale(1); opacity: 1; }
  }

  .analysis-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
    max-width: 200px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    transition: all 0.3s ease;
  }

  .step.active {
    color: var(--text-primary);
  }

  .step.completed {
    color: var(--color-success);
  }

  .step-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(118, 118, 128, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .step.active .step-icon {
    background: var(--color-primary);
    color: white;
    animation: step-pulse 1.5s ease-in-out infinite;
  }

  .step.completed .step-icon {
    background: var(--color-success);
    color: white;
  }

  @keyframes step-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0, 122, 255, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(0, 122, 255, 0); }
  }

  /* ─── State: Results ─────────────────────────────────────────── */
  .state-results {
    padding: 0;
  }

  .results-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .btn-back {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: none;
    background: rgba(118, 118, 128, 0.12);
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .btn-back:hover {
    background: rgba(118, 118, 128, 0.2);
    color: var(--text-primary);
  }

  .results-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin: 0;
    flex: 1;
    letter-spacing: var(--tracking-normal);
  }

  .results-badge {
    padding: 6px var(--space-3);
    background: rgba(0, 122, 255, 0.1);
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-primary);
  }

  .results-subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0 0 var(--space-5) 48px;
  }

  .results-subtitle strong {
    color: var(--text-primary);
    font-weight: var(--font-semibold);
  }

  /* Savings Highlight */
  .savings-highlight {
    position: relative;
    background: linear-gradient(135deg, rgba(52,199,89,0.15) 0%, rgba(52,199,89,0.06) 100%);
    border: 1.5px solid rgba(52,199,89,0.25);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
    overflow: hidden;
    box-shadow:
      0 4px 20px rgba(52, 199, 89, 0.12),
      0 1px 3px rgba(0, 0, 0, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  .savings-highlight::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(52, 199, 89, 0.2) 0%, transparent 70%);
    pointer-events: none;
  }

  .savings-highlight-specular {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.7) 0%,
      rgba(255,255,255,0.2) 50%,
      transparent 100%
    );
    pointer-events: none;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }

  .savings-highlight-content {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .savings-highlight-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .savings-label {
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    color: var(--color-success);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .savings-amount {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: var(--font-extrabold);
    color: var(--color-success);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    text-shadow: 0 2px 8px rgba(52, 199, 89, 0.2);
  }

  .savings-provider {
    text-align: right;
    padding: var(--space-2) var(--space-3);
    background: rgba(255, 255, 255, 0.5);
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.6);
  }

  .savings-provider span {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: 2px;
  }

  .savings-provider strong {
    display: block;
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    letter-spacing: var(--tracking-normal);
  }

  /* Providers List */
  .providers-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    max-height: 300px;
    overflow-y: auto;
    padding-right: 6px;
  }

  .providers-list::-webkit-scrollbar {
    width: 5px;
  }

  .providers-list::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.03);
    border-radius: 3px;
  }

  .providers-list::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 3px;
  }

