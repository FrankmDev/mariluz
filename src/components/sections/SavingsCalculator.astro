---
import { siteConfig } from '../../config/site';
---

<section id="calculadora" class="section" style="background: #FFFFFF;">
  <div class="container-custom">

    <div class="calc-layout">

      <!-- Left: Calculator Widget -->
      <div class="reveal calc-widget-col" style="transition-delay: 0ms;">

        <!-- Header inside widget -->
        <div style="margin-bottom: 48px;">
          <span class="badge badge-green" style="margin-bottom: 16px; display: inline-flex;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Calculadora de ahorro
          </span>
          <h2 class="text-large-title" style="color: var(--label-primary); margin-bottom: 12px;">
            Descubre tu potencial de ahorro.
          </h2>
          <p class="text-body" style="color: var(--label-secondary);">
            Estimación en tiempo real basada en datos reales del mercado energético español.
          </p>
        </div>

        <!-- Widget Card -->
        <div class="calc-card">
          <div style="padding: 36px 36px 0;">

            <!-- Segmented Control -->
            <div class="segmented" style="width: 100%; padding: 3px; margin-bottom: 40px;">
              <button class="segmented-btn active" data-type="home" type="button" aria-pressed="true" style="flex: 1; padding: 10px 16px;">
                <span style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  Hogar
                </span>
              </button>
              <button class="segmented-btn" data-type="business" type="button" aria-pressed="false" style="flex: 1; padding: 10px 16px;">
                <span style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                  Negocio
                </span>
              </button>
            </div>

            <!-- Amount Display -->
            <div style="text-align: center; margin-bottom: 32px;">
              <p class="text-subhead" style="color: var(--label-secondary); margin-bottom: 10px;">Factura mensual actual</p>
              <div class="text-numeric bill-display" style="display: flex; align-items: flex-start; justify-content: center; gap: 8px; line-height: 1;">
                <span id="bill-amount" class="bill-counter" style="font-size: 5rem; font-weight: 800; letter-spacing: -0.05em; color: var(--label-primary);">120</span>
                <span class="bill-currency" style="font-size: 2.25rem; font-weight: 600; color: var(--label-secondary); margin-top: 10px;">€</span>
              </div>
            </div>

            <!-- Slider -->
            <div class="slider-container" style="position: relative; margin-bottom: 10px;">
              <div class="slider-track-bg" style="position: absolute; inset: 0; background: var(--bg-secondary); border-radius: 22px;"></div>
              <div id="slider-track-fill" class="slider-fill" style="position: absolute; left: 0; top: 0; bottom: 0; background: linear-gradient(90deg, var(--ios-blue), #5856D6); border-radius: 22px; width: 22%; transition: width 80ms ease-out; box-shadow: 0 0 30px rgba(0,122,255,0.3);"></div>
              <input
                type="range"
                id="bill-slider"
                min="20"
                max="500"
                value="120"
                step="5"
                class="slider-ios slider-premium"
                style="position: relative; z-index: 2; background: transparent; height: 48px;"
                aria-label="Factura mensual en euros"
              />
              <div class="slider-icon" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); z-index: 3; color: white; pointer-events: none; opacity: 0.9;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
              </div>
              <div class="slider-thumb-glow" id="slider-glow" style="position: absolute; top: 50%; transform: translate(-50%, -50%); width: 40px; height: 40px; background: rgba(0,122,255,0.3); border-radius: 50%; filter: blur(12px); pointer-events: none; opacity: 0; transition: opacity 0.3s;"></div>
            </div>
            <div class="slider-labels" style="display: flex; justify-content: space-between; margin-bottom: 36px;">
              <span class="text-footnote slider-label" style="color: var(--label-tertiary); font-weight: 600; transition: color 0.3s;">20€ / mes</span>
              <span class="text-footnote slider-label" style="color: var(--label-tertiary); font-weight: 600; transition: color 0.3s;">500€ / mes</span>
            </div>
          </div>

          <!-- Result Area -->
          <div style="margin: 0 36px; border-top: 1px solid var(--separator);"></div>
          <div class="result-area" style="padding: 32px 36px 36px; background: linear-gradient(180deg, rgba(52,199,89,0.05) 0%, transparent 100%); position: relative; overflow: hidden;">
            
            <!-- Shimmer effect on high savings -->
            <div id="savings-shimmer" class="savings-shimmer" style="position: absolute; inset: 0; background: linear-gradient(105deg, transparent 40%, rgba(52,199,89,0.1) 50%, transparent 60%); transform: translateX(-100%); pointer-events: none;"></div>

            <div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 28px; position: relative; z-index: 1;">
              <div>
                <p style="font-size: 0.875rem; font-weight: 700; color: var(--ios-green); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.04em; font-family: var(--font-display);">Ahorro anual estimado</p>
                <p class="text-footnote" style="color: var(--label-tertiary);">Mercado libre · tarifa óptima</p>
              </div>
              <div class="text-numeric savings-display" style="display: flex; align-items: flex-start; gap: 4px; line-height: 1;">
                <span class="savings-prefix" style="font-size: 1.25rem; font-weight: 700; color: var(--ios-green); margin-top: 6px;">+</span>
                <span id="yearly-saving" class="savings-counter" style="font-size: 3.5rem; font-weight: 800; letter-spacing: -0.04em; color: var(--ios-green);">316</span>
                <span class="savings-suffix" style="font-size: 1.75rem; font-weight: 700; color: var(--ios-green); margin-top: 6px;">€</span>
              </div>
            </div>

            <a href={siteConfig.whatsappUrl} class="btn-green" style="width: 100%; justify-content: center; font-size: 1.0625rem; padding: 18px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Obtener este ahorro gratis
            </a>

            <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 14px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--label-quaternary); flex-shrink: 0;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span class="text-footnote" style="color: var(--label-quaternary);">Gestión cifrada y segura · Sin compromiso</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Right: Context / Why -->
      <div class="reveal calc-info-col" style="transition-delay: 150ms;">

        <div style="margin-bottom: 40px;">
          <h3 class="text-title-1" style="color: var(--label-primary); margin-bottom: 16px; line-height: 1.2;">
            Por qué muchos pagan de más sin saberlo.
          </h3>
          <p class="text-body" style="color: var(--label-secondary); line-height: 1.7;">
            El mercado eléctrico español tiene más de 300 tarifas activas. Las comercializadoras invierten millones en marketing, no en darte la mejor tarifa. El resultado: el 74% de los hogares está pagando más de lo que debería.
          </p>
        </div>

        <!-- Info cards -->
        <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 40px;">
          <div class="info-card">
            <div class="icon-frame" style="background: var(--ios-blue-light); color: var(--ios-blue); flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <div>
              <p class="text-subhead" style="color: var(--label-primary); font-weight: 700; margin-bottom: 4px;">Comparativa real del mercado</p>
              <p class="text-footnote" style="color: var(--label-secondary); line-height: 1.5;">Accedo a datos actualizados de todas las comercializadoras, no solo las que pagan más comisión.</p>
            </div>
          </div>

          <div class="info-card">
            <div class="icon-frame" style="background: var(--ios-green-light); color: var(--ios-green); flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="text-subhead" style="color: var(--label-primary); font-weight: 700; margin-bottom: 4px;">Cero coste para ti</p>
              <p class="text-footnote" style="color: var(--label-secondary); line-height: 1.5;">Mi servicio es completamente gratuito. Cobro una comisión de la comercializadora, nunca de ti.</p>
            </div>
          </div>

          <div class="info-card">
            <div class="icon-frame" style="background: var(--ios-indigo-light); color: var(--ios-indigo); flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <div>
              <p class="text-subhead" style="color: var(--label-primary); font-weight: 700; margin-bottom: 4px;">Asesora certificada</p>
              <p class="text-footnote" style="color: var(--label-secondary); line-height: 1.5;">8 años de experiencia auditando consumos y optimizando contratos energéticos.</p>
            </div>
          </div>
        </div>

        <!-- Testimonial snippet -->
        <div class="testimonial-snippet">
          <div style="display: flex; gap: 2px; margin-bottom: 12px;">
            <span style="color: var(--ios-orange);">★</span>
            <span style="color: var(--ios-orange);">★</span>
            <span style="color: var(--ios-orange);">★</span>
            <span style="color: var(--ios-orange);">★</span>
            <span style="color: var(--ios-orange);">★</span>
          </div>
          <p class="text-body" style="color: var(--label-primary); line-height: 1.6; margin-bottom: 16px; font-style: italic;">
            "Pensaba que ya tenía una buena tarifa, pero Mariluz encontró una mejor. Ahora ahorro 27€ al mes sin cambiar mis hábitos."
          </p>
          <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="display: flex; align-items: center; gap: 10px;">
              <div class="avatar avatar-sm" style="background: linear-gradient(135deg, var(--ios-indigo), #8B5CF6); color: white;">CR</div>
              <div>
                <p class="text-subhead" style="color: var(--label-primary); font-weight: 600;">Carmen R.</p>
                <p class="text-footnote" style="color: var(--label-secondary);">Madrid</p>
              </div>
            </div>
            <span class="badge badge-green" style="font-size: 0.75rem; padding: 5px 10px;">+324€/año</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .calc-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .calc-card {
    position: relative;
    /* Authentic Liquid Glass */
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 24px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      0 12px 40px rgba(0, 0, 0, 0.08),
      0 4px 12px rgba(0, 0, 0, 0.03);
    overflow: hidden;
    transition: all 0.4s var(--ease-ios-spring);
  }

  .calc-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    border-radius: 24px 24px 0 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.9) 0%,
      rgba(255, 255, 255, 0.25) 60%,
      transparent 100%
    );
    pointer-events: none;
  }

  .calc-card:hover {
    background: rgba(255, 255, 255, 0.85);
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 20px 56px rgba(0, 0, 0, 0.1),
      0 8px 16px rgba(0, 0, 0, 0.04);
  }

  /* Bill display animation */
  .bill-display {
    transition: transform 0.2s var(--ease-ios-spring);
  }

  .bill-display.updating {
    transform: scale(1.05);
  }

  .bill-counter {
    transition: color 0.3s;
  }

  .bill-display.updating .bill-counter {
    color: var(--ios-blue) !important;
  }

  /* Premium slider styles */
  .slider-container {
    border-radius: 22px;
  }

  .slider-premium {
    cursor: grab;
    touch-action: none;
  }

  .slider-premium:active {
    cursor: grabbing;
  }

  .slider-premium::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: white;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.05);
    margin-top: -14px;
    cursor: grab;
    transition: transform 0.2s var(--ease-ios-spring), box-shadow 0.2s;
  }

  .slider-premium::-webkit-slider-thumb:hover {
    transform: scale(1.15);
    box-shadow: 0 4px 20px rgba(0,122,255,0.3), 0 0 0 2px var(--ios-blue);
  }

  .slider-premium::-webkit-slider-thumb:active {
    transform: scale(0.95);
    cursor: grabbing;
  }

  .slider-fill {
    background: linear-gradient(90deg, var(--ios-blue), #5856D6) !important;
  }

  /* Savings display animation */
  .savings-display {
    transition: transform 0.3s var(--ease-ios-spring);
  }

  .savings-display.celebrating {
    animation: savings-celebrate 0.5s var(--ease-ios-spring);
  }

  @keyframes savings-celebrate {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }

  .savings-shimmer.animating {
    animation: savings-shimmer 0.8s ease forwards;
  }

  @keyframes savings-shimmer {
    to { transform: translateX(100%); }
  }

  /* Info card hover effects */
  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    border: 1px solid var(--separator);
    transition: all 0.3s var(--ease-ios-spring);
  }

  .info-card:hover {
    background: var(--bg-primary);
    box-shadow: var(--shadow-sm);
    transform: translateX(4px);
  }

  .info-card:hover .icon-frame {
    transform: scale(1.1);
  }

  /* Testimonial shimmer */
  .testimonial-snippet {
    background: var(--bg-primary);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--separator);
    padding: 28px;
    box-shadow: var(--shadow-xs);
    transition: all 0.4s var(--ease-ios-spring);
    position: relative;
    overflow: hidden;
  }

  .testimonial-snippet::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.5) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: transform 0.6s;
  }

  .testimonial-snippet:hover::before {
    transform: translateX(100%);
  }

  .testimonial-snippet:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  @media (max-width: 1024px) {
    .calc-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .calc-widget-col {
      max-width: 580px;
      margin: 0 auto;
    }
  }
</style>

<script>
  const SAVINGS_RATES = { home: 0.22, business: 0.18 };
  const slider = document.getElementById('bill-slider') as HTMLInputElement | null;
  const billAmountEl = document.getElementById('bill-amount');
  const yearlySavingEl = document.getElementById('yearly-saving');
  const trackFill = document.getElementById('slider-track-fill');
  const sliderGlow = document.getElementById('slider-glow');
  const savingsShimmer = document.getElementById('savings-shimmer');
  const segmentBtns = document.querySelectorAll<HTMLButtonElement>('.segmented-btn');
  const billDisplay = document.querySelector('.bill-display');
  const savingsDisplay = document.querySelector('.savings-display');
  let currentType: 'home' | 'business' = 'home';
  let currentSaving = 0;

  // Animated counter function
  function animateCounter(el: HTMLElement, from: number, to: number, duration = 400) {
    const start = performance.now();
    const step = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const easeOut = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(from + (to - from) * easeOut).toString();
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  function updateUI(animate = false) {
    if (!slider) return;
    const value = parseInt(slider.value);
    const min = parseInt(slider.min);
    const max = parseInt(slider.max);
    const pct = ((value - min) / (max - min)) * 100;
    
    if (trackFill) trackFill.style.width = pct + '%';
    if (sliderGlow) {
      sliderGlow.style.left = `${pct}%`;
      sliderGlow.style.opacity = '1';
    }
    
    const saving = Math.round(value * SAVINGS_RATES[currentType] * 12);
    
    if (billAmountEl) {
      if (animate) {
        const current = parseInt(billAmountEl.textContent || '0');
        animateCounter(billAmountEl, current, value, 200);
      } else {
        billAmountEl.textContent = value.toString();
      }
    }
    
    if (yearlySavingEl && saving !== currentSaving) {
      animateCounter(yearlySavingEl, currentSaving, saving, 300);
      currentSaving = saving;
      
      // Celebration effect for high savings
      if (saving > 400 && savingsDisplay) {
        savingsDisplay.classList.add('celebrating');
        if (savingsShimmer) savingsShimmer.classList.add('animating');
        setTimeout(() => {
          savingsDisplay.classList.remove('celebrating');
          if (savingsShimmer) savingsShimmer.classList.remove('animating');
        }, 800);
      }
    }
  }

  // Slider events with enhanced feedback
  slider?.addEventListener('input', () => {
    if (billDisplay) billDisplay.classList.add('updating');
    updateUI(true);
  });

  slider?.addEventListener('change', () => {
    if (billDisplay) billDisplay.classList.remove('updating');
    if (sliderGlow) sliderGlow.style.opacity = '0';
  });

  slider?.addEventListener('mousedown', () => {
    if (sliderGlow) sliderGlow.style.opacity = '1';
  });

  slider?.addEventListener('mouseup', () => {
    if (sliderGlow) sliderGlow.style.opacity = '0';
  });

  // Touch events for mobile
  slider?.addEventListener('touchstart', () => {
    if (sliderGlow) sliderGlow.style.opacity = '1';
  });

  slider?.addEventListener('touchend', () => {
    if (sliderGlow) sliderGlow.style.opacity = '0';
  });

  segmentBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentType = (btn.dataset.type as 'home' | 'business') || 'home';
      segmentBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      updateUI(true);
    });
  });

  updateUI();
</script>
