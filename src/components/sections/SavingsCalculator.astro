  const PROVIDERS_DATA = [
    { id: 'current', name: 'Tu comercializadora actual', logo: '🔌', color: '#8E8E93', isCurrent: true },
    { id: 'iberdrola', name: 'Iberdrola', logo: '⚡', color: '#007AFF', discount: 0.15, rating: 4.2, features: ['Sin permanencia', 'Factura digital', 'App móvil'] },
    { id: 'endesa', name: 'Endesa', logo: '🔋', color: '#FF9500', discount: 0.12, rating: 4.0, features: ['Tarifa online', 'Descuento 12 meses', 'Gestión online'] },
    { id: 'naturgy', name: 'Naturgy', logo: '🌿', color: '#34C759', discount: 0.18, rating: 4.4, features: ['Energía verde', 'Sin permanencia', 'Precio fijo'] },
    { id: 'repsol', name: 'Repsol', logo: '⛽', color: '#FF3B30', discount: 0.10, rating: 3.9, features: ['Puntos descuento', 'Gas+luz', 'Tarifa plana'] },
  ];

  const SAVINGS_RATES = { home: 0.22, business: 0.18 };
  
  // Elementos DOM
  const widget = document.getElementById('calculator-widget');
  const stateUpload = document.getElementById('state-upload');
  const stateAnalyzing = document.getElementById('state-analyzing');
  const stateResults = document.getElementById('state-results');
  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('file-input');
  const dragOverlay = document.getElementById('drag-overlay');
  const btnAnalyzeManual = document.getElementById('btn-analyze-manual');
  const btnBack = document.getElementById('btn-back');
  const slider = document.getElementById('bill-slider');
  const billAmountEl = document.getElementById('bill-amount');
  const sliderFill = document.getElementById('slider-fill');
  const sliderTooltip = document.getElementById('slider-tooltip');
  const segmentBtns = document.querySelectorAll('.segment-btn');
  const providersList = document.getElementById('providers-list');
  const analyzingStatus = document.getElementById('analyzing-status');
  const analysisSteps = document.querySelectorAll('.step');
  
  let currentType = 'home';
  let currentBillAmount = 120;

  // Estados
  function showState(state) {
    if (stateUpload) stateUpload.hidden = state !== 'upload';
    if (stateAnalyzing) stateAnalyzing.hidden = state !== 'analyzing';
    if (stateResults) stateResults.hidden = state !== 'results';
  }

  // Mostrar error de validación
  function showError(message) {
    let errorEl = document.getElementById('upload-error');
    if (!errorEl) {
      errorEl = document.createElement('div');
      errorEl.id = 'upload-error';
      errorEl.className = 'upload-error';
      const uploadContent = document.querySelector('.upload-content');
      if (uploadContent) {
        uploadContent.insertBefore(errorEl, uploadContent.firstChild);
      }
    }
    
    errorEl.textContent = message;
    errorEl.classList.add('visible');
    
    if (uploadZone) {
      uploadZone.classList.add('shake');
      setTimeout(() => uploadZone.classList.remove('shake'), 500);
    }
    
    setTimeout(() => {
      errorEl.classList.remove('visible');
    }, 3000);
  }

  // Animación de contador
  function animateCounter(el, from, to, duration = 400) {
    const start = performance.now();
    const step = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const easeOut = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(from + (to - from) * easeOut).toString();
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  // Actualizar slider UI
  function updateSliderUI(value) {
    if (!slider) return;
    const min = parseInt(slider.min);
    const max = parseInt(slider.max);
    const pct = ((value - min) / (max - min)) * 100;
    
    if (sliderFill) sliderFill.style.width = pct + '%';
    if (sliderTooltip) {
      sliderTooltip.style.left = pct + '%';
      sliderTooltip.textContent = value + '€';
    }
    
    const ticks = document.querySelectorAll('.tick');
    ticks.forEach((tick, i) => {
      const tickPct = (i / (ticks.length - 1)) * 100;
      tick.classList.toggle('active', tickPct <= pct + 2);
    });
  }

  // Generar lista de proveedores
  function generateProvidersList(monthlyAmount) {
    if (!providersList) return;
    
    const yearlyAmount = monthlyAmount * 12;
    
    const providers = PROVIDERS_DATA.map(provider => {
      if (provider.isCurrent) {
        return {
          ...provider,
          yearlyCost: yearlyAmount,
          savings: 0,
        };
      }
      const discount = provider.discount || 0;
      const yearlyCost = Math.round(yearlyAmount * (1 - discount));
      const savings = yearlyAmount - yearlyCost;
      return {
        ...provider,
        yearlyCost,
        savings,
      };
    }).sort((a, b) => a.yearlyCost - b.yearlyCost);

    const bestProvider = providers.find(p => !p.isCurrent);
    const maxSavings = bestProvider ? bestProvider.savings : 0;

    // Actualizar highlight
    const savingsHighlight = document.getElementById('max-savings');
    const bestProviderEl = document.getElementById('best-provider');
    const monthlyCostEl = document.getElementById('monthly-cost');
    const consumptionBadge = document.getElementById('consumption-badge');
    
    if (savingsHighlight) savingsHighlight.textContent = '+' + maxSavings + '€';
    if (bestProviderEl) bestProviderEl.innerHTML = '<span>con</span><strong>' + (bestProvider ? bestProvider.name : '') + '</strong>';
    if (monthlyCostEl) monthlyCostEl.textContent = monthlyAmount + '€/mes';
    if (consumptionBadge) consumptionBadge.textContent = Math.round(monthlyAmount * 2.5) + ' kWh/mes';

    // Generar HTML con nuevo diseño premium
    const maxYearlyCost = Math.max(...providers.map(p => p.yearlyCost));
    
    providersList.innerHTML = providers.map((provider, index) => {
      const isCurrent = provider.isCurrent;
      const isBest = index === 0 && !isCurrent;
      const monthlyCost = Math.round(provider.yearlyCost / 12);
      const yearlySavings = provider.savings;
      const savingsPercent = maxYearlyCost > 0 ? Math.round((provider.yearlyCost / maxYearlyCost) * 100) : 100;
      
      // Ranking badges
      let rankClass = '';
      if (index === 0) rankClass = 'gold';
      else if (index === 1) rankClass = 'silver';
      else if (index === 2) rankClass = 'bronze';
      
      return `
        <div class="provider-card ${isCurrent ? 'current' : ''} ${isBest ? 'best' : ''}" style="animation: slide-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) ${index * 0.08}s both;">
          ${!isCurrent ? `<div class="provider-rank ${rankClass}">${index}</div>` : ''}
          ${isBest ? `
            <div class="winner-badge">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              Mejor
            </div>
          ` : ''}
          
          <div class="provider-main">
            <div class="provider-logo" style="color: ${provider.color};">${provider.logo}</div>
            <div class="provider-info">
              <div class="provider-header">
                <p class="provider-name">${provider.name}</p>
                ${isCurrent ? '<span class="current-badge">Actual</span>' : ''}
              </div>
              <div class="provider-features">
                ${(provider.features || []).slice(0, 2).map(f => '<span class="provider-feature">' + f + '</span>').join('')}
              </div>
              ${!isCurrent && yearlySavings > 0 ? `
                <div class="savings-bar-container">
                  <div class="savings-bar" style="width: ${100 - savingsPercent}%;"></div>
                </div>
              ` : ''}
            </div>
          </div>
          
          <div class="provider-cost-section">
            <span class="cost-period">/mes</span>
            <span class="cost-amount">${monthlyCost}€</span>
            ${isCurrent 
              ? '<span class="current-tag">Actual</span>' 
              : yearlySavings > 0 
                ? `<span class="savings-pill">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Ahorra ${yearlySavings}€
                  </span>`
                : ''
            }
          </div>
        </div>
      `;
    }).join('');
  }

  // Análisis simulado
  async function simulateAnalysis(file) {
    showState('analyzing');
    
    const steps = [
      { text: 'Extrayendo datos de consumo...', delay: 800 },
      { text: 'Calculando potencia contratada...', delay: 1200 },
      { text: 'Analizando tarifas del mercado...', delay: 1600 },
      { text: 'Comparando ofertas disponibles...', delay: 2200 },
    ];

    // Animar pasos
    for (let i = 0; i < analysisSteps.length; i++) {
      setTimeout(() => {
        analysisSteps.forEach((step, idx) => {
          step.classList.remove('active', 'completed');
          if (idx < i) step.classList.add('completed');
          else if (idx === i) step.classList.add('active');
        });
      }, i * 600);
    }

    // Actualizar status
    for (const step of steps) {
      await new Promise(r => setTimeout(r, step.delay / 4));
      if (analyzingStatus) analyzingStatus.textContent = step.text;
    }

    // Pequeña variación aleatoria en el monto para simular extracción real
    const variation = Math.floor(Math.random() * 20) - 10;
    const analyzedAmount = Math.max(30, currentBillAmount + variation);
    currentBillAmount = analyzedAmount;

    // Mostrar resultados
    generateProvidersList(analyzedAmount);
    showState('results');
  }

  // Drag & Drop
  ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
    if (uploadZone) {
      uploadZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
      });
    }
  });

  ['dragenter', 'dragover'].forEach(eventName => {
    if (uploadZone) {
      uploadZone.addEventListener(eventName, () => {
        uploadZone.classList.add('drag-over');
      });
    }
  });

  ['dragleave', 'drop'].forEach(eventName => {
    if (uploadZone) {
      uploadZone.addEventListener(eventName, () => {
        uploadZone.classList.remove('drag-over');
      });
    }
  });

  if (uploadZone) {
    uploadZone.addEventListener('drop', (e) => {
      const files = e.dataTransfer ? e.dataTransfer.files : null;
      if (files && files.length > 0) {
        const file = files[0];
        if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
          simulateAnalysis(file);
        } else {
          showError('Por favor, sube solo archivos PDF');
        }
      }
    });
  }

  // File input change
  if (fileInput) {
    fileInput.addEventListener('change', () => {
      const file = fileInput.files ? fileInput.files[0] : null;
      if (file) {
        if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
          simulateAnalysis(file);
        } else {
          showError('Por favor, sube solo archivos PDF');
          fileInput.value = '';
        }
      }
    });
  }

  // Botón analizar manual
  if (btnAnalyzeManual) {
    btnAnalyzeManual.addEventListener('click', () => {
      simulateAnalysis();
    });
  }

  // Botón volver
  if (btnBack) {
    btnBack.addEventListener('click', () => {
      showState('upload');
      analysisSteps.forEach(step => step.classList.remove('active', 'completed'));
      if (analyzingStatus) analyzingStatus.textContent = 'Extrayendo datos de consumo...';
    });
  }

  // Slider events
  if (slider) {
    slider.addEventListener('input', () => {
      const value = parseInt(slider.value);
      currentBillAmount = value;
      updateSliderUI(value);
      if (billAmountEl) billAmountEl.textContent = value.toString();
    });
  }

  // Segmented control
  segmentBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentType = btn.dataset.type || 'home';
      segmentBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
    });
  });

  // Stats counter animation
  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const statNumbers = entry.target.querySelectorAll('.stat-number[data-target]');
        statNumbers.forEach((stat, index) => {
          const target = parseInt(stat.dataset.target || '0');
          setTimeout(() => {
            animateCounter(stat, 0, target, 1500);
          }, index * 150);
        });
        statsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  const statsRow = document.querySelector('.stats-row');
  if (statsRow) statsObserver.observe(statsRow);

  // Inicializar
  updateSliderUI(120);

  // CSS para animaciones premium
  const style = document.createElement('style');
  style.textContent = `
    @keyframes slide-in {
      from {
        opacity: 0;
        transform: translateY(20px) scale(0.95);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    
    @keyframes savings-bar-fill {
      from {
        transform: scaleX(0);
        transform-origin: left;
      }
      to {
        transform: scaleX(1);
        transform-origin: left;
      }
    }
    
    .savings-bar {
      animation: savings-bar-fill 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s both;
    }
    
    @keyframes amount-pop {
      0% { transform: scale(1); }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); }
    }
    
    .cost-amount {
      animation: amount-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.6s both;
    }
  `;
  document.head.appendChild(style);
</script>
