---
import { Image } from 'astro:assets';
import { siteConfig, faqData } from '../../config/site';
import aboutPhoto from '../../assets/about.jpeg';
import { MessageCircle, Phone } from 'lucide-astro';

const faqs = faqData.map(faq => ({
  question: faq.question,
  answer: faq.answer,
}));
---

<section id="faq" class="faq-section">
  <div class="container-custom faq-container">

    <!-- Section Header -->
    <div class="faq-header reveal">
      <div class="faq-eyebrow">
        <span class="faq-eyebrow-dot"></span>
        <span class="text-caption">Preguntas frecuentes</span>
      </div>
      <h2 class="faq-title">Todo lo que necesitas saber.</h2>
      <p class="faq-subtitle">Respuestas honestas a las dudas más habituales.</p>
    </div>

    <div class="faq-layout">

      <!-- Left: FAQ Accordion with Liquid Glass -->
      <div class="faq-col reveal" style="--delay: 0ms;">
        <div class="faq-list">
          {faqs.map((faq, index) => (
            <details class="faq-item" data-faq={index} style={`--faq-index: ${index}`}>
              <summary class="faq-summary">
                <div class="faq-summary-content">
                  <span class="faq-number">{String(index + 1).padStart(2, '0')}</span>
                  <span class="faq-question">{faq.question}</span>
                </div>
                <div class="faq-icon-btn">
                  <div class="faq-icon-bg">
                    <svg class="faq-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </div>
                </div>
              </summary>
              <div class="faq-body">
                <div class="faq-body-inner">
                  <div class="faq-answer">
                    <p>{faq.answer}</p>
                  </div>
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- Right: Contact Card -->
      <div class="faq-contact-col reveal" style="--delay: 150ms;">

        <div class="contact-card" data-contact-card>
          <!-- Specular Highlight Layer -->
          <div class="contact-specular"></div>

          <!-- Card Content -->
          <div class="contact-card-content">
            <!-- Avatar -->
            <div class="contact-avatar-wrap">
              <div class="contact-avatar">
                <Image
                  src={aboutPhoto}
                  alt="Mariluz Marín, asesora energética independiente"
                  width={88}
                  height={88}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="contact-status">
                <span class="status-ping"></span>
              </div>
            </div>

            <h3 class="contact-title">¿Tienes más dudas?</h3>
            <p class="contact-description">
              Escríbeme directamente. Respondo en menos de 24 horas y sin compromiso.
            </p>

            <!-- CTAs -->
            <div class="contact-actions">
              <a href={siteConfig.whatsappUrl} class="contact-cta contact-cta-primary">
                <span class="cta-bg"></span>
                <span class="cta-content">
                  <MessageCircle size={18} fill="currentColor" aria-hidden="true" />
                  Escribir por WhatsApp
                </span>
              </a>

              <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="contact-cta contact-cta-secondary">
                <Phone size={18} aria-hidden="true" />
                {siteConfig.phone}
              </a>
            </div>

            <!-- Trust indicators -->
            <div class="contact-trust">
              <div class="trust-item">
                <div class="trust-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                </div>
                <span class="text-caption">Sin compromiso ni permanencia</span>
              </div>
              <div class="trust-item">
                <div class="trust-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                </div>
                <span class="text-caption">Respuesta garantizada en 24h</span>
              </div>
              <div class="trust-item">
                <div class="trust-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                </div>
                <span class="text-caption">Servicio 100% gratuito siempre</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* ========== FAQ Section Base ========== */
  .faq-section {
    position: relative;
    padding: var(--section-py) 0;
    overflow: hidden;
    /* No background - using global background from Layout */
  }

  .faq-container {
    position: relative;
    z-index: 1;
  }

  /* ========== Section Header ========== */
  .faq-header {
    text-align: center;
    margin-bottom: var(--space-20);
  }

  .faq-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 10px var(--space-4);
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.68);
    border-radius: var(--radius-pill);
    box-shadow: 
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      0 2px 8px rgba(0, 0, 0, 0.04);
    margin-bottom: var(--space-6);
    color: var(--text-secondary);
  }

  .faq-eyebrow-dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }

  .faq-title {
    font-size: var(--text-section);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .faq-subtitle {
    font-size: var(--text-xl);
    line-height: 1.5;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto;
  }

  /* ========== FAQ Layout ========== */
  .faq-layout {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-20);
    align-items: start;
  }

  /* ========== FAQ List with Liquid Glass Cards ========== */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .faq-item {
    position: relative;
    display: block;
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-xl);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    transition: transform 0.5s var(--ease-ios-spring), background 0.4s ease, box-shadow 0.4s ease;
  }

  .faq-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.45) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }

  .faq-item:hover {
    background: rgba(255, 255, 255, 0.82);
    transform: translateY(-3px) scale(1.01);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 6px 12px rgba(0, 0, 0, 0.06),
      0 16px 48px rgba(0, 0, 0, 0.10),
      0 40px 96px rgba(0, 0, 0, 0.08);
  }

  .faq-item:hover .faq-number {
    color: var(--color-primary);
    transform: scale(1.1);
  }

  .faq-number {
    transition: color 0.3s ease, transform 0.3s var(--ease-ios-spring);
  }

  .faq-item.is-open {
    background: rgba(255, 255, 255, 0.85);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 8px 24px rgba(0, 0, 0, 0.08),
      0 20px 60px rgba(0, 0, 0, 0.12),
      0 48px 100px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px) scale(1.01);
  }

  .faq-item.is-open:hover {
    transform: translateY(-4px) scale(1.01);
  }

  .faq-summary {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6);
    cursor: pointer;
    list-style: none;
    user-select: none;
    -webkit-user-select: none;
    gap: var(--space-4);
    transition: color 0.3s ease;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary-content {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex: 1;
  }

  .faq-number {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-quaternary);
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    transition: color 0.3s ease, transform 0.3s var(--ease-ios-spring);
    min-width: 28px;
  }

  .faq-item.is-open .faq-number {
    color: var(--color-primary);
  }

  .faq-question {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.5;
    flex: 1;
    transition: color 0.3s;
  }

  .faq-item:hover .faq-question {
    color: var(--color-primary);
  }

  .faq-icon-btn {
    flex-shrink: 0;
    position: relative;
  }

  .faq-icon-bg {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.4s ease, transform 0.4s var(--ease-ios-spring);
  }

  .faq-chevron {
    color: var(--text-tertiary);
    transition: transform 0.4s var(--ease-ios-spring), color 0.4s ease;
  }

  .faq-item.is-open .faq-icon-bg {
    background: var(--color-primary);
  }

  .faq-item.is-open .faq-chevron {
    transform: rotate(180deg);
    color: white;
    stroke: white;
  }

  /* FAQ Body Animation — grid-template-rows for buttery smooth height */
  .faq-body {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.5s var(--ease-ios-decel), opacity 0.35s ease;
  }

  .faq-body-inner {
    overflow: hidden;
    padding: 0 var(--space-6) 0 76px;
  }

  .faq-item.is-open .faq-body {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .faq-answer {
    transform: translateY(-6px);
    opacity: 0;
    transition: transform 0.45s var(--ease-ios-decel) 0.05s, opacity 0.35s ease 0.05s;
  }

  .faq-answer p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-secondary);
    padding-bottom: var(--space-6);
  }

  .faq-item.is-open .faq-answer {
    transform: translateY(0);
    opacity: 1;
  }

  /* ========== Contact Card (Premium Liquid Glass) ========== */
  .faq-contact-col {
    position: relative;
  }

  .contact-card {
    position: sticky;
    top: 100px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(44px) saturate(220%) brightness(1.04);
    -webkit-backdrop-filter: blur(44px) saturate(220%) brightness(1.04);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-2xl);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    transition: transform 0.5s var(--ease-ios-spring), box-shadow 0.4s ease;
  }

  .contact-specular {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.45) 35%,
      rgba(255, 255, 255, 0.12) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .contact-card-content {
    position: relative;
    z-index: 2;
    padding: 44px 36px var(--space-10);
  }

  .contact-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(0, 0, 0, 0.02),
      0 12px 24px rgba(0, 0, 0, 0.08),
      0 28px 72px rgba(0, 0, 0, 0.14),
      0 48px 120px rgba(0, 0, 0, 0.1);
  }

  .contact-card:hover .contact-avatar {
    transform: scale(1.08);
  }

  /* Avatar */
  .contact-avatar-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-6);
    position: relative;
  }

  .contact-avatar {
    position: relative;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    padding: 4px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    box-shadow: 0 8px 32px color-mix(in srgb, var(--color-primary) 35%, transparent);
    transition: transform 0.4s var(--ease-ios-spring), box-shadow 0.4s ease;
  }

  .contact-card:hover .contact-avatar {
    transform: scale(1.05);
    box-shadow: 0 12px 40px color-mix(in srgb, var(--color-primary) 45%, transparent);
  }

  .contact-avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid white;
  }

  .contact-status {
    position: absolute;
    bottom: 0;
    right: calc(50% - 44px);
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-success);
    border: 3px solid white;
  }

  .status-ping {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--color-success);
    animation: status-pulse 2s ease-out infinite;
  }

  @keyframes status-pulse {
    0% { 
      transform: scale(1);
      opacity: 0.8;
    }
    100% { 
      transform: scale(2.5);
      opacity: 0;
    }
  }

  /* Card Text */
  .contact-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    margin-bottom: 10px;
  }

  .contact-description {
    font-size: var(--text-md);
    line-height: 1.6;
    color: var(--text-secondary);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  /* Contact Actions */
  .contact-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .contact-cta {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px var(--space-6);
    border-radius: var(--radius-xl);
    font-size: var(--text-md);
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.4s var(--ease-ios-spring), background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    overflow: hidden;
  }

  .contact-cta-primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-primary) 40%, transparent);
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    background-size: 200% 100%;
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% { background-position: 200% 0; }
    50% { background-position: -200% 0; }
  }

  .cta-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .contact-cta-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 28px color-mix(in srgb, var(--color-primary) 50%, transparent);
  }

  .contact-cta-secondary {
    background: rgba(0, 0, 0, 0.04);
    color: var(--text-primary);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .contact-cta-secondary:hover {
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    color: var(--color-primary);
    border-color: color-mix(in srgb, var(--color-primary) 20%, transparent);
    transform: translateY(-2px);
  }

  /* Trust Indicators */
  .contact-trust {
    border-top: 1px solid var(--separator);
    padding-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-success);
  }

  .trust-icon {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-success) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .trust-item span {
    color: var(--text-secondary);
  }

  /* ========== Responsive ========== */
  @media (max-width: 1024px) {
    .faq-layout {
      grid-template-columns: 1fr;
      gap: var(--space-16);
    }

    .contact-card {
      position: static;
      max-width: 480px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .faq-section {
      padding: var(--section-py-mobile) 0;
    }

    .faq-header {
      margin-bottom: var(--space-16);
    }

    .faq-title {
      font-size: var(--text-5xl);
    }

    .faq-subtitle {
      font-size: var(--text-xl);
    }

    .faq-summary {
      padding: var(--space-5);
    }

    .faq-summary-content {
      gap: var(--space-3);
    }

    .faq-question {
      font-size: var(--text-lg);
    }

    .faq-body-inner {
      padding: 0 var(--space-5) var(--space-5) 62px;
    }

    .contact-card-content {
      padding: 36px var(--space-6) var(--space-8);
    }

    .contact-avatar {
      width: 84px;
      height: 84px;
    }
  }

  @media (max-width: 480px) {
    .faq-title {
      font-size: var(--text-4xl);
    }

    .faq-number {
      font-size: var(--text-xs);
      min-width: 24px;
    }

    .faq-icon-bg {
      width: 32px;
      height: 32px;
    }

    .faq-chevron {
      width: 14px;
      height: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-eyebrow-dot {
      animation: none !important;
    }

    .faq-item {
      transition: background 0.2s ease !important;
    }

    .faq-body,
    .faq-answer,
    .faq-icon-bg,
    .faq-chevron {
      transition: none !important;
    }

    .contact-card:hover {
      transform: none;
    }

    .contact-avatar,
    .cta-bg {
      animation: none !important;
    }

    .status-ping::after {
      animation: none !important;
    }

    .faq-item.is-open .faq-body {
      grid-template-rows: 1fr;
      opacity: 1;
    }

    .faq-answer {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>

<script>
  // FAQ Accordion — smooth grid-template-rows animation
  document.querySelectorAll('.faq-item').forEach((item, index) => {
    const summary = item.querySelector('.faq-summary');
    const body = item.querySelector('.faq-body');

    // Staggered entrance animation
    item.style.opacity = '0';
    item.style.transform = 'translateY(30px) scale(0.98)';
    setTimeout(() => {
      item.style.transition = 'opacity 0.6s var(--ease-ios-decel), transform 0.6s var(--ease-ios-spring), background 0.4s ease, box-shadow 0.4s ease';
      item.style.opacity = '1';
      item.style.transform = 'translateY(0) scale(1)';
    }, index * 100);

    summary?.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = item.classList.contains('is-open');

      // Close other items
      document.querySelectorAll('.faq-item.is-open').forEach(openItem => {
        if (openItem !== item) {
          openItem.classList.remove('is-open');
          // Remove [open] after CSS transition finishes
          const onTransitionEnd = (ev) => {
            if (ev.target === openItem.querySelector('.faq-body')) {
              openItem.removeAttribute('open');
              openItem.removeEventListener('transitionend', onTransitionEnd);
            }
          };
          openItem.addEventListener('transitionend', onTransitionEnd);
          // Fallback: remove after 550ms if transitionend doesn't fire
          setTimeout(() => {
            openItem.removeAttribute('open');
            openItem.removeEventListener('transitionend', onTransitionEnd);
          }, 550);
        }
      });

      if (isOpen) {
        item.classList.remove('is-open');
        const onTransitionEnd = (ev) => {
          if (ev.target === body) {
            item.removeAttribute('open');
            item.removeEventListener('transitionend', onTransitionEnd);
          }
        };
        item.addEventListener('transitionend', onTransitionEnd);
        setTimeout(() => {
          item.removeAttribute('open');
          item.removeEventListener('transitionend', onTransitionEnd);
        }, 550);
      } else {
        item.setAttribute('open', '');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            item.classList.add('is-open');
          });
        });
      }
    });
  });

  // Contact card 3D tilt effect (desktop only)
  const contactCard = document.querySelector('[data-contact-card]');
  if (contactCard && !window.matchMedia('(pointer: coarse)').matches) {
    contactCard.addEventListener('mousemove', (e) => {
      const rect = contactCard.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      const rotateX = (y - centerY) / centerY * -4;
      const rotateY = (x - centerX) / centerX * 4;

      (contactCard).style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
    });

    contactCard.addEventListener('mouseleave', () => {
      (contactCard).style.transform = '';
    });
  }
</script>