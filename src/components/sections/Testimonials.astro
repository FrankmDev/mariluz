---
// NOTA: Estos son testimonios de ejemplo. Reemplazar con datos reales de clientes.
const testimonials = [
  {
    name: 'María G.',
    location: 'Madrid',
    saving: 280,
    quote: 'Me sorprendió lo rápido que fue todo. En unos días ya tenía la nueva tarifa activa y ahora pago menos por la misma luz.',
    initials: 'MG',
    color: 'var(--color-secondary)',
    bg: 'linear-gradient(135deg, var(--color-secondary), #8B5CF6)',
  },
  {
    name: 'Carlos R.',
    location: 'Barcelona',
    saving: 340,
    quote: 'Tenía una tarifa antigua de hace años y no sabía que podía ahorrar tanto. El proceso fue súper sencillo, ella se encargó de todo.',
    initials: 'CR',
    color: 'var(--color-primary)',
    bg: 'linear-gradient(135deg, var(--color-primary), #0051D5)',
  },
  {
    name: 'Laura M.',
    location: 'Valencia',
    saving: 195,
    quote: 'Al principio dudaba, pero vi que no había permanencia ni costes. Ahora recomiendo a todo el mundo que revise su tarifa.',
    initials: 'LM',
    color: 'var(--color-success)',
    bg: 'linear-gradient(135deg, var(--color-success), #248A3D)',
  },
];

const featuredTestimonial = {
  name: 'Antonio P.',
  location: 'Sevilla',
  role: 'Autónomo',
  saving: 890,
  quote: 'Tengo un pequeño taller y la factura de la luz era una preocupación constante. Mariluz estudió mis horarios de consumo y me cambió a una tarifa que se adapta a mi actividad. Ahora ahorro casi 75€ al mes, que al final del año es un dinero importante para mi negocio. Totalmente recomendable.',
  initials: 'AP',
};
---

<section class="section">
  <div class="container-custom">

    <!-- Section Header -->
    <div class="text-center reveal" style="margin-bottom: var(--space-16);">
      <span class="badge" style="margin-bottom: var(--space-5); display: inline-flex;">Testimonios</span>
      <h2 class="text-large-title" style="color: var(--text-primary); margin-bottom: var(--space-4);">
        Lo que dicen mis clientes.
      </h2>
      <p class="text-body-large" style="color: var(--text-secondary);">
        Resultados reales de quienes confiaron en mi asesoría.
      </p>
    </div>

    <!-- Social proof bar -->
    <div class="reveal social-proof-bar" style="transition-delay: 80ms; margin-bottom: var(--space-16);">
      <div class="proof-item">
        <div style="display: flex; gap: 2px; justify-content: center; margin-bottom: 6px;">
          <span style="color: var(--color-accent); font-size: var(--text-md);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-md);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-md);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-md);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-md);">★</span>
        </div>
        <span class="text-numeric" style="font-size: var(--text-4xl); font-weight: 800; color: var(--text-primary); letter-spacing: -0.03em;">4.9</span>
        <p class="text-caption" style="color: var(--text-secondary);">Valoración media</p>
      </div>
      <div class="proof-sep"></div>
      <div class="proof-item">
        <span class="text-numeric" style="font-size: var(--text-4xl); font-weight: 800; color: var(--text-primary); letter-spacing: -0.03em;">450+</span>
        <p class="text-caption" style="color: var(--text-secondary);">Clientes satisfechos</p>
      </div>
      <div class="proof-sep"></div>
      <div class="proof-item">
        <span class="text-numeric" style="font-size: var(--text-4xl); font-weight: 800; color: var(--color-success); letter-spacing: -0.03em;">280€</span>
        <p class="text-caption" style="color: var(--text-secondary);">Ahorro medio anual</p>
      </div>
      <div class="proof-sep"></div>
      <div class="proof-item">
        <span class="text-numeric" style="font-size: var(--text-4xl); font-weight: 800; color: var(--color-primary); letter-spacing: -0.03em;">98%</span>
        <p class="text-caption" style="color: var(--text-secondary);">Recomendarían el servicio</p>
      </div>
    </div>

    <!-- Featured Testimonial -->
    <div class="reveal featured-testimonial" style="transition-delay: 160ms; margin-bottom: var(--space-8);">
      <!-- Quote icon -->
      <div class="featured-quote-icon" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>
      </div>

      <div class="featured-content">
        <div style="display: flex; gap: 2px; margin-bottom: var(--space-5);">
          <span style="color: var(--color-accent); font-size: var(--text-lg);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-lg);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-lg);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-lg);">★</span>
          <span style="color: var(--color-accent); font-size: var(--text-lg);">★</span>
        </div>
        <blockquote class="text-title-2" style="color: var(--text-primary); line-height: 1.5; font-weight: 400; font-style: italic; margin-bottom: var(--space-6); max-width: 700px;">
          "{featuredTestimonial.quote}"
        </blockquote>
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--space-4);">
          <div style="display: flex; align-items: center; gap: 14px;">
            <div class="avatar avatar-md" style="background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent) 100%); color: white; font-size: var(--text-md); font-weight: 700; width: 52px; height: 52px;">
              {featuredTestimonial.initials}
            </div>
            <div>
              <p class="text-headline" style="color: var(--text-primary); font-weight: 700;">{featuredTestimonial.name}</p>
              <p class="text-footnote" style="color: var(--text-secondary);">{featuredTestimonial.role} · {featuredTestimonial.location}</p>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 8px; background: var(--ios-green-light); border: 1px solid rgba(52,199,89,0.2); border-radius: var(--radius-pill); padding: 10px 20px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-success)" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            <span style="font-size: var(--text-md); font-weight: 800; color: var(--color-success); font-family: var(--font-display);">+{featuredTestimonial.saving}€/año</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Testimonials Grid -->
    <div class="testimonials-grid">
      {testimonials.map((t, index) => (
        <div
          class="reveal card"
          style={`padding: var(--space-6); display: flex; flex-direction: column; gap: 18px; border-radius: var(--radius-3xl); transition-delay: ${index * 120 + 280}ms; position: relative; overflow: hidden;`}
        >
          <!-- Stars -->
          <div style="display: flex; gap: 2px; color: var(--color-accent);" aria-label="5 estrellas">
            {[...Array(5)].map(() => (
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-body" style="color: var(--text-primary); flex: 1; line-height: 1.65; font-style: italic; overflow-wrap: break-word;">
            "{t.quote}"
          </blockquote>

          <div class="divider" style="background: rgba(0,0,0,0.06);"></div>

          <!-- Author -->
          <div style="display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);">
            <div style="display: flex; align-items: center; gap: var(--space-3);">
              <div
                class="avatar avatar-md"
                style={`background: ${t.bg}; color: white; font-weight: 700;`}
                aria-hidden="true"
              >
                {t.initials}
              </div>
              <div>
                <p class="text-subhead" style="color: var(--text-primary); font-weight: 600;">{t.name}</p>
                <p class="text-footnote" style="color: var(--text-secondary);">{t.location}</p>
              </div>
            </div>
            <div class="badge badge-green" style="flex-shrink: 0; padding: 6px 12px; font-size: var(--text-sm);">
              +{t.saving}€
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .social-proof-bar {
    display: grid;
    grid-template-columns: 1fr 1px 1fr 1px 1fr 1px 1fr;
    align-items: center;
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-2xl);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    position: relative;
  }

  .social-proof-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
    z-index: 1;
  }

  .proof-item {
    padding: var(--space-6) var(--space-5);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
  }

  .proof-sep {
    background: var(--separator);
    height: 100%;
    width: 1px;
    min-height: 60px;
  }

  .featured-testimonial {
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-3xl);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    padding: var(--space-12);
    position: relative;
    overflow: hidden;
  }

  .featured-testimonial::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    border-radius: var(--radius-3xl) var(--radius-3xl) 0 0;
    z-index: 1;
  }

  .featured-content {
    position: relative;
    z-index: 2;
  }

  .featured-quote-icon {
    color: var(--separator);
    margin-bottom: var(--space-5);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .card {
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.98),
      inset 0 -1px 0 rgba(0, 0, 0, 0.025),
      0 4px 6px rgba(0, 0, 0, 0.04),
      0 12px 40px rgba(0, 0, 0, 0.09),
      0 32px 80px rgba(0, 0, 0, 0.06);
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(255, 255, 255, 0.40) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    border-radius: var(--radius-3xl) var(--radius-3xl) 0 0;
    z-index: 1;
  }

  .card > * {
    position: relative;
    z-index: 2;
  }

  @media (max-width: 900px) {
    .social-proof-bar {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1px 1fr;
    }

    .proof-sep:first-of-type {
      display: none;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin: 0 auto;
    }

    .featured-testimonial {
      padding: 32px var(--space-6);
    }
  }

  @media (max-width: 600px) {
    .social-proof-bar {
      grid-template-columns: 1fr 1fr;
    }
    .proof-sep {
      display: none;
    }
  }
</style>
