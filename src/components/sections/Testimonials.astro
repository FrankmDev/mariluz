---
const cases = [
  {
    name: 'Cliente particular',
    location: 'Córdoba',
    profile: 'Vivienda familiar',
    before: 'No tenía claro si la potencia contratada era adecuada',
    detected: 'Potencia por encima del uso habitual',
    action: 'Revisión de potencia, consumo y condiciones actuales',
    result: 'Decisión tomada con explicación previa',
    saving: 'Caso resumido y anonimizado',
  },
  {
    name: 'Cliente particular',
    location: 'Córdoba',
    profile: 'Piso habitual',
    before: 'Tarifa sin revisar desde hacía tiempo',
    detected: 'Precio y condiciones mejorables según consumo',
    action: 'Comparación de alternativa y explicación de permanencia',
    result: 'Cambio autorizado solo después de entender condiciones',
    saving: 'Sin corte de suministro ni cambio de instalación',
  },
  {
    name: 'Cliente particular',
    location: 'Córdoba',
    profile: 'Casa unifamiliar',
    before: 'No entendía los conceptos principales',
    detected: 'Dudas en potencia, horarios y servicios asociados',
    action: 'Lectura completa de factura y revisión de servicios añadidos',
    result: 'Factura más comprensible antes de decidir nada',
    saving: 'Revisión orientada a claridad, no a venta rápida',
  },
];
---

<section id="testimonios" class="cases-section" aria-label="Casos de revisión anonimizados">
  <div class="cases-container">
    <header class="cases-header reveal">
      <p>Casos anonimizados</p>
      <h2>No se promete mejora. Se comprueba si existe margen real.</h2>
    </header>

    <div class="case-carousel reveal" data-case-carousel>
      <div class="case-portrait-stack" aria-hidden="true">
        <div class="portrait portrait-a"></div>
        <div class="portrait portrait-b"></div>
        <div class="portrait portrait-c"></div>
      </div>

      <div class="case-slides">
        {cases.map((item, index) => (
          <article class={`case-slide ${index === 0 ? 'is-active' : ''}`} data-case-slide={index}>
            <div class="case-specular"></div>
            <div class="case-content">
              <div class="case-person">
                <span>{item.name}</span>
                <small>{item.profile} · {item.location}</small>
              </div>
              <div class="case-grid">
                <div>
                  <span>Situación</span>
                  <p>{item.before}</p>
                </div>
                <div>
                  <span>Detectado</span>
                  <p>{item.detected}</p>
                </div>
                <div>
                  <span>Trabajo realizado</span>
                  <p>{item.action}</p>
                </div>
                <div>
                  <span>Resultado</span>
                  <p>{item.result}</p>
                </div>
              </div>
              <div class="case-saving">{item.saving}</div>
            </div>
          </article>
        ))}
      </div>

      <div class="case-controls" aria-label="Controles de casos">
        <button type="button" class="case-control" data-case-prev aria-label="Caso anterior">‹</button>
        <div class="case-dots" aria-hidden="true">
          {cases.map((_, index) => (
            <span class={index === 0 ? 'is-active' : ''} data-case-dot={index}></span>
          ))}
        </div>
        <button type="button" class="case-control" data-case-next aria-label="Caso siguiente">›</button>
      </div>

      <p class="case-note">
        Casos resumidos y anonimizados. Cada factura depende de consumo, potencia, tarifa y condiciones reales.
      </p>
    </div>
  </div>
</section>

<style>
  .cases-section {
    position: relative;
    padding: var(--section-py) var(--space-6);
    overflow: hidden;
  }

  .cases-container {
    width: min(1160px, 100%);
    margin: 0 auto;
  }

  .cases-header {
    display: grid;
    grid-template-columns: 0.34fr 1fr;
    gap: clamp(28px, 6vw, 76px);
    align-items: end;
    margin-bottom: var(--space-12);
  }

  .cases-header p {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 800;
  }

  .cases-header h2 {
    margin: 0;
    max-width: 900px;
    color: var(--text-primary);
    font-size: clamp(2.2rem, 4.4vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.048em;
    font-weight: 800;
  }

  .case-carousel {
    position: relative;
    display: grid;
    grid-template-columns: 0.38fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }

  .case-portrait-stack {
    position: relative;
    min-height: 420px;
  }

  .portrait {
    position: absolute;
    width: 72%;
    aspect-ratio: 3 / 4;
    border-radius: 30px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    filter: grayscale(0.15) contrast(1.08) saturate(0.88);
    box-shadow: var(--shadow-glass);
    border: 1px solid rgba(255,255,255,0.58);
  }

  .portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.1), rgba(0,122,255,0.18));
    mix-blend-mode: soft-light;
  }

  .portrait-a {
    left: 0;
    top: 24px;
    background-image: url('https://picsum.photos/seed/luzaria-factura-casa/700/900');
    transform: rotate(-5deg);
  }

  .portrait-b {
    right: 6px;
    top: 108px;
    background-image: url('https://picsum.photos/seed/luzaria-recibo-luz/700/900');
    transform: rotate(4deg);
  }

  .portrait-c {
    left: 14%;
    bottom: 10px;
    background-image: url('https://picsum.photos/seed/luzaria-asesoria/700/900');
    transform: rotate(-1deg);
  }

  .case-slides {
    position: relative;
    min-height: 440px;
  }

  .case-slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    border-radius: 28px;
    background: rgba(255,255,255,0.72);
    border: 1px solid rgba(255,255,255,0.58);
    backdrop-filter: blur(44px) saturate(210%) brightness(1.03);
    -webkit-backdrop-filter: blur(44px) saturate(210%) brightness(1.03);
    box-shadow: var(--shadow-glass);
    opacity: 0;
    transform: translateY(24px) scale(0.98);
    pointer-events: none;
    transition: opacity 0.45s var(--ease-ios), transform 0.55s var(--ease-ios-spring);
  }

  .case-slide.is-active {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .case-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 55%;
    background: linear-gradient(180deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.36) 42%, transparent 100%);
    pointer-events: none;
  }

  .case-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: clamp(26px, 4vw, 42px);
    display: flex;
    flex-direction: column;
  }

  .case-person span {
    display: block;
    color: var(--text-primary);
    font-size: clamp(1.55rem, 2.4vw, 2.15rem);
    line-height: 1;
    letter-spacing: -0.05em;
    font-weight: 800;
  }

  .case-person small {
    display: block;
    margin-top: 8px;
    color: var(--text-secondary);
    font-size: var(--text-base);
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-7);
  }

  .case-grid div {
    min-height: 104px;
    padding: 16px;
    border-radius: 20px;
    background: rgba(255,255,255,0.54);
    border: 1px solid rgba(255,255,255,0.64);
  }

  .case-grid span {
    color: var(--ios-blue);
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .case-grid p {
    margin: var(--space-2) 0 0;
    color: var(--text-secondary);
    line-height: 1.48;
  }

  .case-saving {
    align-self: flex-start;
    margin-top: auto;
    padding: 12px 16px;
    border-radius: var(--radius-pill);
    color: var(--ios-green);
    background: rgba(238,255,245,0.78);
    border: 1px solid rgba(255,255,255,0.58);
    font-weight: 800;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.88);
  }

  .case-controls {
    grid-column: 2;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-4);
  }

  .case-control {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255,255,255,0.58);
    border-radius: 50%;
    color: var(--text-primary);
    background: rgba(255,255,255,0.68);
    backdrop-filter: blur(22px) saturate(170%);
    -webkit-backdrop-filter: blur(22px) saturate(170%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
  }

  .case-dots {
    display: flex;
    gap: 8px;
  }

  .case-dots span {
    width: 8px;
    height: 8px;
    border-radius: 99px;
    background: rgba(0,0,0,0.18);
    transform: scaleX(1);
    transition: transform 0.3s var(--ease-ios), background 0.3s var(--ease-ios);
  }

  .case-dots span.is-active {
    transform: scaleX(3);
    background: var(--ios-blue);
  }

  .case-note {
    grid-column: 2;
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    line-height: 1.5;
    text-align: right;
  }

  @media (max-width: 920px) {
    .cases-header,
    .case-carousel {
      grid-template-columns: 1fr;
    }

    .case-portrait-stack {
      display: none;
    }

    .case-controls,
    .case-note {
      grid-column: auto;
    }
  }

  @media (max-width: 640px) {
    .cases-section {
      padding: var(--section-py-mobile) var(--space-5);
    }

    .case-slides {
      min-height: 640px;
    }

    .case-grid {
      grid-template-columns: 1fr;
    }

    .case-controls {
      justify-content: center;
    }

    .case-note {
      text-align: center;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-case-carousel]');
  if (root) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-case-slide]'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-case-dot]'));
    const prev = root.querySelector<HTMLButtonElement>('[data-case-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-case-next]');
    let current = 0;

    const setSlide = (index: number) => {
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => slide.classList.toggle('is-active', i === current));
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === current));
    };

    prev?.addEventListener('click', () => setSlide(current - 1));
    next?.addEventListener('click', () => setSlide(current + 1));
  }
</script>
