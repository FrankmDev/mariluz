<script>
  // CountUp — reveal handled by Layout.astro's global IntersectionObserver
  const countUp = (el: HTMLElement) => {
    const target = parseInt(el.dataset.target ?? '0');
    const start = performance.now();
    const tick = (now: number) => {
      const p = Math.min((now - start) / 1600, 1);
      const ease = 1 - Math.pow(1 - p, 4);
      el.textContent = String(Math.floor(ease * target));
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll<HTMLElement>('.counter').forEach((c, i) => {
        if (!c.classList.contains('done')) {
          setTimeout(() => { c.classList.add('done'); countUp(c); }, i * 120);
        }
      });
    });
  }, { threshold: 0.25 });

  document.querySelectorAll('.stats-wrap, .float-card').forEach(el => io.observe(el));

  // Parallax effect on mouse move
  const hero = document.getElementById('hero');
  const cards = document.querySelectorAll('.float-card');
  let rafId: number | null = null;
  let mouseX = 0;
  let mouseY = 0;

  if (hero && !window.matchMedia('(pointer: coarse)').matches) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width - 0.5;
      mouseY = (e.clientY - rect.top) / rect.height - 0.5;

      if (!rafId) {
        rafId = requestAnimationFrame(() => {
          cards.forEach((card, index) => {
            const depth = (index + 1) * 8;
            const moveX = mouseX * depth * -1;
            const moveY = mouseY * depth * -1;
            (card as HTMLElement).style.setProperty('--parallax-x', `${moveX}px`);
            (card as HTMLElement).style.setProperty('--parallax-y', `${moveY}px`);
          });
          rafId = null;
        });
      }
    });
  }
</script>
