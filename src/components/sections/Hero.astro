---
import { siteConfig } from '../../config/site';
import { MessageCircle, Clock } from 'lucide-astro';
import LiquidAction from '../ui/LiquidAction.astro';
---

<section class="hero" aria-label="Revisión gratuita de tu factura de luz" id="hero" itemscope itemtype="https://schema.org/WebPageElement">

  <!-- Floating Cards — premium Liquid Glass dashboard widgets -->
  <div class="card-wrapper" data-card="1" aria-hidden="true">
    <div class="float-card card-1">
      <div class="card-specular"></div>
      <div class="card-inner">
        <div class="card-header">
          <div class="icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="card-title-wrap">
            <p class="card-title">Factura recibida</p>
            <p class="card-sub">lectura en curso</p>
          </div>
          <div class="pulse-dot"></div>
        </div>
        <div class="review-summary">
          <div class="summary-status">
            <span class="summary-label">Análisis inicial</span>
            <span class="summary-badge">24 h</span>
          </div>
          <div class="summary-scope">
            <span>Tarifa</span>
            <span>Potencia</span>
            <span>Extras</span>
          </div>
          <p class="summary-note">Recibes una explicación antes de tocar nada</p>
        </div>
      </div>
    </div>
  </div>

  <div class="card-wrapper" data-card="2" aria-hidden="true">
    <div class="float-card card-2">
      <div class="card-specular"></div>
      <div class="card-inner">
        <div class="card-header">
          <div class="icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div class="card-title-wrap">
            <p class="card-title">Coste por kWh</p>
            <p class="card-sub">actual vs alternativa</p>
          </div>
        </div>
        <div class="comparison-chart">
          <div class="comp-row">
            <span class="comp-label">Factura</span>
            <div class="comp-bar-wrap"><div class="comp-bar comp-bar-old"></div></div>
            <span class="comp-val">0,178€</span>
          </div>
          <div class="comp-row">
            <span class="comp-label accent">Alternativa</span>
            <div class="comp-bar-wrap"><div class="comp-bar comp-bar-new"></div></div>
            <span class="comp-val accent">0,151€</span>
          </div>
        </div>
        <div class="comp-footer">
          <span class="savings-pill">Brecha revisada: 2,7 cts/kWh</span>
        </div>
      </div>
    </div>
  </div>

  <div class="card-wrapper" data-card="3" aria-hidden="true">
    <div class="float-card card-3">
      <div class="card-specular"></div>
      <div class="card-inner">
        <div class="card-header">
          <div class="icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div class="card-title-wrap">
            <p class="card-title">Revisión de factura</p>
            <p class="card-sub">puntos que sí importan</p>
          </div>
        </div>
        <div class="review-panel">
          <div class="review-row">
            <span class="review-dot review-dot-blue" aria-hidden="true"></span>
            <div class="review-copy">
              <span class="review-label">Potencia</span>
              <span class="review-value">4,6 kW contratados</span>
            </div>
            <span class="review-status">ajustar</span>
          </div>
          <div class="review-row">
            <span class="review-dot review-dot-green" aria-hidden="true"></span>
            <div class="review-copy">
              <span class="review-label">Condiciones</span>
              <span class="review-value">extras y permanencia</span>
            </div>
            <span class="review-status">ver</span>
          </div>
        </div>
        <div class="activity-total">
          <span>Propuesta solo si compensa</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero content -->
  <div class="content">

    <div class="reveal stagger-1">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        <span class="eyebrow-text">Revisión de factura</span>
        <span class="eyebrow-sep"></span>
        <span class="eyebrow-free">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
          Revisión inicial
        </span>
      </div>
    </div>

    <h1 class="headline reveal stagger-2" itemprop="headline">
      <span class="line line-1">Analizo tu factura.</span>
      <span class="line line-accent">Decides con datos.</span>
    </h1>

    <p class="subhead reveal stagger-3">
      Reviso tu factura y te digo, con datos, si conviene cambiar algo.
      <strong>Sin cambios automáticos.</strong>
    </p>

    <div class="cta-group reveal stagger-4">
      <LiquidAction
        href="#contacto"
        class="cta-btn"
        ariaLabel="Enviar factura para estudio gratuito"
        bgClass="cta-btn-bg"
      >
        <MessageCircle size={20} fill="currentColor" style="position:relative;z-index:1" aria-hidden="true" />
        <span style="position:relative;z-index:1">Enviar factura</span>
      </LiquidAction>
      <p class="cta-note">
        <Clock size={12} aria-hidden="true" />
        Respuesta habitual en 24 h
      </p>
    </div>

    <div class="trust reveal stagger-5">
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M20 6L9 17l-5-5"/></svg>
        Sin cambio automático
      </span>
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Datos cifrados
      </span>
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        Tú decides
      </span>
      <span class="pill pill-gold">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Sin coste inicial
      </span>
    </div>
  </div>

</section>

<style>
  /* ─── Hero shell ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100px var(--space-6);
    overflow: hidden;
    /* No background - using global background from Layout */
  }

  /* ─── Floating Cards ─────────────────────────────────────────── */
  .card-wrapper {
    position: absolute;
    z-index: 2;
    display: none;
    will-change: transform;
    transition: transform var(--duration-normal) var(--ease-ios);
  }
  [data-card="1"] { left: 4%; top: 26%; }
  [data-card="2"] { right: 4%; top: 22%; }
  [data-card="3"] { left: 5%; top: 56%; }
  @media (min-width: 1100px) { .card-wrapper { display: block; } }

  .card-wrapper:hover {
    z-index: 10;
  }

  .card-wrapper:hover .float-card {
    transform: translateY(-7px) scale(1.012);
    box-shadow: var(--shadow-glass-hover);
  }

  .float-card {
    width: 260px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-glass);
    transition: transform 0.5s var(--ease-ios-spring), box-shadow 0.4s var(--ease-ios), background 0.35s var(--ease-ios);
    will-change: transform;
    position: relative;
  }

  .float-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease-ios);
  }

  .card-wrapper:hover .float-card::after {
    opacity: 1;
  }

  /* Color tint per card */
  .card-1 { background: rgba(238, 255, 245, 0.72); }
  .card-2 { background: rgba(236, 246, 255, 0.72); }
  .card-3 { background: rgba(243, 240, 255, 0.72); }

  /* Individual float animations */
  .card-1 {
    animation: float1 6s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards;
    animation-delay: 0s, 0.6s;
    opacity: 0;
  }
  .card-2 {
    animation: float2 7s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards;
    animation-delay: -2s, 0.75s;
    opacity: 0;
  }
  .card-3 {
    animation: float3 8s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards;
    animation-delay: -4s, 0.9s;
    opacity: 0;
  }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes float1 {
    0%, 100% { transform: translateY(0) translateX(0); }
    25% { transform: translateY(-6px) translateX(3px); }
    50% { transform: translateY(-3px) translateX(-2px); }
    75% { transform: translateY(-8px) translateX(2px); }
  }

  @keyframes float2 {
    0%, 100% { transform: translateY(0) translateX(0); }
    33% { transform: translateY(-8px) translateX(-3px); }
    66% { transform: translateY(-4px) translateX(2px); }
  }

  @keyframes float3 {
    0%, 100% { transform: translateY(0) translateX(0); }
    20% { transform: translateY(-5px) translateX(2px); }
    40% { transform: translateY(-9px) translateX(-2px); }
    60% { transform: translateY(-4px) translateX(3px); }
    80% { transform: translateY(-7px) translateX(-1px); }
  }

  /* Specular highlight */
  .card-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 55%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.45) 35%,
      rgba(255, 255, 255, 0.08) 65%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 1;
    opacity: 0.85;
  }

  /* Card content */
  .card-inner {
    position: relative;
    z-index: 2;
    padding: var(--space-4);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .icon {
    width: 36px; height: 36px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(0,122,255,0.12) 0%, rgba(0,122,255,0.06) 100%);
    backdrop-filter: blur(10px) saturate(160%);
    -webkit-backdrop-filter: blur(10px) saturate(160%);
    border: 1px solid rgba(0,122,255,0.18);
    color: var(--color-primary);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.65),
      0 2px 6px rgba(0,122,255,0.12),
      0 4px 12px rgba(0,122,255,0.06);
    transition: all var(--duration-normal) var(--ease-ios-spring);
  }

  .icon::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(255,255,255,0.55) 0%, transparent 50%);
    pointer-events: none;
  }

  .card-wrapper:hover .icon {
    transform: scale(1.12) rotate(-3deg);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.85),
      0 4px 14px rgba(0,122,255,0.22),
      0 8px 24px rgba(0,122,255,0.12);
    border-color: rgba(0,122,255,0.28);
  }

  .card-wrapper:hover .icon svg {
    animation: icon-bounce 0.5s var(--ease-ios-spring);
  }

  @keyframes icon-bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .card-1,
    .card-2,
    .card-3,
    .pulse-dot,
    .cta-btn-bg {
      animation: none !important;
      opacity: 1;
    }

    .card-wrapper:hover .float-card,
    .card-wrapper:hover .icon,
    .card-wrapper:hover .icon svg {
      transform: none;
    }
  }

  .card-title-wrap { flex: 1; min-width: 0; }

  .card-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin: 0;
    line-height: var(--leading-none);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-sub {
    font-size: var(--text-xs);
    color: var(--text-quaternary);
    margin: 2px 0 0;
  }

  .pulse-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 100%);
    flex-shrink: 0;
    position: relative;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.50),
      0 0 0 0 rgba(0,122,255,0.45);
    animation: pulse-glass 2.2s ease-in-out infinite;
  }

  .pulse-dot::before {
    content: '';
    position: absolute;
    top: 1px; left: 1px; right: 1px; bottom: 1px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255,255,255,0.65) 0%, transparent 50%);
    pointer-events: none;
  }

  @keyframes pulse-glass {
    0%, 100% {
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.50),
        0 0 0 0 rgba(0,122,255,0.45);
    }
    50% {
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.50),
        0 0 0 8px rgba(0,122,255,0);
    }
  }

  /* Card-1: Review summary */
  .review-summary {
    display: grid;
    gap: 10px;
    padding: 12px;
    background: linear-gradient(135deg, rgba(0,122,255,0.06) 0%, rgba(0,122,255,0.02) 100%);
    border-radius: var(--radius-md);
    border: 1px solid rgba(0,122,255,0.08);
    position: relative;
    overflow: hidden;
  }

  .review-summary::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.40) 0%, transparent 100%);
    pointer-events: none;
  }

  .summary-status,
  .summary-scope,
  .summary-note {
    position: relative;
    z-index: 1;
  }

  .summary-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .summary-label {
    color: var(--text-primary);
    font-size: 1.02rem;
    font-weight: var(--font-extrabold);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .summary-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    background: linear-gradient(135deg, rgba(52,199,89,0.14) 0%, rgba(52,199,89,0.07) 100%);
    color: var(--color-success);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    padding: 3px 8px;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(52,199,89,0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.45);
  }

  .summary-badge::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
  }

  .summary-scope {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
  }

  .summary-scope span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 28px;
    border-radius: 12px;
    background: rgba(255,255,255,0.46);
    border: 1px solid rgba(255,255,255,0.48);
    color: var(--text-secondary);
    font-size: 0.68rem;
    font-weight: var(--font-semibold);
  }

  .summary-note {
    margin: 0;
    color: var(--text-tertiary);
    font-size: 0.72rem;
    line-height: 1.35;
  }

  /* Card-2: Comparison chart */
  .comparison-chart { margin-bottom: var(--space-3); }

  .comp-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .comp-row:last-child { margin-bottom: 0; }

  .comp-label {
    font-size: var(--text-xs);
    color: var(--text-quaternary);
    width: 64px;
    flex-shrink: 0;
  }
  .comp-label.accent { color: var(--color-primary); font-weight: var(--font-semibold); }

  .comp-bar-wrap {
    flex: 1;
    height: 7px;
    background: rgba(0,0,0,0.04);
    border-radius: var(--radius-pill);
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.05);
  }

  .comp-bar {
    height: 100%;
    border-radius: var(--radius-pill);
    position: relative;
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
  }

  .comp-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.30) 0%, transparent 100%);
    border-radius: var(--radius-pill) var(--radius-pill) 0 0;
  }

  .comp-bar-old {
    width: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.10) 0%, rgba(0,0,0,0.05) 100%);
  }

  .comp-bar-new {
    width: 78%;
    background: linear-gradient(90deg, var(--blue-600) 0%, var(--color-primary) 50%, var(--cyan-400) 100%);
    animation: barGrow 1.2s ease-out forwards;
    transform-origin: left;
  }

  @keyframes barGrow {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .comp-val {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    width: 58px;
    text-align: right;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
  .comp-val.accent { color: var(--color-primary); font-weight: var(--font-bold); }

  .comp-footer {
    display: flex;
    justify-content: flex-start;
  }

  .savings-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: linear-gradient(135deg, rgba(0,122,255,0.12) 0%, rgba(0,122,255,0.05) 100%);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    color: var(--color-primary);
    max-width: 100%;
    font-size: 0.6875rem;
    font-weight: var(--font-semibold);
    line-height: 1.2;
    padding: 5px 10px;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(0,122,255,0.18);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.55),
      0 2px 6px rgba(0,122,255,0.10);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-ios-spring);
  }

  .savings-pill::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.45) 0%, transparent 100%);
    border-radius: var(--radius-pill) var(--radius-pill) 0 0;
    pointer-events: none;
  }

  .card-wrapper:hover .savings-pill {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.65),
      0 3px 10px rgba(0,122,255,0.12);
  }

  /* Card-3: Technical review */
  .review-panel {
    display: grid;
    gap: 6px;
    margin-bottom: var(--space-2);
  }

  .review-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 9px 10px;
    border-radius: 15px;
    background: rgba(255,255,255,0.44);
    border: 1px solid rgba(255,255,255,0.46);
  }

  .review-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.64);
  }

  .review-dot-blue { background: var(--color-primary); }
  .review-dot-green { background: var(--color-success); }

  .review-copy {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .review-label {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-value {
    font-size: 11px;
    color: var(--text-tertiary);
    font-weight: var(--font-medium);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-status {
    padding: 3px 7px;
    border-radius: var(--radius-pill);
    background: rgba(255,255,255,0.62);
    border: 1px solid rgba(255,255,255,0.56);
    color: var(--text-secondary);
    font-size: 9px;
