---
import { siteConfig } from '../../config/site';
---

<section class="hero" aria-label="Presentación" id="hero">

  <!-- Layered background atmosphere -->
  <div class="orbs" aria-hidden="true">
    <div class="orb orb-blue"></div>
    <div class="orb orb-cyan"></div>
    <div class="orb orb-green"></div>
    <div class="orb orb-purple"></div>
  </div>

  <!-- Floating Cards — premium Liquid Glass with color tints + rotation -->
  <div class="float-card card-1" aria-hidden="true">
    <div class="card-specular"></div>
    <div class="card-inner">
      <div class="card-header">
        <div class="icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <div class="card-title-wrap">
          <p class="card-title">Análisis completado</p>
          <p class="card-sub">hace 2 min</p>
        </div>
        <div class="pulse-dot"></div>
      </div>
      <div class="card-box">
        <p class="card-user">Carmen R. · Madrid</p>
        <p class="card-amount">+<span class="counter" data-target="312">0</span><span class="currency">€</span><span class="period">/año</span></p>
      </div>
    </div>
  </div>

  <div class="float-card card-2" aria-hidden="true">
    <div class="card-specular"></div>
    <div class="card-inner">
      <div class="card-header">
        <div class="icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div class="card-title-wrap">
          <p class="card-title">Tarifa optimizada</p>
          <p class="card-sub">En 7 días</p>
        </div>
      </div>
      <div class="bars">
        <div class="bar-line">
          <span class="bar-label">Antes</span>
          <div class="bar-track"><div class="bar-fill bar-old"></div></div>
          <span class="bar-val">145€</span>
        </div>
        <div class="bar-line">
          <span class="bar-label accent">Ahora</span>
          <div class="bar-track"><div class="bar-fill bar-new"></div></div>
          <span class="bar-val accent">112€</span>
        </div>
      </div>
      <div class="card-footer-row">
        <span class="savings-badge">-23% ahorro</span>
      </div>
    </div>
  </div>

  <div class="float-card card-3" aria-hidden="true">
    <div class="card-specular"></div>
    <div class="card-inner">
      <div class="card-header">
        <div class="icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <div class="card-title-wrap">
          <p class="card-title">Clientes activos</p>
          <p class="card-sub">Esta semana</p>
        </div>
      </div>
      <div class="client-row">
        <div class="avatars">
          <span class="avatar" style="background:linear-gradient(135deg,#007AFF,#5856D6)">MR</span>
          <span class="avatar" style="background:linear-gradient(135deg,#34C759,#30D158)">JL</span>
          <span class="avatar" style="background:linear-gradient(135deg,#FF9500,#FF6B00)">AP</span>
          <span class="avatar more">+12</span>
        </div>
        <div class="client-stat">
          <span class="stat-num">+47</span>
          <span class="stat-lbl">nuevos</span>
        </div>
      </div>
      <div class="trend">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
        <span>+18% vs mes anterior</span>
      </div>
    </div>
  </div>

  <!-- Hero content -->
  <div class="content">

    <div class="reveal stagger-1">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        <span class="eyebrow-text">Asesoría Energética Independiente</span>
        <span class="eyebrow-sep"></span>
        <span class="eyebrow-free">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
          100% Gratuito
        </span>
      </div>
    </div>

    <h1 class="headline reveal stagger-2">
      <span class="line line-1">Tu factura de luz.</span>
      <span class="line line-accent">Reducida.</span>
    </h1>

    <p class="subhead reveal stagger-3">
      Análisis técnico real. Tarifa perfecta del mercado.<br>
      <strong>Sin que muevas un dedo.</strong>
    </p>

    <div class="cta-group reveal stagger-4">
      <a href={siteConfig.whatsappUrl} class="cta-btn">
        <span class="cta-btn-bg"></span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="position:relative;z-index:1"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span style="position:relative;z-index:1">Estudio gratuito</span>
      </a>
      <p class="cta-note">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Respuesta en menos de 24 horas
      </p>
    </div>

    <div class="trust reveal stagger-5">
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        Sin permanencia
      </span>
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Datos cifrados
      </span>
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        +450 hogares
      </span>
      <span class="pill pill-gold">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        4.9 / 5
      </span>
    </div>
  </div>

  <!-- Stats Island -->
  <div class="stats-wrap reveal stagger-5">
    <div class="stats-specular"></div>
    <div class="stats-content">
      <div class="stat-col">
        <span class="stat-num-big"><span class="counter" data-target="450">0</span>+</span>
        <span class="stat-label">Hogares asesorados</span>
      </div>
      <div class="stat-vline"></div>
      <div class="stat-col">
        <span class="stat-num-big blue"><span class="counter" data-target="280">0</span>€</span>
        <span class="stat-label">Ahorro medio/año</span>
      </div>
      <div class="stat-vline"></div>
      <div class="stat-col">
        <span class="stat-num-big green"><span class="counter" data-target="8">0</span>+</span>
        <span class="stat-label">Años experiencia</span>
      </div>
      <div class="stat-vline"></div>
      <div class="stat-col">
        <span class="stat-stars">★★★★★</span>
        <span class="stat-num-big" style="font-size:1.625rem">4.9</span>
        <span class="stat-label">Valoración media</span>
      </div>
    </div>
  </div>

</section>

<style>
  /* ─── Hero shell ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 108px 24px 200px;
    overflow: hidden;
    /* Premium layered background with subtle noise texture */
    background:
      radial-gradient(ellipse 120% 80% at 20% -10%, rgba(0,122,255,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 80% 50% at 80% -5%, rgba(90,200,250,0.08) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 50% 100%, rgba(52,199,89,0.04) 0%, transparent 50%),
      linear-gradient(180deg, #F8FAFC 0%, #F2F5FA 50%, #EDF2F7 100%);
  }

  /* Subtle grain texture overlay */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.015;
    pointer-events: none;
    z-index: 1;
  }

  /* ─── Background orbs ────────────────────────────────────────── */
  .orbs {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
  }

  .orb-blue {
    width: 72vw; height: 72vw;
    max-width: 860px; max-height: 860px;
    top: -22%; left: -12%;
    background: radial-gradient(circle, rgba(0,122,255,0.50) 0%, transparent 65%);
    animation: orb1 22s ease-in-out infinite;
  }

  .orb-cyan {
    width: 55vw; height: 55vw;
    max-width: 680px; max-height: 680px;
    top: -8%; right: -4%;
    background: radial-gradient(circle, rgba(90,200,250,0.42) 0%, transparent 65%);
    animation: orb2 28s ease-in-out infinite;
  }

  .orb-green {
    width: 80vw; height: 38vw;
    max-width: 920px; max-height: 480px;
    bottom: 3%; left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(52,199,89,0.34) 0%, transparent 65%);
    animation: orb3 32s ease-in-out infinite;
  }

  .orb-purple {
    width: 42vw; height: 42vw;
    max-width: 520px; max-height: 520px;
    bottom: 18%; left: 4%;
    background: radial-gradient(circle, rgba(88,86,214,0.26) 0%, transparent 65%);
    animation: orb2 24s ease-in-out infinite reverse;
  }

  @keyframes orb1 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 0.9; }
    25% { transform: translate(25px, -15px) scale(1.05) rotate(5deg); opacity: 1; }
    50% { transform: translate(40px, -30px) scale(1.02) rotate(-3deg); opacity: 0.95; }
    75% { transform: translate(15px, -20px) scale(1.08) rotate(8deg); opacity: 1; }
  }
  @keyframes orb2 {
    0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 0.85; }
    33% { transform: translate(-20px, 25px) scale(0.95) rotate(-8deg); opacity: 0.95; }
    66% { transform: translate(-35px, 15px) scale(1.03) rotate(5deg); opacity: 0.9; }
  }
  @keyframes orb3 {
    0%, 100% { transform: translateX(-50%) translateY(0) scale(1); opacity: 0.8; }
    50% { transform: translateX(-50%) translateY(-35px) scale(1.06); opacity: 0.9; }
  }

  /* ─── Floating Cards — premium Liquid Glass ──────────────────── */
  .float-card {
    position: absolute;
    width: 268px;
    z-index: 2;
    display: none;
    border-radius: 22px;
    overflow: hidden;
    /* Authentic Liquid Glass with premium feel */
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.05);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.05);
    border: 1px solid rgba(255,255,255,0.75);
    box-shadow:
      /* Luminous top edge — signature Apple look */
      inset 0 1px 0 rgba(255,255,255,0.98),
      inset 0 -1px 0 rgba(0,0,0,0.02),
      /* Multi-layer ambient shadow for depth */
      0 2px 4px rgba(0,0,0,0.02),
      0 8px 24px rgba(0,0,0,0.06),
      0 24px 60px rgba(0,0,0,0.08),
      0 48px 100px rgba(0,0,0,0.05);
    transition: all 400ms var(--ease-ios);
    cursor: default;
  }

  .float-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,1),
      inset 0 -1px 0 rgba(0,0,0,0.02),
      0 4px 8px rgba(0,0,0,0.03),
      0 12px 32px rgba(0,0,0,0.08),
      0 32px 72px rgba(0,0,0,0.10),
      0 56px 120px rgba(0,0,0,0.07);
  }

  /* Subtle color tint per card type */
  .card-1 { background: rgba(245,255,250,0.74); }
  .card-2 { background: rgba(240,248,255,0.74); }
  .card-3 { background: rgba(248,245,255,0.74); }

  @media (min-width: 1200px) { .float-card { display: block; } }

  /* Position + individual movement with 3D parallax */
  .card-1 { left: 5%;  top: 25%; animation: float1 8s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards; animation-delay: 0s, 0.6s; opacity: 0; --rotation: -2deg; --parallax-x: 0px; --parallax-y: 0px; }
  .card-2 { right: 5%; top: 20%; animation: float2 7s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards; animation-delay: -2.5s, 0.75s; opacity: 0; --rotation: 2deg; --parallax-x: 0px; --parallax-y: 0px; }
  .card-3 { left: 7%;  top: 55%; animation: float3 9s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards; animation-delay: -5s, 0.9s; opacity: 0; --rotation: -1.5deg; --parallax-x: 0px; --parallax-y: 0px; }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: perspective(1000px) rotateY(15deg) translateY(40px) scale(0.9);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      filter: blur(0);
    }
  }

  /* Complex floating animations with rotation, translation and subtle scale */
  @keyframes float1 {
    0%, 100% { transform: rotate(-2deg) translateY(0px) translateX(0px) scale(1); }
    25% { transform: rotate(-1.5deg) translateY(-15px) translateX(5px) scale(1.01); }
    50% { transform: rotate(-2.5deg) translateY(-8px) translateX(-3px) scale(0.99); }
    75% { transform: rotate(-1.8deg) translateY(-18px) translateX(8px) scale(1.01); }
  }
  
  @keyframes float2 {
    0%, 100% { transform: rotate(2deg) translateY(0px) translateX(0px) scale(1); }
    33% { transform: rotate(1.5deg) translateY(-12px) translateX(-6px) scale(1.02); }
    66% { transform: rotate(2.5deg) translateY(-6px) translateX(4px) scale(0.98); }
  }
  
  @keyframes float3 {
    0%, 100% { transform: rotate(-1.5deg) translateY(0px) translateX(0px) scale(1); }
    20% { transform: rotate(-1deg) translateY(-10px) translateX(4px) scale(1.01); }
    40% { transform: rotate(-2deg) translateY(-5px) translateX(-2px) scale(0.99); }
    60% { transform: rotate(-1.2deg) translateY(-14px) translateX(6px) scale(1.01); }
    80% { transform: rotate(-1.8deg) translateY(-7px) translateX(-4px) scale(0.99); }
  }

  /* 3D tilt effect on hover */
  .float-card:hover {
    transform: translateY(-6px) scale(1.03) rotateX(5deg) rotateY(-5deg) !important;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,1),
      inset 0 -1px 0 rgba(0,0,0,0.02),
      0 8px 16px rgba(0,0,0,0.05),
      0 20px 40px rgba(0,0,0,0.10),
      0 40px 80px rgba(0,0,0,0.12),
      0 60px 120px rgba(0,0,0,0.08);
  }

  /* Specular highlight — the curved "glass lens" reflection */
  .card-specular {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 60%;
    pointer-events: none;
    z-index: 3;
    border-radius: 22px 22px 0 0;
    background: linear-gradient(
      175deg,
      rgba(255,255,255,0.95) 0%,
      rgba(255,255,255,0.50) 30%,
      rgba(255,255,255,0.15) 55%,
      transparent 80%
    );
    opacity: 0.9;
  }

  /* Card content sits above specular */
  .card-inner {
    position: relative;
    z-index: 4;
    padding: 18px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .icon {
    width: 38px; height: 38px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(0,122,255,0.15) 0%, rgba(0,122,255,0.08) 100%);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border: 1px solid rgba(0,122,255,0.20);
    color: var(--ios-blue);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.70),
      0 2px 8px rgba(0,122,255,0.15),
      0 4px 16px rgba(0,122,255,0.08);
    transition: all 300ms var(--ease-ios-spring);
  }

  .icon::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(255,255,255,0.60) 0%, transparent 50%);
    pointer-events: none;
  }

  .float-card:hover .icon {
    transform: scale(1.08);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.80),
      0 4px 12px rgba(0,122,255,0.20),
      0 8px 24px rgba(0,122,255,0.12);
  }

  .card-title-wrap { flex: 1; min-width: 0; }

  .card-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--label-primary);
    margin: 0;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-sub {
    font-size: 0.71875rem;
    color: var(--label-quaternary);
    margin: 2px 0 0;
  }

  .pulse-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #007AFF 0%, #5AC8FA 100%);
    flex-shrink: 0;
    position: relative;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.50),
      0 0 0 0 rgba(0,122,255,0.50);
    animation: pulse-glass 2s ease-in-out infinite;
  }

  .pulse-dot::before {
    content: '';
    position: absolute;
    top: 1px; left: 1px; right: 1px; bottom: 1px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255,255,255,0.70) 0%, transparent 50%);
    pointer-events: none;
  }

  @keyframes pulse-glass {
    0%, 100% {
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.50),
        0 0 0 0 rgba(0,122,255,0.50);
    }
    50% {
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.50),
        0 0 0 10px rgba(0,122,255,0);
    }
  }

  /* Card-1: savings box */
  .card-box {
    background: linear-gradient(135deg, rgba(0,122,255,0.10) 0%, rgba(0,122,255,0.05) 100%);
    border-radius: 14px;
    padding: 16px;
    border: 1px solid rgba(0,122,255,0.12);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.50);
    position: relative;
    overflow: hidden;
  }

  .card-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.40) 0%, transparent 100%);
    pointer-events: none;
  }

  .card-user {
    font-size: 0.8125rem;
    color: var(--label-secondary);
    margin: 0 0 6px;
    position: relative;
    z-index: 1;
  }

  .card-amount {
    font-size: 2.125rem;
    font-weight: 700;
    color: var(--ios-blue);
    margin: 0;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    position: relative;
    z-index: 1;
  }

  .currency { margin-left: 1px; }

  .period {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--label-secondary);
    margin-left: 3px;
  }

  .counter {
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum" 1;
  }

  /* Card-2: bars */
  .bars { margin-bottom: 12px; }

  .bar-line {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .bar-label {
    font-size: 0.71875rem;
