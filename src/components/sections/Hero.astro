---
import { siteConfig } from '../../config/site';
import { MessageCircle, Clock } from 'lucide-astro';
---

<section class="hero" aria-label="Asesoría energética gratuita para ahorrar en tu factura de luz" id="hero" itemscope itemtype="https://schema.org/WebPageElement">

  <!-- Floating Cards — premium Liquid Glass with color tints -->
  <div class="card-wrapper" data-card="1" aria-hidden="true">
    <div class="float-card card-1">
      <div class="card-specular"></div>
      <div class="card-inner">
        <div class="card-header">
          <div class="icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="card-title-wrap">
            <p class="card-title">Análisis completado</p>
            <p class="card-sub">hace 2 min</p>
          </div>
          <div class="pulse-dot"></div>
        </div>
        <div class="card-box">
          <p class="card-user">Carmen R. · Madrid</p>
          <p class="card-amount">+<span class="counter" data-target="180" aria-hidden="true">0</span><span class="sr-only">180</span><span class="currency">€</span><span class="period">/año</span></p>
        </div>
      </div>
    </div>
  </div>

  <div class="card-wrapper" data-card="2" aria-hidden="true">
    <div class="float-card card-2">
      <div class="card-specular"></div>
      <div class="card-inner">
        <div class="card-header">
          <div class="icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div class="card-title-wrap">
            <p class="card-title">Tarifa optimizada</p>
            <p class="card-sub">En 7 días</p>
          </div>
        </div>
        <div class="bars">
          <div class="bar-line">
            <span class="bar-label">Antes</span>
            <div class="bar-track"><div class="bar-fill bar-old"></div></div>
            <span class="bar-val">120€</span>
          </div>
          <div class="bar-line">
            <span class="bar-label accent">Ahora</span>
            <div class="bar-track"><div class="bar-fill bar-new"></div></div>
            <span class="bar-val accent">102€</span>
          </div>
        </div>
        <div class="card-footer-row">
          <span class="savings-badge">-15% ahorro</span>
        </div>
      </div>
    </div>
  </div>

  <div class="card-wrapper" data-card="3" aria-hidden="true">
    <div class="float-card card-3">
      <div class="card-specular"></div>
      <div class="card-inner">
        <div class="card-header">
          <div class="icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div class="card-title-wrap">
            <p class="card-title">Clientes activos</p>
            <p class="card-sub">Esta semana</p>
          </div>
        </div>
        <div class="client-row">
          <div class="avatars">
            <span class="avatar" style={`background:linear-gradient(135deg,var(--color-primary) 0%,var(--color-secondary) 100%)`} aria-hidden="true">MR</span>
            <span class="avatar" style={`background:linear-gradient(135deg,var(--color-success) 0%,var(--green-400) 100%)`} aria-hidden="true">JL</span>
            <span class="avatar" style={`background:linear-gradient(135deg,var(--color-accent) 0%,#FF6B00 100%)`} aria-hidden="true">AP</span>
            <span class="avatar more" aria-hidden="true">+12</span>
          </div>
          <div class="client-stat">
            <span class="stat-num">+47</span>
            <span class="stat-lbl">nuevos</span>
          </div>
        </div>
        <div class="trend">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
          <span>+18% vs mes anterior</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero content -->
  <div class="content">

    <div class="reveal stagger-1">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        <span class="eyebrow-text">Asesoría Energética Independiente</span>
        <span class="eyebrow-sep"></span>
        <span class="eyebrow-free">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
          100% Gratuito
        </span>
      </div>
    </div>

    <h1 class="headline reveal stagger-2" itemprop="headline">
      <span class="line line-1">Tu factura de luz</span>
      <span class="line line-accent">Reducida.</span>
    </h1>

    <p class="subhead reveal stagger-3">
      Análisis técnico real. Tarifa perfecta del mercado.<br>
      <strong>Sin que muevas un dedo.</strong>
    </p>

    <div class="cta-group reveal stagger-4">
      <a href={siteConfig.whatsappUrl} class="cta-btn" rel="noopener noreferrer" aria-label="Solicitar estudio gratuito por WhatsApp">
        <span class="cta-btn-bg" aria-hidden="true"></span>
        <MessageCircle size={20} fill="currentColor" style="position:relative;z-index:1" aria-hidden="true" />
        <span style="position:relative;z-index:1">Estudio gratuito por WhatsApp</span>
      </a>
      <p class="cta-note">
        <Clock size={12} aria-hidden="true" />
        Respuesta en menos de 24 horas
      </p>
    </div>

    <div class="trust reveal stagger-5">
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M20 6L9 17l-5-5"/></svg>
        Sin permanencia
      </span>
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Datos cifrados
      </span>
      <span class="pill">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" focusable="false"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        +300 hogares
      </span>
      <span class="pill pill-gold">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        4.9 / 5
      </span>
    </div>
  </div>

</section>

<style>
  /* ─── Hero shell ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100px var(--space-6);
    overflow: hidden;
    /* No background - using global background from Layout */
  }

  /* ─── Floating Cards ─────────────────────────────────────────── */
  .card-wrapper {
    position: absolute;
    z-index: 2;
    display: none;
    will-change: transform;
    transition: transform var(--duration-normal) var(--ease-ios);
  }
  [data-card="1"] { left: 4%; top: 26%; }
  [data-card="2"] { right: 4%; top: 22%; }
  [data-card="3"] { left: 5%; top: 56%; }
  @media (min-width: 1100px) { .card-wrapper { display: block; } }

  .card-wrapper:hover {
    z-index: 10;
  }

  .card-wrapper:hover .float-card {
    transform: translateY(-8px) scale(1.02);
    box-shadow: var(--shadow-glass-hover);
  }

  .float-card {
    width: 260px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-glass);
    transition: all 0.5s var(--ease-ios-spring);
    will-change: transform;
    position: relative;
  }

  .float-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, transparent 50%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease-ios);
  }

  .card-wrapper:hover .float-card::after {
    opacity: 1;
  }

  /* Color tint per card */
  .card-1 { background: rgba(238, 255, 245, 0.72); }
  .card-2 { background: rgba(236, 246, 255, 0.72); }
  .card-3 { background: rgba(243, 240, 255, 0.72); }

  /* Individual float animations */
  .card-1 {
    animation: float1 6s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards;
    animation-delay: 0s, 0.6s;
    opacity: 0;
  }
  .card-2 {
    animation: float2 7s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards;
    animation-delay: -2s, 0.75s;
    opacity: 0;
  }
  .card-3 {
    animation: float3 8s ease-in-out infinite, cardEnter 1s var(--ease-ios-decel) forwards;
    animation-delay: -4s, 0.9s;
    opacity: 0;
  }

  @keyframes cardEnter {
    from {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes float1 {
    0%, 100% { transform: translateY(0) translateX(0); }
    25% { transform: translateY(-6px) translateX(3px); }
    50% { transform: translateY(-3px) translateX(-2px); }
    75% { transform: translateY(-8px) translateX(2px); }
  }

  @keyframes float2 {
    0%, 100% { transform: translateY(0) translateX(0); }
    33% { transform: translateY(-8px) translateX(-3px); }
    66% { transform: translateY(-4px) translateX(2px); }
  }

  @keyframes float3 {
    0%, 100% { transform: translateY(0) translateX(0); }
    20% { transform: translateY(-5px) translateX(2px); }
    40% { transform: translateY(-9px) translateX(-2px); }
    60% { transform: translateY(-4px) translateX(3px); }
    80% { transform: translateY(-7px) translateX(-1px); }
  }

  /* Specular highlight */
  .card-specular {
    composes: specular from global;
    opacity: 0.85;
  }

  /* Card content */
  .card-inner {
    position: relative;
    z-index: 2;
    padding: var(--space-4);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .icon {
    width: 36px; height: 36px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(0,122,255,0.12) 0%, rgba(0,122,255,0.06) 100%);
    backdrop-filter: blur(10px) saturate(160%);
    -webkit-backdrop-filter: blur(10px) saturate(160%);
    border: 1px solid rgba(0,122,255,0.18);
    color: var(--color-primary);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.65),
      0 2px 6px rgba(0,122,255,0.12),
      0 4px 12px rgba(0,122,255,0.06);
    transition: all var(--duration-normal) var(--ease-ios-spring);
  }

  .icon::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(255,255,255,0.55) 0%, transparent 50%);
    pointer-events: none;
  }

  .card-wrapper:hover .icon {
    transform: scale(1.12) rotate(-3deg);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.85),
      0 4px 14px rgba(0,122,255,0.22),
      0 8px 24px rgba(0,122,255,0.12);
    border-color: rgba(0,122,255,0.28);
  }

  .card-wrapper:hover .icon svg {
    animation: icon-bounce 0.5s var(--ease-ios-spring);
  }

  @keyframes icon-bounce {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }

  .card-title-wrap { flex: 1; min-width: 0; }

  .card-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin: 0;
    line-height: var(--leading-none);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-sub {
    font-size: var(--text-xs);
    color: var(--text-quaternary);
    margin: 2px 0 0;
  }

  .pulse-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--cyan-400) 100%);
    flex-shrink: 0;
    position: relative;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.50),
      0 0 0 0 rgba(0,122,255,0.45);
    animation: pulse-glass 2.2s ease-in-out infinite;
  }

  .pulse-dot::before {
    content: '';
    position: absolute;
    top: 1px; left: 1px; right: 1px; bottom: 1px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(255,255,255,0.65) 0%, transparent 50%);
    pointer-events: none;
  }

  @keyframes pulse-glass {
    0%, 100% {
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.50),
        0 0 0 0 rgba(0,122,255,0.45);
    }
    50% {
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.50),
        0 0 0 8px rgba(0,122,255,0);
    }
  }

  /* Card-1: savings box */
  .card-box {
    background: linear-gradient(135deg, rgba(0,122,255,0.08) 0%, rgba(0,122,255,0.04) 100%);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    border: 1px solid rgba(0,122,255,0.10);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.45);
    position: relative;
    overflow: hidden;
  }

  .card-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.35) 0%, transparent 100%);
    pointer-events: none;
  }

  .card-user {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0 0 var(--space-1);
    position: relative;
    z-index: 1;
  }

  .card-amount {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    margin: 0;
    line-height: var(--leading-none);
    font-variant-numeric: tabular-nums;
    position: relative;
    z-index: 1;
  }

  .currency { margin-left: 1px; }

  .period {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
    margin-left: 3px;
  }

  .counter {
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum" 1;
  }

  /* Card-2: bars */
  .bars { margin-bottom: var(--space-2); }

  .bar-line {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 9px;
  }

  .bar-label {
    font-size: var(--text-xs);
    color: var(--text-quaternary);
    width: 38px;
    flex-shrink: 0;
  }
  .bar-label.accent { color: var(--color-primary); font-weight: var(--font-semibold); }

  .bar-track {
    flex: 1;
    height: 6px;
    background: rgba(0,0,0,0.05);
    border-radius: var(--radius-pill);
    overflow: hidden;
    position: relative;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.06);
  }

  .bar-fill {
    height: 100%;
    border-radius: var(--radius-pill);
    position: relative;
    box-shadow: 0 1px 2px rgba(0,0,0,0.08);
  }

  .bar-fill::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255,255,255,0.25) 0%, transparent 100%);
    border-radius: var(--radius-pill) var(--radius-pill) 0 0;
  }

  .bar-old  {
    width: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0.10) 0%, rgba(0,0,0,0.06) 100%);
  }

  .bar-new  {
    width: 85%;
    background: linear-gradient(90deg, var(--blue-600) 0%, var(--color-primary) 50%, var(--cyan-400) 100%);
    animation: barGrow 1s ease-out forwards;
    transform-origin: left;
  }

  @keyframes barGrow {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .bar-val {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    width: 36px;
    text-align: right;
    flex-shrink: 0;
  }
  .bar-val.accent { color: var(--color-primary); font-weight: var(--font-bold); }

  .card-footer-row { display: flex; justify-content: flex-end; }

  .savings-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: linear-gradient(135deg, rgba(0,122,255,0.16) 0%, rgba(0,122,255,0.08) 100%);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    border: 1px solid rgba(0,122,255,0.22);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.55),
      0 2px 6px rgba(0,122,255,0.16),
      0 3px 10px rgba(0,122,255,0.08);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-ios-spring);
  }

  .savings-badge::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.45) 0%,
      transparent 100%
    );
    border-radius: var(--radius-pill) var(--radius-pill) 0 0;
    pointer-events: none;
  }

  .card-wrapper:hover .savings-badge {
    transform: scale(1.04);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.65),
      0 3px 10px rgba(0,122,255,0.22),
      0 5px 14px rgba(0,122,255,0.12);
  }

  /* Card-3: clients */
  .client-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .avatars { display: flex; }

  .avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    color: var(--text-inverse);
    margin-left: -9px;
    border: 2.5px solid rgba(255,255,255,0.92);
    box-shadow:
      0 2px 6px rgba(0,0,0,0.12),
      0 4px 10px rgba(0,0,0,0.06);
    position: relative;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-ios-spring);
  }

  .avatar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.28) 0%, transparent 50%);
    pointer-events: none;
  }

  .avatar:first-child { margin-left: 0; }
  .avatar.more {
    background: linear-gradient(135deg, rgba(0,122,255,0.55) 0%, rgba(0,122,255,0.35) 100%);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .card-wrapper:hover .avatar {
    transform: translateX(3px);
    box-shadow:
      0 3px 10px rgba(0,0,0,0.16),
      0 5px 14px rgba(0,0,0,0.08);
  }

  .client-stat { text-align: right; }

  .stat-num {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    display: block;
    line-height: var(--leading-none);
    font-variant-numeric: tabular-nums;
  }

  .stat-lbl {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }

  .trend {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: var(--text-xs);
    color: var(--color-primary);
    font-weight: var(--font-semibold);
    padding: var(--space-1) var(--space-2);
    background: linear-gradient(135deg, rgba(0,122,255,0.06) 0%, rgba(0,122,255,0.03) 100%);
    border-radius: var(--radius-pill);
    border: 1px solid rgba(0,122,255,0.10);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.45);
  }
  .trend svg { stroke: var(--color-primary); }

  /* ─── Hero content ───────────────────────────────────────────── */
  .content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 760px;
    padding: 0 var(--space-4);
  }

  /* Eyebrow pill - Liquid Glass Formula (matches trust pills) */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-8);
    background: rgba(255, 255, 255, 0.70);
    backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    -webkit-backdrop-filter: blur(40px) saturate(200%) brightness(1.03);
    border: 1px solid rgba(255, 255, 255, 0.72);
