<script>
  // CountUp for floating cards only
  const countUp = (el: HTMLElement) => {
    const target = parseInt(el.dataset.target ?? '0');
    const start = performance.now();
    const tick = (now: number) => {
      const p = Math.min((now - start) / 1600, 1);
      const ease = 1 - Math.pow(1 - p, 4);
      el.textContent = String(Math.floor(ease * target));
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.querySelectorAll<HTMLElement>('.counter').forEach((c, i) => {
        if (!c.classList.contains('done')) {
          setTimeout(() => { c.classList.add('done'); countUp(c); }, i * 120);
        }
      });
    });
  }, { threshold: 0.25 });

  document.querySelectorAll('.float-card').forEach(el => io.observe(el));

  // Parallax effect on mouse move
  const hero = document.getElementById('hero');
  const cardWrappers = document.querySelectorAll('.card-wrapper');
  let rafId: number | null = null;
  let mouseX = 0;
  let mouseY = 0;
  let currentX = 0;
  let currentY = 0;

  const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && !window.matchMedia('(pointer: coarse)').matches && !noMotion && cardWrappers.length > 0) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width - 0.5;
      mouseY = (e.clientY - rect.top) / rect.height - 0.5;

      if (!rafId) {
        rafId = requestAnimationFrame(() => {
          currentX += (mouseX - currentX) * 0.08;
          currentY += (mouseY - currentY) * 0.08;

          cardWrappers.forEach((wrapper, index) => {
            const depth = (index + 1) * 4;
            const moveX = currentX * depth * -1;
            const moveY = currentY * depth * -1;
            (wrapper as HTMLElement).style.transform = `translate(${moveX}px, ${moveY}px)`;
          });
          rafId = null;
        });
      }
    }, { passive: true });
  }
</script>