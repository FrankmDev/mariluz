---
import { siteConfig } from '../../config/site';
import { MessageCircle, Phone, Mail, ShieldCheck, Clock } from 'lucide-astro';
---

<footer class="footer" aria-label="Pie de página">
  <!-- Atmospheric orbs -->
  <div class="orb orb-blue-soft float-slow" style="width: 300px; height: 300px; top: -10%; left: -6%; opacity: 0.22;" aria-hidden="true"></div>
  <div class="orb orb-cyan-soft float-breathe" style="width: 220px; height: 220px; bottom: 20%; right: -5%; opacity: 0.18;" aria-hidden="true"></div>

  <div class="container-custom footer-container">

    <!-- Main Footer Content -->
    <div class="footer-main">
      
      <!-- Brand Column -->
      <div class="footer-brand-col reveal">
        <a href="/" class="footer-brand">
          luzaria<span class="dot">.</span>
        </a>
        <p class="brand-tagline">
          Asesoría energética personal para entender tu factura y valorar si compensa cambiar.
        </p>
        <div class="trust-badges">
          <span class="badge">
            <ShieldCheck size={13} aria-hidden="true" />
            Sin cambios sin autorización
          </span>
          <span class="badge">
            <Clock size={13} aria-hidden="true" />
            Estudio gratuito
          </span>
        </div>
      </div>

      <!-- Links Columns -->
      <div class="footer-links reveal">
        <div class="links-col">
          <h4 class="links-title">Servicio</h4>
          <ul class="links-list">
            <li><a href="#como-funciona">Cómo funciona</a></li>
            <li><a href="#sobre-mi">Sobre mí</a></li>
            <li><a href="#contacto">Revisar factura</a></li>
            <li><a href="#faq">Preguntas frecuentes</a></li>
          </ul>
        </div>
        <div class="links-col">
          <h4 class="links-title">Contacto</h4>
          <ul class="links-list">
            <li>
              <a href={siteConfig.whatsappUrl} class="link-with-icon">
                <MessageCircle size={14} fill="currentColor" />
                WhatsApp
              </a>
            </li>
            <li>
              <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="link-with-icon">
                <Phone size={14} />
                {siteConfig.phone}
              </a>
            </li>
            <li>
              <a href={`mailto:${siteConfig.email}`} class="link-with-icon">
                <Mail size={14} />
                Email
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom reveal">
      <div class="bottom-glass">
        <div class="bottom-specular" aria-hidden="true"></div>
        <div class="bottom-content">
          <p class="copyright">
            © {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.
          </p>
          <div class="legal-links">
            <a href="/privacidad" rel="nofollow noopener">Privacidad</a>
            <a href="/cookies" rel="nofollow noopener">Cookies</a>
            <a href="/legal" rel="nofollow noopener">Aviso legal</a>
            <a href="https://frnq.studio" target="_blank" rel="noopener noreferrer" class="developer-link">
              Desarrollado por FRN.Q
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>
</footer>

<style>
  /* ═══════════════════════════════════════════════════════════════
     FOOTER - Premium iOS 26 Edition
     ═══════════════════════════════════════════════════════════════ */

  .footer {
    position: relative;
    padding: 80px 0 40px;
    overflow: hidden;
    isolation: isolate;
    /* No background - using global background from Layout */
  }

  .footer-container {
    position: relative;
    z-index: 1;
  }

  /* ─── Main Footer ─────────────────────────────────────────────── */
  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 64px;
    padding: 48px 0;
    border-top: 1px solid var(--separator);
    border-bottom: 1px solid var(--separator);
  }

  /* Brand Column */
  .footer-brand-col {
    max-width: 360px;
  }

  .footer-brand {
    display: inline-flex;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--label-primary);
    letter-spacing: -0.04em;
    text-decoration: none;
    margin-bottom: 16px;
    transition: transform 0.3s var(--ease-ios-spring), opacity 0.3s var(--ease-ios);
  }

  .footer-brand:hover {
    opacity: 0.7;
    transform: scale(1.02);
  }

  .dot {
    color: var(--ios-blue);
  }

  .brand-tagline {
    font-size: var(--text-base);
    color: var(--label-secondary);
    line-height: 1.6;
    margin: 0 0 24px;
  }

  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.68);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.60);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--label-secondary);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.92),
      0 2px 6px rgba(0,0,0,0.03);
    transition: transform 0.3s var(--ease-ios-spring), background 0.3s var(--ease-ios), box-shadow 0.3s var(--ease-ios);
  }

  .badge:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.82);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.98),
      0 4px 12px rgba(0,0,0,0.05);
  }

  .badge svg {
    color: var(--color-success);
    flex-shrink: 0;
  }

  /* Links Section */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px;
  }

  .links-col {
    display: flex;
    flex-direction: column;
  }

  .links-title {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--label-primary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 20px;
  }

  .links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .links-list a {
    display: inline-flex;
    align-items: center;
    font-size: 0.9375rem;
    color: var(--label-secondary);
    text-decoration: none;
    transition: color 0.25s var(--ease-ios), transform 0.25s var(--ease-ios-spring);
    position: relative;
  }

  .links-list a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--ios-blue);
    transition: width 0.3s var(--ease-ios);
  }

  .links-list a:hover {
    color: var(--ios-blue);
    transform: translateX(3px);
  }

  .links-list a:hover::after {
    width: 100%;
  }

  .link-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .link-with-icon svg {
    opacity: 0.7;
  }

  /* ─── Footer Bottom ───────────────────────────────────────────── */
  .footer-bottom {
    padding-top: var(--space-6);
  }

  .bottom-glass {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 16px;
    padding: var(--space-4) var(--space-6);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(32px) saturate(180%) brightness(1.02);
    -webkit-backdrop-filter: blur(32px) saturate(180%) brightness(1.02);
    border: 1px solid rgba(255, 255, 255, 0.60);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.90),
      0 2px 8px rgba(0,0,0,0.03);
    transition: transform 0.45s var(--ease-ios-spring), box-shadow 0.35s var(--ease-ios);
  }

  .bottom-glass:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.95),
      0 6px 16px rgba(0,0,0,0.05);
  }

  .bottom-specular {
    position: absolute;
    inset: 0 0 auto;
    height: 45%;
    pointer-events: none;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(255,255,255,0.85) 0%,
      rgba(255,255,255,0.25) 50%,
      transparent 100%
    );
    border-radius: 16px 16px 0 0;
  }

  .bottom-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .copyright {
    font-size: var(--text-sm);
    color: var(--label-tertiary);
    margin: 0;
    font-weight: var(--font-medium);
  }

  .legal-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .legal-links a {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    border-radius: var(--radius-pill);
    background: rgba(255,255,255,0.45);
    border: 1px solid rgba(255,255,255,0.55);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.70);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--label-secondary);
    text-decoration: none;
    transition: all 0.25s var(--ease-ios);
    white-space: nowrap;
  }

  .legal-links a:hover {
    color: var(--color-primary);
    background: rgba(255,255,255,0.70);
    transform: translateY(-1px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.85), 0 2px 6px rgba(0,0,0,0.04);
  }

  .developer-link {
    font-weight: var(--font-semibold);
    color: var(--label-secondary) !important;
  }

  .developer-link:hover {
    color: var(--color-primary) !important;
  }

  /* ─── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .footer {
      padding: 60px 0 32px;
    }

    .footer-main {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 36px 0;
    }

    .footer-brand-col {
      max-width: 100%;
      text-align: center;
    }

    .trust-badges {
      justify-content: center;
    }

    .footer-links {
      gap: 32px;
    }

    .bottom-glass {
      padding: var(--space-3) var(--space-4);
    }

    .bottom-content {
      flex-direction: column;
      text-align: center;
      gap: 14px;
    }

    .legal-links {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .footer {
      padding: 48px 0 24px;
    }

    .footer-links {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .links-list a {
      justify-content: center;
    }

    .footer-brand {
      font-size: 1.5rem;
    }

    .brand-tagline {
      font-size: var(--text-sm);
    }

    .bottom-glass {
      border-radius: 14px;
      padding: var(--space-3);
    }

    .bottom-specular {
      border-radius: 14px 14px 0 0;
    }

    .copyright {
      font-size: var(--text-xs);
    }

    .legal-links {
      gap: var(--space-1);
    }

    .legal-links a {
      font-size: var(--text-xs);
      padding: 4px 10px;
    }
  }

  /* ─── Reveal Animation ────────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s var(--ease-ios-decel), transform 0.7s var(--ease-ios-decel);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .badge,
    .links-list a,
    .legal-links a,
    .bottom-glass {
      transition: none !important;
    }

    .badge:hover,
    .links-list a:hover,
    .legal-links a:hover,
    .bottom-glass:hover {
      transform: none !important;
    }
  }
</style>
