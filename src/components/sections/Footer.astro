---
import { siteConfig } from '../../config/site';

const footerLinks = [
  { label: 'Cómo funciona', href: '#como-funciona' },
  { label: 'Calculadora', href: '#calculadora' },
  { label: 'Sobre mí', href: '#sobre-mi' },
  { label: 'FAQ', href: '#faq' },
];

const legalLinks = [
  { label: 'Aviso legal', href: '#' },
  { label: 'Privacidad', href: '#' },
  { label: 'Cookies', href: '#' },
];
---

<footer class="footer-dark">
  <div class="container-custom" style="padding-top: 80px; padding-bottom: 40px;">

    <!-- Main Footer Grid -->
    <div class="footer-grid">

      <!-- Brand Column -->
      <div>
        <a href="/" class="footer-brand" aria-label="Mariluz — Inicio">
          Mariluz<span style="color: var(--ios-blue);">.</span>
        </a>
        <p class="text-body" style="color: rgba(255,255,255,0.5); max-width: 280px; line-height: 1.65; margin-bottom: 32px; margin-top: 16px;">
          Asesoramiento energético independiente. Ayudando a familias y empresas a reducir su factura de la luz desde 2016.
        </p>

        <!-- Stats row -->
        <div style="display: flex; gap: 28px; flex-wrap: wrap;">
          <div>
            <p class="text-numeric" style="font-size: 1.5rem; font-weight: 800; color: #FFFFFF; letter-spacing: -0.04em;">450+</p>
            <p style="font-size: 0.75rem; color: rgba(255,255,255,0.4); font-family: var(--font-display); font-weight: 500; margin-top: 2px;">Hogares asesorados</p>
          </div>
          <div>
            <p class="text-numeric" style="font-size: 1.5rem; font-weight: 800; color: var(--ios-green); letter-spacing: -0.04em;">280€</p>
            <p style="font-size: 0.75rem; color: rgba(255,255,255,0.4); font-family: var(--font-display); font-weight: 500; margin-top: 2px;">Ahorro medio / año</p>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="footer-col-title">Navegación</h4>
        <ul class="footer-links">
          {footerLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="footer-col-title">Contacto</h4>
        <ul class="footer-links">
          <li>
            <a href={siteConfig.whatsappUrl} class="footer-link" style="display: flex; align-items: center; gap: 8px;">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color: #25D366; flex-shrink: 0;">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="footer-link">{siteConfig.phone}</a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="footer-link" style="word-break: break-all;">{siteConfig.email}</a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="footer-col-title">Legal</h4>
        <ul class="footer-links">
          {legalLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 32px; margin-top: 64px; display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center;">
      <p style="font-size: 0.8125rem; color: rgba(255,255,255,0.3); font-family: var(--font-display);">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-dark {
    background: #1D1D1F;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    font-size: 1.75rem;
    font-weight: 800;
    color: #FFFFFF;
    letter-spacing: -0.04em;
    text-decoration: none;
    transition: opacity 200ms;
  }

  .footer-brand:hover {
    opacity: 0.75;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 64px;
  }

  .footer-col-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 20px;
    font-family: var(--font-display);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-family: var(--font-display);
    transition: color 200ms;
  }

  .footer-link:hover {
    color: rgba(255,255,255,0.9);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
    .footer-grid > div:first-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 580px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-grid > div:first-child {
      grid-column: span 1;
    }
  }
</style>
