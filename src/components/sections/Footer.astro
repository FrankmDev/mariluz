---
import { siteConfig } from '../../config/site';
import { MessageCircle, Phone, Mail } from 'lucide-astro';
---

<footer class="footer" aria-label="Pie de página">
  <div class="container-custom footer-container">

    <!-- CTA Banner -->
    <div class="cta-banner reveal">
      <div class="banner-specular"></div>
      <div class="banner-content">
        <h3 class="banner-title">¿Listo para ahorrar?</h3>
        <p class="banner-text">Análisis gratuito en menos de 24 horas</p>
        <a href={siteConfig.whatsappUrl} class="banner-cta">
          <MessageCircle size={18} fill="currentColor" />
          Hablar por WhatsApp
        </a>
      </div>
    </div>

    <!-- Main Footer Content -->
    <div class="footer-main">
      
      <!-- Brand Column -->
      <div class="footer-brand-col reveal">
        <a href="/" class="footer-brand">
          luzaria<span class="dot">.</span>
        </a>
        <p class="brand-tagline">
          Asesoría energética independiente. Ahorra en tu factura de luz sin complicaciones.
        </p>
        <div class="trust-badges">
          <span class="badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Sin permanencia
          </span>
          <span class="badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            24h respuesta
          </span>
        </div>
      </div>

      <!-- Links Columns -->
      <div class="footer-links reveal">
        <div class="links-col">
          <h4 class="links-title">Servicio</h4>
          <ul class="links-list">
            <li><a href="#como-funciona">Cómo funciona</a></li>
            <li><a href="#calculadora">Calculadora</a></li>
            <li><a href="#beneficios">Beneficios</a></li>
            <li><a href="#sobre-mi">Sobre mí</a></li>
          </ul>
        </div>
        <div class="links-col">
          <h4 class="links-title">Contacto</h4>
          <ul class="links-list">
            <li>
              <a href={siteConfig.whatsappUrl} class="link-with-icon">
                <MessageCircle size={14} fill="currentColor" />
                WhatsApp
              </a>
            </li>
            <li>
              <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="link-with-icon">
                <Phone size={14} />
                {siteConfig.phone}
              </a>
            </li>
            <li>
              <a href={`mailto:${siteConfig.email}`} class="link-with-icon">
                <Mail size={14} />
                Email
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom reveal">
      <div class="bottom-content">
        <p class="copyright">
          © {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.
        </p>
        <div class="legal-links">
          <a href="/privacidad" rel="nofollow noopener">Privacidad</a>
          <span class="divider"></span>
          <a href="/cookies" rel="nofollow noopener">Cookies</a>
          <span class="divider"></span>
          <a href="/legal" rel="nofollow noopener">Aviso legal</a>
          <span class="divider"></span>
          <a href="https://frnq.studio" target="_blank" rel="noopener noreferrer" class="developer-link">
            Desarrollado por FRN.Q
          </a>
        </div>
      </div>
    </div>

  </div>
</footer>

<style>
  /* ═══════════════════════════════════════════════════════════════
     FOOTER - Premium iOS 26 Edition
     ═══════════════════════════════════════════════════════════════ */

  .footer {
    position: relative;
    padding: 80px 0 40px;
    overflow: hidden;
    isolation: isolate;
    /* No background - using global background from Layout */
  }

  .footer-container {
    position: relative;
    z-index: 1;
  }

  /* ─── CTA Banner ──────────────────────────────────────────────── */
  .cta-banner {
    position: relative;
    margin-bottom: 64px;
    padding: 40px;
    border-radius: 28px;
    overflow: hidden;
    background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
    box-shadow: 
      0 20px 60px rgba(0,122,255,0.2),
      0 8px 24px rgba(0,122,255,0.12);
  }

  .banner-specular {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 55%;
    background: linear-gradient(180deg, rgba(255,255,255,0.2) 0%, transparent 100%);
    pointer-events: none;
    border-radius: 28px 28px 0 0;
  }

  .banner-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .banner-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }

  .banner-text {
    font-size: var(--text-md);
    color: rgba(255,255,255,0.8);
    margin: 0;
  }

  .banner-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: rgba(255,255,255,0.95);
    color: #007AFF;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 100px;
    box-shadow: 
      0 4px 16px rgba(0,0,0,0.15),
      inset 0 1px 1px rgba(255,255,255,1);
    transition: all 0.3s var(--ease-ios-spring);
    flex-shrink: 0;
  }

  .banner-cta:hover {
    transform: translateY(-3px) scale(1.03);
    background: white;
    box-shadow: 
      0 12px 32px rgba(0,0,0,0.25),
      inset 0 1px 1px rgba(255,255,255,1);
    letter-spacing: 0.01em;
  }

  .banner-cta:active {
    transform: translateY(-1px) scale(0.98);
    box-shadow: 
      0 6px 16px rgba(0,0,0,0.2),
      inset 0 1px 1px rgba(255,255,255,1);
  }

  /* ─── Main Footer ─────────────────────────────────────────────── */
  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 64px;
    padding: 48px 0;
    border-top: 1px solid var(--separator);
    border-bottom: 1px solid var(--separator);
  }

  /* Brand Column */
  .footer-brand-col {
    max-width: 360px;
  }

  .footer-brand {
    display: inline-flex;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--label-primary);
    letter-spacing: -0.04em;
    text-decoration: none;
    margin-bottom: 16px;
    transition: all 0.3s var(--ease-ios-spring);
  }

  .footer-brand:hover {
    opacity: 0.7;
    transform: scale(1.02);
  }

  .dot {
    color: var(--ios-blue);
  }

  .brand-tagline {
    font-size: var(--text-base);
    color: var(--label-secondary);
    line-height: 1.6;
    margin: 0 0 24px;
  }

  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(10px) saturate(160%);
    -webkit-backdrop-filter: blur(10px) saturate(160%);
    border: 1px solid rgba(255,255,255,0.8);
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--label-secondary);
    box-shadow: 
      inset 0 1px 1px rgba(255,255,255,1),
      0 2px 8px rgba(0,0,0,0.04);
  }

  /* Links Section */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px;
  }

  .links-col {
    display: flex;
    flex-direction: column;
  }

  .links-title {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--label-primary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 20px;
  }

  .links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .links-list a {
    display: inline-flex;
    align-items: center;
    font-size: 0.9375rem;
    color: var(--label-secondary);
    text-decoration: none;
    transition: all 0.25s var(--ease-ios-spring);
    position: relative;
  }

  .links-list a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--ios-blue);
    transition: width 0.3s var(--ease-ios);
  }

  .links-list a:hover {
    color: var(--ios-blue);
  }

  .links-list a:hover::after {
    width: 100%;
  }

  .link-with-icon {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .link-with-icon svg {
    opacity: 0.7;
  }

  /* ─── Footer Bottom ───────────────────────────────────────────── */
  .footer-bottom {
    padding-top: 32px;
  }

  .bottom-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .copyright {
    font-size: 0.8125rem;
    color: var(--label-tertiary);
    margin: 0;
  }

  .legal-links {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .legal-links a {
    font-size: 0.8125rem;
    color: var(--label-tertiary);
    text-decoration: none;
    transition: color 0.25s var(--ease-ios);
  }

  .legal-links a:hover {
    color: var(--ios-blue);
  }

  .divider {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--label-quaternary);
  }

  .developer-link {
    font-weight: 500;
    color: var(--label-secondary) !important;
  }

  .developer-link:hover {
    color: var(--ios-blue) !important;
  }

  /* ─── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .footer {
      padding: 60px 0 32px;
    }

    .cta-banner {
      padding: 32px 24px;
      margin-bottom: 48px;
    }

    .banner-content {
      flex-direction: column;
      text-align: center;
      gap: 24px;
    }

    .banner-title {
      font-size: 1.5rem;
    }

    .banner-cta {
      width: 100%;
      justify-content: center;
    }

    .footer-main {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 40px 0;
    }

    .footer-brand-col {
      max-width: 100%;
      text-align: center;
    }

    .trust-badges {
      justify-content: center;
    }

    .footer-links {
      gap: 32px;
    }

    .bottom-content {
      flex-direction: column;
      text-align: center;
      gap: 16px;
    }

    .legal-links {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .links-list a {
      justify-content: center;
    }
  }

  /* ─── Reveal Animation ────────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s var(--ease-ios-decel), transform 0.7s var(--ease-ios-decel);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
