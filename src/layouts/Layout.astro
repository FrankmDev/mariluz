---
import { siteConfig } from '../config/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.meta.title,
  description = siteConfig.meta.description
} = Astro.props;

const fullTitle = title === siteConfig.meta.title ? title : `${title} | ${siteConfig.name}`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{fullTitle}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteConfig.meta.canonical} />
		<meta property="og:image" content={siteConfig.meta.ogImage} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={siteConfig.meta.ogImage} />

		<!-- Canonical -->
		<link rel="canonical" href={siteConfig.meta.canonical} />

		<!-- LocalBusiness Schema -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": siteConfig.name,
			"description": description,
			"url": siteConfig.meta.canonical,
			"telephone": siteConfig.phone,
			"email": siteConfig.email,
			"areaServed": "ES",
			"serviceType": "Asesoramiento energético",
			"priceRange": "€"
		})} />
	</head>
	<body>
		<!-- Hidden SVG Filters for Premium Glass Effects -->
		<svg style="position: absolute; width: 0; height: 0; overflow: hidden;" aria-hidden="true">
			<defs>
				<!-- Glass refraction distortion -->
				<filter id="glass-distortion" x="-50%" y="-50%" width="200%" height="200%">
					<feGaussianBlur in="SourceGraphic" stdDeviation="0.4" result="blur"/>
					<feTurbulence type="fractalNoise" baseFrequency="0.008 0.012" numOctaves="3" seed="42" result="noise"/>
					<feDisplacementMap in="blur" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G" result="displaced"/>
					<feComposite in="displaced" in2="SourceGraphic" operator="in"/>
				</filter>
				<!-- Subtle glass shimmer -->
				<filter id="glass-shimmer" x="-10%" y="-10%" width="120%" height="120%">
					<feGaussianBlur in="SourceAlpha" stdDeviation="2" result="blur"/>
					<feOffset dx="0" dy="1" in="blur" result="offset"/>
					<feFlood flood-color="white" flood-opacity="0.6" result="color"/>
					<feComposite in="color" in2="offset" operator="in" result="inner-glow"/>
					<feMerge><feMergeNode in="SourceGraphic"/><feMergeNode in="inner-glow"/></feMerge>
				</filter>
			</defs>
		</svg>

		<!-- Custom Cursor -->
		<div class="cursor-dot" aria-hidden="true"></div>
		<div class="cursor-ring" aria-hidden="true"></div>

		<slot />

		<style is:global>
			/* Custom Cursor */
			@media (pointer: fine) {
				* {
					cursor: none !important;
				}

				.cursor-dot {
					position: fixed;
					top: 0;
					left: 0;
					width: 8px;
					height: 8px;
					background: var(--ios-blue);
					border-radius: 50%;
					pointer-events: none;
					z-index: 9999;
					transform: translate(-50%, -50%);
					transition: width 0.2s, height 0.2s, background 0.2s;
					mix-blend-mode: difference;
				}

				.cursor-ring {
					position: fixed;
					top: 0;
					left: 0;
					width: 40px;
					height: 40px;
					border: 1px solid rgba(0, 122, 255, 0.3);
					border-radius: 50%;
					pointer-events: none;
					z-index: 9998;
					transform: translate(-50%, -50%);
					transition: width 0.3s var(--ease-ios-spring), height 0.3s var(--ease-ios-spring), border-color 0.2s;
				}

				.cursor-dot.hover {
					width: 12px;
					height: 12px;
					background: var(--ios-green);
				}

				.cursor-ring.hover {
					width: 60px;
					height: 60px;
					border-color: rgba(52, 199, 89, 0.4);
				}

				.cursor-ring.click {
					width: 30px;
					height: 30px;
				}
			}

			/* Smooth scroll behavior */
			html {
				scroll-behavior: smooth;
			}

			/* Selection color */
			::selection {
				background: rgba(0, 122, 255, 0.2);
				color: inherit;
			}

			/* Focus visible styles */
			:focus-visible {
				outline: 2px solid var(--ios-blue);
				outline-offset: 2px;
			}
		</style>

		<script>
			// Scroll reveal — gentle fade-up intersection observer
			document.addEventListener('DOMContentLoaded', () => {
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
							observer.unobserve(entry.target);
						}
					});
				}, {
					root: null,
					rootMargin: '0px 0px -60px 0px',
					threshold: 0.1
				});

				document.querySelectorAll('.reveal, .reveal-scale').forEach(el => {
					observer.observe(el);
				});
			});

			// Navbar scroll behavior
			const navbar = document.getElementById('navbar');
			if (navbar) {
				window.addEventListener('scroll', () => {
					if (window.scrollY > 10) {
						navbar.classList.add('scrolled');
					} else {
						navbar.classList.remove('scrolled');
					}
				}, { passive: true });
			}

			// Custom Cursor (desktop only)
			if (!window.matchMedia('(pointer: coarse)').matches) {
				const cursorDot = document.querySelector('.cursor-dot');
				const cursorRing = document.querySelector('.cursor-ring');
				
				if (cursorDot && cursorRing) {
					let mouseX = 0, mouseY = 0;
					let ringX = 0, ringY = 0;
					
					document.addEventListener('mousemove', (e) => {
						mouseX = e.clientX;
						mouseY = e.clientY;
						cursorDot.style.left = mouseX + 'px';
						cursorDot.style.top = mouseY + 'px';
					});

					// Smooth ring follow
					const animateRing = () => {
						ringX += (mouseX - ringX) * 0.15;
						ringY += (mouseY - ringY) * 0.15;
						cursorRing.style.left = ringX + 'px';
						cursorRing.style.top = ringY + 'px';
						requestAnimationFrame(animateRing);
					};
					animateRing();
					
					// Hover effects
					const interactiveElements = document.querySelectorAll('a, button, [data-tilt], .faq-item, .step-card, .bento-small, .bento-feature');
					interactiveElements.forEach(el => {
						el.addEventListener('mouseenter', () => {
							cursorDot.classList.add('hover');
							cursorRing.classList.add('hover');
						});
						el.addEventListener('mouseleave', () => {
							cursorDot.classList.remove('hover');
							cursorRing.classList.remove('hover');
						});
					});

					// Click effect
					document.addEventListener('mousedown', () => {
						cursorRing.classList.add('click');
					});
					document.addEventListener('mouseup', () => {
						cursorRing.classList.remove('click');
					});
				}
			}
		</script>
	</body>
</html>
