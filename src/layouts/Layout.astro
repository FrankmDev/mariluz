---
import { siteConfig, faqData } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'service';
  canonical?: string;
  noindex?: boolean;
  keywords?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
    author?: string;
  };
}

const {
  title = siteConfig.meta.title,
  description = siteConfig.meta.description,
  ogImage = siteConfig.meta.ogImage,
  ogType = 'website',
  canonical = siteConfig.meta.canonical,
  noindex = false,
  keywords = siteConfig.meta.keywords,
  article
} = Astro.props;

const fullTitle = title === siteConfig.meta.title ? title : `${title} | ${siteConfig.name}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteConfig.meta.canonical}${ogImage}`;

// Enhanced LocalBusiness Schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "Service", "ProfessionalService"],
  "@id": `${siteConfig.meta.canonical}/#business`,
  "name": siteConfig.name,
  "description": description,
  "url": siteConfig.meta.canonical,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteConfig.meta.canonical}/favicon.svg`,
    "width": 512,
    "height": 512
  },
  "image": ogImageUrl,
  "telephone": siteConfig.phone,
  "email": siteConfig.email,
  "priceRange": siteConfig.business.priceRange,
  "currenciesAccepted": siteConfig.business.currenciesAccepted,
  "paymentAccepted": siteConfig.business.paymentAccepted,
  "areaServed": {
    "@type": "Country",
    "name": siteConfig.location.country,
    "identifier": siteConfig.location.countryCode
  },
  "serviceType": siteConfig.business.serviceType,
  "openingHoursSpecification": siteConfig.business.openingHours.map(hours => ({
    "@type": "OpeningHoursSpecification",
    "opens": hours.split(' ')[1].split('-')[0],
    "closes": hours.split(' ')[1].split('-')[1],
    "dayOfWeek": hours.startsWith('Mo-Fr') 
      ? ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]
      : hours.startsWith('Sa') ? ["Saturday"] : []
  })),
  "founder": {
    "@type": "Person",
    "name": siteConfig.advisor.name,
    "jobTitle": siteConfig.advisor.title,
    "knowsAbout": ["Energía", "Tarifas eléctricas", "Ahorro energético"]
  },
  "foundingDate": `${siteConfig.founded}-01-01`,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": siteConfig.advisor.satisfaction.toString(),
    "reviewCount": siteConfig.advisor.reviews.toString(),
    "bestRating": "5",
    "worstRating": "1"
  },
  "sameAs": [
    siteConfig.whatsappUrl
  ]
};

// Service Schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${siteConfig.meta.canonical}/#service`,
  "serviceType": "Asesoramiento Energético",
  "provider": {
    "@id": `${siteConfig.meta.canonical}/#business`
  },
  "areaServed": {
    "@type": "Country",
    "name": "España"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios de Asesoría Energética",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Análisis de factura de luz",
          "description": "Estudio gratuito de tu factura para encontrar la mejor tarifa"
        },
        "price": "0",
        "priceCurrency": "EUR"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cambio de comercializadora",
          "description": "Gestión completa del cambio de compañía eléctrica sin coste"
        },
        "price": "0",
        "priceCurrency": "EUR"
      }
    ]
  }
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${siteConfig.meta.canonical}/#faq`,
  "mainEntity": faqData.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

// WebSite Schema
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteConfig.meta.canonical}/#website`,
  "url": siteConfig.meta.canonical,
  "name": siteConfig.name,
  "description": description,
  "inLanguage": "es-ES",
  "publisher": {
    "@id": `${siteConfig.meta.canonical}/#business`
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteConfig.meta.canonical}/?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

// BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteConfig.meta.canonical
    }
  ]
};

// Combine all schemas
const allSchemas = [websiteSchema, localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema];
---

<!doctype html>
<html lang="es-ES" dir="ltr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Performance Optimizations -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.svg" />
		<meta name="theme-color" content="#007AFF" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0A0A0A" media="(prefers-color-scheme: dark)" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content={siteConfig.meta.author} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />

		<!-- Language & Region -->
		<meta http-equiv="Content-Language" content="es-ES" />
		<meta property="og:locale" content={siteConfig.meta.locale} />
		<meta name="geo.region" content="ES" />
		<meta name="geo.placename" content="España" />
		<link rel="alternate" hreflang="es-ES" href={canonical} />
		<link rel="alternate" hreflang="x-default" href={canonical} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonical} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={siteConfig.meta.ogImageAlt} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content={siteConfig.name} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonical} />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={siteConfig.meta.ogImageAlt} />
		
		<!-- Article Specific (if applicable) -->
		{article && (
			<>
				<meta property="article:author" content={article.author || siteConfig.meta.author} />
				<meta property="article:published_time" content={article.publishedTime?.toISOString()} />
				{article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime.toISOString()} />}
			</>
		)}
		
		<!-- Mobile App -->
		<meta name="format-detection" content="telephone=yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-title" content={siteConfig.name} />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="mobile-web-app-capable" content="yes" />
		
		<!-- Verification (placeholder - add real values when available) -->
		<!-- <meta name="google-site-verification" content="your-google-verification-code" /> -->
		<!-- <meta name="msvalidate.01" content="your-bing-verification-code" /> -->
		
		<!-- Structured Data -->
		{allSchemas.map((schema, index) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}
	</head>
	<body>
		<!-- Skip to content for accessibility -->
		<a href="#main-content" class="skip-link">Saltar al contenido principal</a>
		
		<!-- Global Unified Background -->
		<div class="global-background" aria-hidden="true">
			<div class="bg-base"></div>
			<div class="bg-orb orb-1"></div>
			<div class="bg-orb orb-2"></div>
			<div class="bg-orb orb-3"></div>
			<div class="bg-orb orb-4"></div>
			<div class="bg-orb orb-5"></div>
			<div class="bg-noise"></div>
		</div>



		<slot />

		<style is:global>
			/* Skip Link for Accessibility */
			.skip-link {
				position: absolute;
				top: -40px;
				left: 0;
				background: var(--color-primary);
				color: white;
				padding: 8px 16px;
				z-index: 10000;
				font-weight: 600;
				border-radius: 0 0 8px 0;
				transition: top 0.3s;
			}
			
			.skip-link:focus {
				top: 0;
			}
			
			/* Smooth scroll behavior */
			html {
				scroll-behavior: smooth;
			}

			/* Selection color */
			::selection {
				background: rgba(0, 122, 255, 0.2);
				color: inherit;
			}

			/* Focus visible styles */
			:focus-visible {
				outline: 2px solid var(--color-primary);
				outline-offset: 2px;
			}

			/* Global Unified Background */
			.global-background {
				position: fixed;
				inset: 0;
				z-index: -1;
				pointer-events: none;
				overflow: hidden;
			}

			.bg-base {
				position: absolute;
				inset: 0;
				background:
					radial-gradient(ellipse 100% 70% at 15% 10%, rgba(0,122,255,0.04) 0%, transparent 55%),
					radial-gradient(ellipse 80% 50% at 85% 15%, rgba(90,200,250,0.03) 0%, transparent 50%),
					radial-gradient(ellipse 60% 40% at 75% 50%, rgba(52,199,89,0.025) 0%, transparent 45%),
					radial-gradient(ellipse 70% 50% at 20% 80%, rgba(88,86,214,0.02) 0%, transparent 50%),
					linear-gradient(180deg, 
						#FAFBFC 0%, 
						#F8F9FA 15%,
						#F5F7F8 35%, 
						#F3F5F7 50%,
						#F1F4F6 65%,
						#F0F3F5 80%,
						#EFF2F4 100%
					);
			}

			.bg-orb {
				position: absolute;
				border-radius: 50%;
				filter: blur(140px);
				pointer-events: none;
			}

			.orb-1 {
				width: 65vw;
				height: 65vw;
				max-width: 800px;
				max-height: 800px;
				top: -15%;
				left: -8%;
				background: radial-gradient(circle, rgba(0,122,255,0.18) 0%, transparent 75%);
				animation: orb-float-1 32s ease-in-out infinite;
			}

			.orb-2 {
				width: 50vw;
				height: 50vw;
				max-width: 600px;
				max-height: 600px;
				top: 10%;
				right: -8%;
				background: radial-gradient(circle, rgba(90,200,250,0.14) 0%, transparent 75%);
				animation: orb-float-2 38s ease-in-out infinite;
			}

			.orb-3 {
				width: 55vw;
				height: 30vw;
				max-width: 650px;
				max-height: 380px;
				top: 40%;
				left: 35%;
				background: radial-gradient(ellipse, rgba(52,199,89,0.10) 0%, transparent 80%);
				animation: orb-float-3 28s ease-in-out infinite;
			}

			.orb-4 {
				width: 40vw;
				height: 40vw;
				max-width: 500px;
				max-height: 500px;
				top: 60%;
				left: -10%;
				background: radial-gradient(circle, rgba(88,86,214,0.12) 0%, transparent 75%);
				animation: orb-float-2 34s ease-in-out infinite reverse;
			}

			.orb-5 {
				width: 45vw;
				height: 45vw;
				max-width: 550px;
				max-height: 550px;
				bottom: -10%;
				right: 5%;
				background: radial-gradient(circle, rgba(0,122,255,0.10) 0%, transparent 75%);
				animation: orb-float-1 36s ease-in-out infinite reverse;
			}

			@keyframes orb-float-1 {
				0%, 100% { 
					transform: translate(0, 0) scale(1); 
					opacity: 0.6; 
				}
				25% { 
					transform: translate(25px, -15px) scale(1.03); 
					opacity: 0.75; 
				}
				50% { 
					transform: translate(40px, 8px) scale(0.98); 
					opacity: 0.65; 
				}
				75% { 
					transform: translate(15px, 25px) scale(1.02); 
					opacity: 0.7; 
				}
			}

			@keyframes orb-float-2 {
				0%, 100% { 
					transform: translate(0, 0) scale(1); 
					opacity: 0.55; 
				}
				33% { 
					transform: translate(-20px, 20px) scale(0.97); 
					opacity: 0.7; 
				}
				66% { 
					transform: translate(-35px, -12px) scale(1.03); 
					opacity: 0.6; 
				}
			}

			@keyframes orb-float-3 {
				0%, 100% { 
					transform: translate(0, 0) scale(1); 
					opacity: 0.45; 
				}
				50% { 
					transform: translate(15px, -25px) scale(1.05); 
					opacity: 0.55; 
				}
			}

			.bg-noise {
				position: absolute;
				inset: 0;
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
				opacity: 0.008;
				mix-blend-mode: overlay;
			}

			@media (prefers-reduced-motion: reduce) {
				.bg-orb {
					animation: none !important;
				}
			}
		</style>

		<script>
			// Unified scroll reveal observer (single instance for entire page)
			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const delay = parseInt((entry.target).dataset.delay || '0') * 80;
						if (delay > 0) {
							setTimeout(() => entry.target.classList.add('visible'), delay);
						} else {
							entry.target.classList.add('visible');
						}
						revealObserver.unobserve(entry.target);
					}
				});
			}, {
				root: null,
				rootMargin: '0px 0px -50px 0px',
				threshold: 0.08
			});

			document.querySelectorAll('.reveal, .reveal-scale').forEach(el => {
				revealObserver.observe(el);
			});

			// Navbar scroll behavior
			const navbar = document.getElementById('navbar');
			if (navbar) {
				window.addEventListener('scroll', () => {
					if (window.scrollY > 10) {
						navbar.classList.add('scrolled');
					} else {
						navbar.classList.remove('scrolled');
					}
				}, { passive: true });
			}

			// Pause CSS animations when tab is hidden to save GPU
			document.addEventListener('visibilitychange', () => {
				const orbs = document.querySelectorAll('.bg-orb');
				orbs.forEach(orb => {
					(orb as HTMLElement).style.animationPlayState = document.hidden ? 'paused' : 'running';
				});
			});
		</script>
	</body>
</html>
